
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Параметры.АдресURL) Тогда
		АдресURL = Параметры.АдресURL;
		HTML = АдресURL;
	Иначе
		HTML = Параметры.HTML;
	КонецЕсли;
	
	ОбновитьДоступностьОткрытияВБраузере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьДоступностьОткрытияВБраузере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура HTMLДокументСформирован(Элемент)
	
	Попытка
		АдресURL = Элемент.Документ.url;
		ОбновитьДоступностьОткрытияВБраузере();
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВБраузере(Команда)
	
	Если НЕ ЗначениеЗаполнено(АдресURL) Тогда
		ПоказатьПредупреждение(, "Адрес страницы ещё не определён. Дождитесь загрузки содержимого.");
		Возврат;
	КонецЕсли;
	
	Попытка
		ЗапуститьПриложение(АдресURL);
	Исключение
		ПоказатьПредупреждение(, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьОткрытияВБраузере()
	
	Доступно = ЗначениеЗаполнено(АдресURL);
	Элементы.ОткрытьВБраузереВерх.Доступность = Доступно;
	
КонецПроцедуры

#КонецОбласти
