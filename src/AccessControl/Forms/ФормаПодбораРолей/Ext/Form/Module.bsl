&НаКлиенте
Процедура УдалитьОтборРоли(Команда)
	
	ЭтотОбъект.ВыбраннаяРоль = Неопределено;
	
	ЭтотОбъект.ТаблицаВхождений.Очистить();
	
	Элементы.УдалитьОтборРоли.Доступность = Ложь;
	
	НайденныеОбъекты = "";
	
	Если НЕ ЗначениеЗаполнено(Объект.Пользователь) Тогда			
		
		СкрытьВидимостьПравДоступаПользователя();
		СменитьНадписьВыборПользователя();
		ОчиститьТаблицыГрупп();
		РолиОбъекта.Очистить();
		
		СменитьНадписьВыборПользователя();
		
	КонецЕсли;	
	
