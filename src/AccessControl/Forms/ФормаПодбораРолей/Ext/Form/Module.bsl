	СоответствиеИмен.Вставить("ПланОбмена", "МетаданныеПланыОбмена");
	СоответствиеИмен.Вставить("КритерийОтбора", "МетаданныеКритерииОтбора");
	СоответствиеИмен.Вставить("ОбщаяКоманда", "МетаданныеОбщиеКоманды");
	СоответствиеИмен.Вставить("Форма", "МетаданныеОбщиеФормы");
	СоответствиеИмен.Вставить("WebСервис", "МетаданныеWebСервисы");
	СоответствиеИмен.Вставить("WebСервисОперация", "МетаданныеWebСервисыОперации");
	СоответствиеИмен.Вставить("HTTPСервис", "МетаданныеHTTPСервисы");
	СоответствиеИмен.Вставить("HTTPШаблонURL", "МетаданныеHTTPСервисыШаблоныURL");
	СоответствиеИмен.Вставить("HTTPМетод", "МетаданныеHTTPСервисыШаблоныURLМетоды");
	СоответствиеИмен.Вставить("Константа", "МетаданныеКонстанты");
	СоответствиеИмен.Вставить("Справочник", "МетаданныеСправочники");
	СоответствиеИмен.Вставить("Документ", "МетаданныеДокументы");
	СоответствиеИмен.Вставить("ЖурналДокументов", "МетаданныеЖурналыДокументов");
	СоответствиеИмен.Вставить("МетаданныеКоманды", "МетаданныеКоманды");
	СоответствиеИмен.Вставить("Отчет", "МетаданныеОтчеты");
	СоответствиеИмен.Вставить("Обработка", "МетаданныеОбработки");
	СоответствиеИмен.Вставить("ПланВидовХарактеристик", "МетаданныеПланыВидовХарактеристик");
	СоответствиеИмен.Вставить("ПланСчетов", "МетаданныеПланыСчетов");
	СоответствиеИмен.Вставить("ПланВидовРасчета", "МетаданныеПланыВидовРасчета");
	СоответствиеИмен.Вставить("РегистрСведений", "МетаданныеРегистрыСведений");
	СоответствиеИмен.Вставить("РегистрНакопления", "МетаданныеРегистрыНакопления");
	СоответствиеИмен.Вставить("РегистрБухгалтерии", "МетаданныеРегистрыБухгалтерии");
	СоответствиеИмен.Вставить("РегистрРасчета", "МетаданныеРегистрыРасчета");
	СоответствиеИмен.Вставить("БизнесПроцесс", "МетаданныеБизнесПроцессы");
	СоответствиеИмен.Вставить("Задача", "МетаданныеЗадачи");
	СоответствиеИмен.Вставить("ВнешнийИсточникДанных", "МетаданныеВнешниеИсточникиДанных");
	
	ИменаДляПоиска = Новый Массив;
	
	ИмяИзКоллекции = СоответствиеИмен.Получить(ИмяКартинки);
	Если ИмяИзКоллекции <> Неопределено Тогда
		ИменаДляПоиска.Добавить(ИмяИзКоллекции);
	КонецЕсли;
	
	ИменаДляПоиска.Добавить(ИмяКартинки);
	
	Если ИмяКартинки = "Конфигурация" Тогда
		ИменаДляПоиска.Добавить("МетаданныеОсновнаяКонфигурация");
	ИначеЕсли ИмяКартинки = "Раздел" Тогда
		ИменаДляПоиска.Добавить("Папка");
	ИначеЕсли ИмяКартинки = "ОбщаяКоманда" Тогда
		ИменаДляПоиска.Добавить("Команда");
	КонецЕсли;
	
	Возврат ИменаДляПоиска;
	
КонецФункции

