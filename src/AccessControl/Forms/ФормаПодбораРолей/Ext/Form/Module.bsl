&НаСервере
Процедура СортироватьСтрокиДереваМетаданных(СтрокиДерева)
	
	СтрокиДерева.Сортировать("ПорядокСортировки");
	
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		СортироватьСтрокиДереваМетаданных(СтрокаДерева.Строки);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьПустыеУзлыДереваМетаданных(СтрокиДерева)
	
	КоличествоЭлементов = СтрокиДерева.Количество();
	
	Для ОбратныйИндекс = 1 По КоличествоЭлементов Цикл
		
		ТекущийИндекс = КоличествоЭлементов - ОбратныйИндекс;
		СтрокаДерева = СтрокиДерева[ТекущийИндекс];
		
		УдалитьПустыеУзлыДереваМетаданных(СтрокаДерева.Строки);
		
		Если СтрокаДерева.Строки.Количество() = 0
			И (ПустаяСтрока(СтрокаДерева.ПолноеИмя) ИЛИ СтрНайти(СтрокаДерева.ПолноеИмя, ".") = 0) Тогда
			СтрокиДерева.Удалить(ТекущийИндекс);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьКаждыйДобавленныйУровень(ДеревоМетаданных, Отбор)
	
	РодителиКУдалению = Новый Соответствие;
	Для Каждого ТекРодитель Из ДеревоМетаданных.Строки Цикл
		
		ХотьОднаСтрокаПопалаПоОтбору = Истина;
		ОбходДереваДляПоиска(ТекРодитель, РодителиКУдалению, Отбор, ХотьОднаСтрокаПопалаПоОтбору, "99", "Уровень1");
		
	КонецЦикла;
	
	УдалитьУровниДереваПослеОтбора(ДеревоМетаданных, РодителиКУдалению);
	
КонецПроцедуры

&НаСервере
Процедура УдалитьУровниДереваПослеОтбора(ДеревоОсновное, РодителиКУдалению)
	
	ВерхниеУровниКУдалению = Новый Массив;
	ВложенныеСтрокиКУдалению = Новый Массив;
	
	Для Каждого Элемент Из РодителиКУдалению Цикл
		
		Если СтрНайти(Элемент.Ключ, "Уровень0") > 0 Тогда
			ВерхниеУровниКУдалению.Добавить(Элемент.Значение.Имя);
		Иначе
			
			ТекУровень = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(НайтиЧислаСконца(Элемент.Ключ)) - 1;
			
			ЧастьИмени = "99";
			Для А = 1 По ТекУровень Цикл
				ЧастьИмени = ЧастьИмени + "9";
			КонецЦикла;
			
			ИмяРодителя = Сред(Элемент.Ключ, 1, СтрНайти(Элемент.Ключ, ЧастьИмени) - 1);
			
			ВложенныеСтрокиКУдалению.Добавить(Новый Структура(
				"ИмяРодителя, ПолноеИмя, Имя",
				ИмяРодителя,
				Элемент.Значение.ПолноеИмя,
				Элемент.Значение.Имя));
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ИмяВерхнегоУровня Из ВерхниеУровниКУдалению Цикл
		
		СтрокаДерева = ДеревоОсновное.Строки.Найти(ИмяВерхнегоУровня, "Имя");
		Если СтрокаДерева <> Неопределено Тогда
			ДеревоОсновное.Строки.Удалить(СтрокаДерева);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ЭлементУдаления Из ВложенныеСтрокиКУдалению Цикл
		
		Если ВерхниеУровниКУдалению.Найти(ЭлементУдаления.ИмяРодителя) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаДерева = НайтиСтрокуДереваМетаданных(ДеревоОсновное, ЭлементУдаления.ПолноеИмя, ЭлементУдаления.Имя);
		Если СтрокаДерева <> Неопределено И СтрокаДерева.Родитель <> Неопределено Тогда
			СтрокаДерева.Родитель.Строки.Удалить(СтрокаДерева);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НайтиСтрокуДереваМетаданных(ДеревоОсновное, ПолноеИмя, Имя)
	
	Возврат НайтиСтрокуДереваМетаданныхРекурсивно(ДеревоОсновное.Строки, ПолноеИмя, Имя);
	
КонецФункции

&НаСервере
Функция НайтиСтрокуДереваМетаданныхРекурсивно(СтрокиДерева, ПолноеИмя, Имя)
	
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		
		Если (НЕ ПустаяСтрока(ПолноеИмя) И СтрокаДерева.ПолноеИмя = ПолноеИмя)
			ИЛИ (ПустаяСтрока(ПолноеИмя) И СтрокаДерева.Имя = Имя) Тогда
			Возврат СтрокаДерева;
		КонецЕсли;
		
		НайденнаяСтрока = НайтиСтрокуДереваМетаданныхРекурсивно(СтрокаДерева.Строки, ПолноеИмя, Имя);
		Если НайденнаяСтрока <> Неопределено Тогда
			Возврат НайденнаяСтрока;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Процедура НоваяСтрокаКоллекцииОбъектовМетаданных(Имя, Синоним, Картинка, КартинкаОбъекта, Таб, ГруппаОбщие = Ложь, Порядок = 0)
	
	НоваяСтрока = Таб.Добавить();
	НоваяСтрока.Имя = Имя;
	НоваяСтрока.Синоним = Синоним;
	НоваяСтрока.Картинка = Картинка;
	НоваяСтрока.КартинкаОбъекта = КартинкаОбъекта;
	НоваяСтрока.ГруппаОбщие = ГруппаОбщие;
	НоваяСтрока.Порядок = Порядок;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбойтиУровеньДерева(КоллекцияСтрок, НаименованиеРоли = Неопределено, ПоискЗавершен = Ложь, Идентификатор = Неопределено)
	
	Если ПоискЗавершен Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Роль из КоллекцияСтрок Цикл 
		
		Если ПоискЗавершен Тогда
			Прервать;
		КонецЕсли;
		
		Если Роль.Имя = НаименованиеРоли Тогда
			Роль.Пометка = Истина; 
			ПоискЗавершен = Истина; 
			Идентификатор = Роль.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
				
		Если Роль.ПолучитьЭлементы().Количество() И НЕ ПоискЗавершен Тогда
			ОбойтиУровеньДерева(Роль.ПолучитьЭлементы(), НаименованиеРоли, ПоискЗавершен, Идентификатор);
		КонецЕсли;
			
	КонецЦикла; 	                           	
	
	Если ПоискЗавершен Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокРолейМетаданных(ПоказатьПустыеРоли)
	
	Если ПоказатьПустыеРоли Тогда
		//TODO 
		
		МассивРолей = Новый Массив;
		
		Для Каждого Роль Из Метаданные.Роли Цикл
			СписокРолейМетаданных.Добавить(Роль.Имя, Роль.Синоним,, БиблиотекаКартинок.ЗакрытыйКлюч);	
		КонецЦикла;
		
	Иначе
		
		Для Каждого Роль Из Метаданные.Роли Цикл		
			СписокРолейМетаданных.Добавить(Роль.Имя, Роль.Синоним,, БиблиотекаКартинок.ЗакрытыйКлюч);		
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция СформироватьСписокРолейПоОтборуНаКлиенте(СтрокаПоиска)
	
	Результат = Новый СписокЗначений;
	СтрокаПоискаВРег = ВРег(СокрЛП(СтрокаПоиска));
	
	Для Каждого ЭлементСписка Из СписокРолейМетаданных Цикл
		
		Если НЕ ПустаяСтрока(СтрокаПоискаВРег) Тогда
			ИмяВРег = ВРег(Строка(ЭлементСписка.Значение));
			СинонимВРег = ВРег(ЭлементСписка.Представление);
			Если СтрНайти(ИмяВРег, СтрокаПоискаВРег) = 0
				И СтрНайти(СинонимВРег, СтрокаПоискаВРег) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Результат.Добавить(
			ЭлементСписка.Значение, ЭлементСписка.Представление,, ЭлементСписка.Картинка);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьСписокВыбораРолейНаКлиенте(СтрокаПоиска)
	
	СписокДляВыбора = СформироватьСписокРолейПоОтборуНаКлиенте(СтрокаПоиска);
	
	Элементы.ВыбраннаяРоль.СписокВыбора.Очистить();
	
	Для Каждого ЭлементСписка Из СписокДляВыбора Цикл
		Элементы.ВыбраннаяРоль.СписокВыбора.Добавить(
			ЭлементСписка.Значение, ЭлементСписка.Представление,, ЭлементСписка.Картинка);
	КонецЦикла;
	
	Подсказка = "Введите имя или синоним роли для поиска";
	Если ЗначениеЗаполнено(СтрокаПоиска) Тогда
		Подсказка = Подсказка + " — найдено: " + Формат(СписокДляВыбора.Количество(), "ЧГ=0");
	Иначе
		Подсказка = Подсказка + " (" + Формат(СписокДляВыбора.Количество(), "ЧГ=0") + ")";
	КонецЕсли;
	Элементы.ВыбраннаяРоль.ПодсказкаВвода = Подсказка;
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьВыбраннуюРоль()
	
	Элементы.УдалитьОтборРоли.Доступность = Истина;
	ПослеВыбораРолиНаСервере(Истина);
	
	Если НЕ ТаблицаВхождений.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ДеревоКонфигурации.ТекущиеДанные <> Неопределено Тогда
		ВыбранныйОбъект = Элементы.ДеревоКонфигурации.ТекущиеДанные.Синоним;
	КонецЕсли;
	
	СменитьНадписьВыборОбъекта();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораПользователя(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("СправочникСсылка.Пользователи") Тогда
		Объект.Пользователь = Результат;
		ПользовательПриИзмененииОбработчик(Неопределено, ДополнительныеПараметры);                         
	ИначеЕсли ТипЗнч(Результат) = Тип("СписокЗначений") Тогда
		ПослеВыбораРоли(Результат[0], Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЕстьРоль(ИмяРоли, Пользователь)
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	1 КАК Поле1,
	               |	ГруппыДоступаПользователи.Ссылка КАК Ссылка,
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь
	               |ИЗ
	               |	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступаРоли.Ссылка
	               |ГДЕ
	               |	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	               |	И ГруппыДоступаПользователи.Пользователь В
	               |			(ВЫБРАТЬ
	               |				ГруппыПользователейСостав.Ссылка КАК ГруппаПользователей
	               |			ИЗ
	               |				Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	               |			ГДЕ
	               |				ГруппыПользователейСостав.Пользователь = &Пользователь)";
	
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Роль", ИмяРоли);
    
    УстановитьПривилегированныйРежим(Истина);
    РезультатЗапроса = Запрос.Выполнить();
    УстановитьПривилегированныйРежим(Ложь);
    
    Если РезультатЗапроса.Пустой() Тогда
        Возврат Ложь;        
    Иначе    
        Возврат Истина;        
    КонецЕсли;
    
КонецФункции

