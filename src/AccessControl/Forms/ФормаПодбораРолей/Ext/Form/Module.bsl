&НаКлиенте
Процедура РедактироватьОграничения(Команда)
		
	ТекДанныеГруппДоступа = Элементы.ТаблицаГруппДоступа.ТекущиеДанные;
	Если ТекДанныеГруппДоступа = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ФормаГруппДоступа = ПолучитьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента", Новый Структура("Ключ", ТекДанныеГруппДоступа.ГруппаДоступа), ЭтотОбъект);
	ФормаГруппДоступа.ПодчиненныеЭлементы.ПользователиИДоступ.ТекущаяСтраница = ФормаГруппДоступа.Элементы.ПользователиИДоступ.ПодчиненныеЭлементы.Доступ;
	ФормаГруппДоступа.Открыть();
	
	СтрокаКоллекции = ТаблицаГруппДоступа.НайтиПоИдентификатору(Элементы.ТаблицаГруппДоступа.ТекущаяСтрока);
	ИндексСтрокиКоллекции = ТаблицаГруппДоступа.Индекс(СтрокаКоллекции);
	
	СтрокаОграничения = ВидыДоступа.НайтиПоИдентификатору(Элементы.ВидыДоступа.ТекущаяСтрока);
	ИндексСтрокиОграничения =  ВидыДоступа.Индекс(СтрокаОграничения);
	
	ОО = Новый ОписаниеОповещения("ПослеРедактированияОграничений", ЭтотОбъект, Новый Структура("ИндексСтрокиКоллекции, ИндексСтрокиОграничения", ИндексСтрокиКоллекции, ИндексСтрокиОграничения));
	ПараметрыОткрытия = Новый Структура("Ключ", ТекДанныеГруппДоступа.ГруппаДоступа);
	ОткрытьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента", ПараметрыОткрытия, ЭтотОбъект,, ФормаГруппДоступа.Окно,, ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

