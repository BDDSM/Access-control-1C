&НаСервере
Процедура ЗаполнитьПодчиненныеПодсистемы(ПодсистемаРодитель, СтрокаДерева, Картинка)
	
	СтрокаДереваОМ = СтрокаДерева.Строки.Добавить();
	СтрокаДереваОМ.Имя       = ПодсистемаРодитель.Имя;
	СтрокаДереваОМ.ПолноеИмя = ПодсистемаРодитель.ПолноеИмя();
	СтрокаДереваОМ.Синоним   = ПодсистемаРодитель.Синоним;
	СтрокаДереваОМ.Картинка  = Картинка;
	
	Для Каждого Подсистема Из ПодсистемаРодитель.Подсистемы Цикл
		ЗаполнитьПодчиненныеПодсистемы(Подсистема, СтрокаДереваОМ, Картинка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДеревоМетаданныхКонфигурации(Отбор = Неопределено, ОтборЗадан = Ложь, ЭтоПоискРоли = Ложь)
	
	ИспользоватьОтбор = (Отбор <> Неопределено);
	
	КоллекцииОбъектовМетаданных = Новый ТаблицаЗначений;
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Имя");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Синоним");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Картинка");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("КартинкаОбъекта");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("ГруппаОбщие");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Порядок");
	
	Если НЕ ОтборЗадан Тогда
		ЗаполнитьСписокЗначений();
	КонецЕсли;
	
	ОписанияКоллекций = ПолучитьОписаниеКоллекцийМетаданных();
	СоответствиеОписаний = Новый Соответствие;
	Для Каждого ОписаниеКоллекции Из ОписанияКоллекций Цикл
		СоответствиеОписаний.Вставить(ОписаниеКоллекции.Имя, ОписаниеКоллекции);
	КонецЦикла;
	
	Для Каждого Мета Из СписокМетаданных Цикл
		
		Если ОтборЗадан И НЕ Мета.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеКоллекции = СоответствиеОписаний.Получить(Мета.Значение);
		Если ОписаниеКоллекции = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаКоллекцииОбъектовМетаданных(
			ОписаниеКоллекции.Имя,
			ОписаниеКоллекции.Синоним,
			ОписаниеКоллекции.Картинка,
			ОписаниеКоллекции.Картинка,
			КоллекцииОбъектовМетаданных,
			ОписаниеКоллекции.ГруппаОбщие,
			ОписаниеКоллекции.Порядок);
		
	КонецЦикла;
	
	ДеревоМетаданных = Новый ДеревоЗначений;
	ДеревоМетаданных.Колонки.Добавить("Имя");
	ДеревоМетаданных.Колонки.Добавить("ПолноеИмя");
	ДеревоМетаданных.Колонки.Добавить("Синоним");
	ДеревоМетаданных.Колонки.Добавить("Картинка");
	ДеревоМетаданных.Колонки.Добавить("ПорядокСортировки");
	
	СтрокаОбщие = Неопределено;
	
	Для Каждого СтрокаКоллекции Из КоллекцииОбъектовМетаданных Цикл
		
		Если СтрокаКоллекции.ГруппаОбщие Тогда
			
			Если СтрокаОбщие = Неопределено Тогда
				СтрокаОбщие = ДеревоМетаданных.Строки.Добавить();
				СтрокаОбщие.Имя = "Общие";
				СтрокаОбщие.Синоним = "Общие";
				СтрокаОбщие.Картинка = КартинкаКоллекцииМетаданных("Раздел");
				СтрокаОбщие.ПорядокСортировки = 1;
			КонецЕсли;
			
			СтрокаДерева = СтрокаОбщие.Строки.Добавить();
			
		Иначе
			СтрокаДерева = ДеревоМетаданных.Строки.Добавить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаКоллекции);
		СтрокаДерева.ПорядокСортировки = СтрокаКоллекции.Порядок;
		
		ЗаполнитьОбъектыКоллекцииВДереве(
			СтрокаДерева,
			СтрокаКоллекции,
			Отбор,
			ИспользоватьОтбор,
			ЭтоПоискРоли,
			ДеревоМетаданных);
		
	КонецЦикла;
	
	СортироватьСтрокиДереваМетаданных(ДеревоМетаданных.Строки);
	
	Если ИспользоватьОтбор Тогда
		УдалитьПустыеУзлыДереваМетаданных(ДеревоМетаданных.Строки);
	КонецЕсли;
	
	Возврат ДеревоМетаданных;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьОбъектыКоллекцииВДереве(СтрокаДерева, СтрокаКоллекции, Отбор, ИспользоватьОтбор, ЭтоПоискРоли, ДеревоМетаданных)
	
	Если СтрокаКоллекции.Имя = "Подсистемы" Тогда
		
		Для Каждого ОбъектМетаданных Из Метаданные[СтрокаКоллекции.Имя] Цикл
			ЗаполнитьПодчиненныеПодсистемы(ОбъектМетаданных, СтрокаДерева, СтрокаКоллекции.КартинкаОбъекта);
		КонецЦикла;
		
		Если ЭтоПоискРоли И ИспользоватьОтбор Тогда
			ПроверитьКаждыйДобавленныйУровень(ДеревоМетаданных, Отбор);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	Для Каждого ОбъектМетаданных Из Метаданные[СтрокаКоллекции.Имя] Цикл
		
		Если ИспользоватьОтбор Тогда
			
			ОбъектПрошелФильтр = Истина;
			Для Каждого ЭлементОтбора Из Отбор Цикл
				
				Значение = ?(ВРег(ЭлементОтбора.Ключ) = ВРег("ПолноеИмя"), ОбъектМетаданных.ПолноеИмя(), ОбъектМетаданных[ЭлементОтбора.Ключ]);
				Если ЭлементОтбора.Значение.Найти(Значение) = Неопределено Тогда
					ОбъектПрошелФильтр = Ложь;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
			Если Не ОбъектПрошелФильтр Тогда
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаДереваОМ = СтрокаДерева.Строки.Добавить();
		СтрокаДереваОМ.Имя = ОбъектМетаданных.Имя;
		СтрокаДереваОМ.ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		СтрокаДереваОМ.Синоним = ОбъектМетаданных.Синоним;
		СтрокаДереваОМ.Картинка = СтрокаКоллекции.КартинкаОбъекта;
		
		Если СтрокаКоллекции.Имя = "WebСервисы" Тогда
			ЗаполнитьОперацииWebСервисаВДереве(
				ОбъектМетаданных,
				СтрокаДереваОМ,
				КартинкаКоллекцииМетаданных("WebСервисОперация"));
		ИначеЕсли СтрокаКоллекции.Имя = "HTTPСервисы" Тогда
			ЗаполнитьШаблоныHTTPСервисаВДереве(
				ОбъектМетаданных,
				СтрокаДереваОМ,
				КартинкаКоллекцииМетаданных("HTTPШаблонURL"),
				КартинкаКоллекцииМетаданных("HTTPМетод"));
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОперацииWebСервисаВДереве(ОбъектМетаданных, СтрокаСервиса, КартинкаОперации)
	
	Попытка
		КоллекцияОпераций = ОбъектМетаданных.Операции;
	Исключение
		Возврат;
	КонецПопытки;
	
	Для Каждого Операция Из КоллекцияОпераций Цикл
		
		СтрокаОперации = СтрокаСервиса.Строки.Добавить();
		СтрокаОперации.Имя = Операция.Имя;
		СтрокаОперации.ПолноеИмя = Операция.ПолноеИмя();
		СтрокаОперации.Синоним = Операция.Синоним;
		СтрокаОперации.Картинка = КартинкаОперации;
		СтрокаОперации.ПорядокСортировки = 0;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШаблоныHTTPСервисаВДереве(ОбъектМетаданных, СтрокаСервиса, КартинкаШаблона, КартинкаМетода)
	
	Попытка
		КоллекцияШаблонов = ОбъектМетаданных.ШаблоныURL;
	Исключение
		Возврат;
	КонецПопытки;
	
	Для Каждого ШаблонURL Из КоллекцияШаблонов Цикл
		
		СтрокаШаблона = СтрокаСервиса.Строки.Добавить();
		СтрокаШаблона.Имя = ШаблонURL.Имя;
		СтрокаШаблона.Синоним = ШаблонURL.Синоним;
		СтрокаШаблона.Картинка = КартинкаШаблона;
		СтрокаШаблона.ПорядокСортировки = 0;
		
		Попытка
			КоллекцияМетодов = ШаблонURL.Методы;
		Исключение
			Продолжить;
		КонецПопытки;
		
		Для Каждого Метод Из КоллекцияМетодов Цикл
			
			СтрокаМетода = СтрокаШаблона.Строки.Добавить();
			СтрокаМетода.Имя = Метод.Имя;
			СтрокаМетода.ПолноеИмя = Метод.ПолноеИмя();
			СтрокаМетода.Синоним = Метод.Синоним;
			СтрокаМетода.Картинка = КартинкаМетода;
			СтрокаМетода.ПорядокСортировки = 0;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЭтоОбъектПравДоступа(ПолноеИмя)
	
	Если НЕ ЗначениеЗаполнено(ПолноеИмя) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если СтрНайти(ПолноеИмя, ".") = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ВидОбъекта = Лев(ПолноеИмя, СтрНайти(ПолноеИмя, ".") - 1);
	ПолноеИмяВерхний = ВРег(ПолноеИмя);
	
	Если ВидОбъекта = "WebСервис" Тогда
		Возврат СтрНайти(ПолноеИмяВерхний, ".ОПЕРАЦИЯ.") > 0;
	ИначеЕсли ВидОбъекта = "HTTPСервис" Тогда
		Возврат СтрНайти(ПолноеИмяВерхний, ".МЕТОД.") > 0;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

