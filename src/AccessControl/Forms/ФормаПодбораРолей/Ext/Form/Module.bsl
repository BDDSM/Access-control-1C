Процедура СкопироватьПрава(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Источник", Объект.Пользователь);
	ПараметрыОткрытия.Вставить("Организация", ЭтотОбъект.МестоРаботы);
	ПараметрыОткрытия.Вставить("Должность", ЭтотОбъект.Должность);
	
	ОО = Новый ОписаниеОповещения("ПослеКопированияПрав", ЭтотОбъект);
	
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаСкопироватьПраваПользователя", ПараметрыОткрытия, ЭтотОбъект,,,, ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
