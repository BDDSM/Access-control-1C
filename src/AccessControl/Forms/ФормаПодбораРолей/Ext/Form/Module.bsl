	ПараметрыФормы.Вставить("Пользователи", МассивПользователь);
	ПараметрыФормы.Вставить("ВнешниеПользователи", Ложь);
	
	ОткрытьФорму("ОбщаяФорма.ГруппыПользователей", ПараметрыФормы, ЭтотОбъект,,,, ОО);
	
