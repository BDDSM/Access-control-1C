#Область ОграниченияДоступа

&НаКлиентеНаСервереБезКонтекста
Функция КлючВидаДоступа(ВидДоступаСсылка)
	
	Если НЕ ЗначениеЗаполнено(ВидДоступаСсылка) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка(ВидДоступаСсылка.УникальныйИдентификатор());
	
КонецФункции

&НаКлиенте
Функция СсылкаВидаДоступаИзСтроки(СтрокаВидаДоступа)
	
	Если СтрокаВидаДоступа = Неопределено
		ИЛИ НЕ ЗначениеЗаполнено(СтрокаВидаДоступа.ВидДоступаСсылка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СтрокаВидаДоступа.ВидДоступаСсылка;
	
КонецФункции

&НаКлиенте
Функция КартинкаЗначенияДоступа(ЗначениеДоступа)
	
	Если НЕ ЗначениеЗаполнено(ЗначениеДоступа) Тогда
		Возврат БиблиотекаКартинок.Пустая;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(ЗначениеДоступа);
	
	Если ТипЗначения = Тип("СправочникСсылка.Пользователи") Тогда
		Возврат БиблиотекаКартинок.Пользователь;
	ИначеЕсли ТипЗначения = Тип("СправочникСсылка.ГруппыПользователей") Тогда
		Возврат Элементы.ДекорацияКартинкаГруппаПользователя.Картинка;
	ИначеЕсли ТипЗначения = Тип("СправочникСсылка.Организации") Тогда
		Возврат Элементы.ДекорацияКартинкаОрганизация.Картинка;
	Иначе                                       
		Возврат БиблиотекаКартинок.Справочник;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ЭтоВидДоступаПользователи(СтрокаВидаДоступа)
	
	Для Каждого СтрокаЗначения Из ТаблицаЗначенияДоступа Цикл
		
		Если СтрокаЗначения.КлючВидаДоступа <> СтрокаВидаДоступа.КлючВидаДоступа Тогда
			Продолжить;
		КонецЕсли;
		
		ТипЗначения = ТипЗнч(СтрокаЗначения.ЗначениеДоступа);
		Если ТипЗначения = Тип("СправочникСсылка.Пользователи")
			ИЛИ ТипЗначения = Тип("СправочникСсылка.ГруппыПользователей") Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтрНайти(СтрокаВидаДоступа.ВидДоступа, "Пользовател") > 0;
	
КонецФункции

&НаКлиенте
Функция ЭтоВидДоступаОрганизации(СтрокаВидаДоступа)
	
	Для Каждого СтрокаЗначения Из ТаблицаЗначенияДоступа Цикл
		
		Если СтрокаЗначения.КлючВидаДоступа <> СтрокаВидаДоступа.КлючВидаДоступа Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(СтрокаЗначения.ЗначениеДоступа) = Тип("СправочникСсылка.Организации") Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтрНайти(СтрокаВидаДоступа.ВидДоступа, "Организац") > 0;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьЗначенияДоступаДляВида(СтрокаВидаДоступа)
	
	ЗначенияДоступа.Очистить();
	
	Если СтрокаВидаДоступа = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаЗначения Из ТаблицаЗначенияДоступа Цикл
		
		Если СтрокаЗначения.КлючВидаДоступа <> СтрокаВидаДоступа.КлючВидаДоступа Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ЗначенияДоступа.Добавить();
		НоваяСтрока.ЗначениеДоступа = СтрокаЗначения.ЗначениеДоступа;
		НоваяСтрока.Картинка = КартинкаЗначенияДоступа(СтрокаЗначения.ЗначениеДоступа);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПризнакиЗначенийДоступаПользователя(ЗначениеПользователь, ЗначениеОрганизация)
	
	ЗначениеПользовательЕсть = Ложь;
	ЗначениеОрганизацияЕсть = Ложь;
	
	Для Каждого Строка Из ЗначенияДоступа Цикл
		
		Строка.ПризнакВхожденияВГруппу = Ложь;
		Строка.ПризнакНаличияЗначения = Ложь;
		
		Если ЗначениеПользователь Тогда
			
			Строка.ПризнакВхожденияВГруппу = Строка.ЗначениеДоступа = Объект.Пользователь;
			Строка.ПризнакНаличияЗначения = Строка.ЗначениеДоступа = Объект.Пользователь;
			ЗначениеПользовательЕсть = ЗначениеПользовательЕсть ИЛИ Строка.ПризнакНаличияЗначения;
			
			Если ТипЗнч(Строка.ЗначениеДоступа) = Тип("СправочникСсылка.ГруппыПользователей") Тогда
				
				НайденнаяСтрока = ГруппыПользователя.НайтиСтроки(Новый Структура("Группа", Строка.ЗначениеДоступа));
				Строка.ПризнакВхожденияВГруппу = НайденнаяСтрока.Количество() > 0;
				Строка.ПризнакНаличияЗначения = НайденнаяСтрока.Количество() > 0;
				ЗначениеПользовательЕсть = ЗначениеПользовательЕсть ИЛИ Строка.ПризнакНаличияЗначения;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеОрганизация Тогда
			
			Строка.ПризнакВхожденияВГруппу = Строка.ЗначениеДоступа = МестоРаботы;
			Строка.ПризнакНаличияЗначения = Строка.ЗначениеДоступа = МестоРаботы;
			ЗначениеОрганизацияЕсть = ЗначениеОрганизацияЕсть ИЛИ Строка.ПризнакНаличияЗначения;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		
		Элементы.ИсключитьОрганизациюИзШаблона.Видимость = ЗначениеОрганизация И ЗначениеОрганизацияЕсть;
		Элементы.ДобавитьОрганизациюВШаблон.Видимость = ЗначениеОрганизация И НЕ ЗначениеОрганизацияЕсть;
		Элементы.ИсключитьПользователяИзШаблона.Видимость = ЗначениеПользователь И ЗначениеПользовательЕсть;
		Элементы.ДобавитьПользователяВШаблон.Видимость = ЗначениеПользователь И НЕ ЗначениеПользовательЕсть;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТаблицыОграниченийДоступа()
	
	ВидыДоступа.Очистить();
	ЗначенияДоступа.Очистить();
	ТаблицаЗначенияДоступа.Очистить();
	ВыбраннаяГруппаДоступа = Неопределено;
	
	Элементы.РедактироватьШаблоныОграничений.Доступность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВидыДоступаГруппы(ФормаДоступа)
	
	ВидыДоступа.Очистить();
	
	ТаблицаВидыДоступа = ФормаДоступа.Объект.ВидыДоступа;
	КлючиДобавленных = Новый Соответствие;
	
	Для Каждого Строка Из ТаблицаВидыДоступа Цикл
		
		Если НЕ Строка.ВсеРазрешены Тогда
			
			НоваяСтрока = ВидыДоступа.Добавить();
			НоваяСтрока.ВидДоступа = Строка.ВидДоступаПредставление;
			НоваяСтрока.ЗначенияДоступа = Строка.ВсеРазрешеныПредставление;
			НоваяСтрока.КлючВидаДоступа = КлючВидаДоступа(Строка.ВидДоступа);
			НоваяСтрока.ВидДоступаСсылка = Строка.ВидДоступа;
			КлючиДобавленных.Вставить(НоваяСтрока.КлючВидаДоступа, Истина);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокаЗначения Из ФормаДоступа.Объект.ЗначенияДоступа Цикл
		
		Ключ = КлючВидаДоступа(СтрокаЗначения.ВидДоступа);
		Если ПустаяСтрока(Ключ) ИЛИ КлючиДобавленных[Ключ] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Представление = Строка(СтрокаЗначения.ВидДоступа);
		СтрокиВида = ТаблицаВидыДоступа.НайтиСтроки(Новый Структура("ВидДоступа", СтрокаЗначения.ВидДоступа));
		Если СтрокиВида.Количество() > 0 Тогда
			Представление = СтрокиВида[0].ВидДоступаПредставление;
		КонецЕсли;
		
		НоваяСтрока = ВидыДоступа.Добавить();
		НоваяСтрока.ВидДоступа = Представление;
		НоваяСтрока.ЗначенияДоступа = "";
		НоваяСтрока.КлючВидаДоступа = Ключ;
		НоваяСтрока.ВидДоступаСсылка = СтрокаЗначения.ВидДоступа;
		КлючиДобавленных.Вставить(Ключ, Истина);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьПервуюГруппуДоступа()
	
	Если ТаблицаГруппДоступа.Количество() = 0 Тогда
		ОчиститьТаблицыОграниченийДоступа();
		Возврат;
	КонецЕсли;
	
	ВыбраннаяГруппаДоступа = Неопределено;
	Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = ТаблицаГруппДоступа[0].ПолучитьИдентификатор();
	ТаблицаГруппДоступаПриАктивизацииСтроки(Элементы.ТаблицаГруппДоступа);
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьПервыйВидДоступа()
	
	Если ВидыДоступа.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ВидыДоступа.ТекущаяСтрока = ВидыДоступа[0].ПолучитьИдентификатор();
	ВидыДоступаПриАктивизацииСтроки(Элементы.ВидыДоступа);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ТаблицаГруппДоступаПриАктивизацииСтроки(Элемент)
	
	ТекДанные = Элемент.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ВыбраннаяГруппаДоступа = Неопределено И ВыбраннаяГруппаДоступа = ТекДанные.ГруппаДоступа Тогда
		Возврат;
	КонецЕсли;   
	ВыбраннаяГруппаДоступа = ТекДанные.ГруппаДоступа;
	
	ВидыДоступа.Очистить();
	ЗначенияДоступа.Очистить();
	ТаблицаЗначенияДоступа.Очистить();
	
	ФормаДоступа = ПолучитьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента", Новый Структура("Ключ", Элемент.ТекущиеДанные.ГруппаДоступа), ЭтотОбъект);

	ЗаполнитьВидыДоступаГруппы(ФормаДоступа);
	
	КопияЗначенийДоступа = ФормаДоступа.Объект.ЗначенияДоступа;
	
	Для Каждого Строка Из КопияЗначенийДоступа Цикл
		
		НоваяСтрока = ТаблицаЗначенияДоступа.Добавить();
		НоваяСтрока.ЗначениеДоступа = Строка.ЗначениеДоступа;
		НоваяСтрока.КлючВидаДоступа = КлючВидаДоступа(Строка.ВидДоступа);
		
	КонецЦикла;
	
	Элементы.ВключитьВГруппу.Видимость = НЕ Элемент.ТекущиеДанные.ПризнакНаличияГруппы;
	Элементы.ИсключитьИзГруппы.Видимость = Элемент.ТекущиеДанные.ПризнакНаличияГруппы;
	
	АктивироватьПервыйВидДоступа();

КонецПроцедуры

&НаКлиенте
Процедура ВидыДоступаПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Элементы.РедактироватьШаблоныОграничений.Доступность = Ложь;
		ЗначенияДоступа.Очистить();
		Возврат;
	КонецЕсли;
	
	Элементы.РедактироватьШаблоныОграничений.Доступность = Истина;
	
	Элементы.ДобавитьПользователяВШаблон.Видимость = Ложь;
	Элементы.ДобавитьОрганизациюВШаблон.Видимость = Ложь;
	Элементы.ИсключитьПользователяИзШаблона.Видимость = Ложь;
	Элементы.ИсключитьОрганизациюИзШаблона.Видимость = Ложь;
	
	ЗаполнитьЗначенияДоступаДляВида(Элемент.ТекущиеДанные);
	
	ЗначениеПользователь = ЭтоВидДоступаПользователи(Элемент.ТекущиеДанные);
	ЗначениеОрганизация = ЭтоВидДоступаОрганизации(Элемент.ТекущиеДанные);
	ОбновитьПризнакиЗначенийДоступаПользователя(ЗначениеПользователь, ЗначениеОрганизация);

КонецПроцедуры

&НаКлиенте
Процедура РолиОбъектаПриАктивизацииСтроки(Элемент)
	
	ТекДанные = Элемент.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбраннаяРольТаблицы = ТекДанные.Роль Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяРольТаблицы = ТекДанные.Роль;
	ВыбраннаяГруппаДоступа = Неопределено;
	
	Элементы.СоздатьНовуюГруппу.Заголовок = "Создать новую группу доступа [" + ТекДанные.РольПредставление + "]";
	
	РолиОбъектаВыборНаСервере(Элемент.ТекущиеДанные.Роль);
	АктивироватьПервуюГруппуДоступа();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоКонфигурацииПриАктивизацииСтроки(Элемент)
	
	ТекДанные = Элементы.ДеревоКонфигурации.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КлючТекущейСтроки = Строка(Элемент.ТекущаяСтрока);
	
	Если СтрокаБылаПеревыбрана = КлючТекущейСтроки Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаБылаПеревыбрана = КлючТекущейСтроки;
	
	ПолноеИмяТекущего = ТекДанные.ПолноеИмя;
	
	Если НЕ ЗначениеЗаполнено(ПолноеИмяТекущего) И ЭтоОткрытиеФормы <> 1 Тогда
		СменитьНадписьВыборОбъекта();
		Возврат;
	КонецЕсли;
	
	Если ЭтоОткрытиеФормы = 1 Тогда
		ЭтоОткрытиеФормы = 2;
		Возврат;
	КонецЕсли;
	
	ТекДанные = Элемент.ТекущиеДанные;
	
	Если ТекДанные <> Неопределено Тогда
		Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Зеленый;
		Элементы.ДекорацияКартинкаМетаданных.Картинка = ТекДанные.Картинка;	
		ЭтотОбъект.ПолноеИмяОбъекта = ПолноеИмяТекущего;
	КонецЕсли;
	
	ВыбранныйОбъект = ТекДанные.Синоним;
	ВыбраннаяРольТаблицы = Неопределено;
	ВыбраннаяГруппаДоступа = Неопределено;
	ОчиститьТаблицыГрупп();
	
	Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) И ЭтоОбъектПравДоступаНаСервере(ПолноеИмяОбъекта) Тогда
		
		НайтиРолиВОбъекте(ПолноеИмяОбъекта);
		
		ВыбранныйОбъект = ТекДанные.Синоним;
		
		СменитьНадписьВыборОбъекта(Истина);
		
		Если РолиОбъекта.Количество() > 0 Тогда
			ВыбраннаяРольТаблицы = РолиОбъекта[0].Роль;
			Элементы.РолиОбъекта.ТекущаяСтрока = РолиОбъекта[0].ПолучитьИдентификатор();
			Элементы.СоздатьНовуюГруппу.Заголовок = "Создать новую группу доступа [" + РолиОбъекта[0].РольПредставление + "]";
			АктивироватьПервуюГруппуДоступа();
		Иначе
			ВыбраннаяРольТаблицы = Неопределено;
			ОчиститьТаблицыОграниченийДоступа();
			Элементы.ДекорацияКартинкаМетаданных.Картинка = БиблиотекаКартинок.Внимание16;
			Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Красный;
			ВыбранныйОбъект = "Нет данных";
		КонецЕсли;
		
	ИначеЕсли НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
		
		РолиОбъекта.Очистить();
		Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Зеленый;
		ВыбранныйОбъект = ТекДанные.Синоним + " — выберите команду, операцию или метод HTTP";
		СменитьНадписьВыборОбъекта();
		
	Иначе
		Элементы.ДекорацияКартинкаМетаданных.Картинка = БиблиотекаКартинок.Внимание16;
		Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Красный;
		ВыбранныйОбъект = "Нет данных";
		ОчиститьТаблицыГрупп();
		ЭтотОбъект.РолиОбъекта.Очистить();
	КонецЕсли;
	
КонецПроцедуры

