	//		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	//		НоваяСтрока.ДатаИсправления = ТекущаяДата();
	//		
	//	КонецЦикла;
	//		
	//
	//	ВыполнитьАвтоматическийАнализОшибок();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы  

&НаКлиенте
Процедура СтрокаПоискаОчистка(Элемент, СтандартнаяОбработка)
	
	СтрокаПоиска = "";
	ПрименитьПоискДереваМетаданных("");
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаПоискаПриИзмененииТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	
	ПрименитьПоискДереваМетаданных(Текст);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьПоискДереваМетаданных(Текст)
	
	ПрименитьОтборДереваМетаданныхНаСервере(Текст);
	ВосстановитьТекстВПолеПоискаДерева(Текст);
	
	Если НЕ ПустаяСтрока(СокрЛП(Текст)) Тогда
		РазвернутьДеревоРекурсивно(ДеревоКонфигурации);
		ВосстановитьТекстВПолеПоискаДерева(Текст);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьТекстВПолеПоискаДерева(Текст)
	
	СтрокаПоиска = Текст;
	
	Попытка
		Элементы.СтрокаПоиска.ТекстРедактирования = Текст;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОбновлениеОбработкиОтложенно()
	
	Если НЕ ПроверятьНаличиеОбновлений Тогда
		Возврат;
	КонецЕсли;
	
	РезультатПроверки = ПроверитьОбновлениеОбработкиНаСервере();
	ПрименитьСтатусОбновленияНаКлиенте(РезультатПроверки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьСтатусОбновленияНаКлиенте(РезультатПроверки)
	
	ПрименитьСтатусОбновленияНаСервере(РезультатПроверки);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияСтатусОбновленияНажатие(Элемент)
	
	Если НЕ ЗначениеЗаполнено(АдресСтраницыРелизов) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ЗапуститьПриложение(АдресСтраницыРелизов);
	Исключение
		ПоказатьПредупреждение(, ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьОтображениеВерсии() Экспорт
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	Версия = ТекОбъект.ВерсияОбработки();
	Элементы.ДекорацияВерсияОбработки.Заголовок = "v." + Версия;
	АдресСтраницыРелизов = ТекОбъект.URLСтраницыРелизов();
	
	Если НЕ ПроверятьНаличиеОбновлений Тогда
		Элементы.ДекорацияСтатусОбновления.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.ДекорацияСтатусОбновления.Видимость = Истина;
	ПрименитьСтатусОбновленияНаСервере(Новый Структура(
		"Состояние, Заголовок, Подсказка, ЭтоГиперссылка, АдресПерехода",
		"Проверка", "проверка…", "Проверка наличия обновлений на GitHub…", Ложь, АдресСтраницыРелизов));
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьСтатусОбновленияНаСервере(РезультатПроверки)
	
	ЭлементСтатуса = Элементы.ДекорацияСтатусОбновления;
	ЭлементСтатуса.Заголовок = РезультатПроверки.Заголовок;
	ЭлементСтатуса.Подсказка = РезультатПроверки.Подсказка;
	ЭлементСтатуса.Гиперссылка = РезультатПроверки.ЭтоГиперссылка;
	АдресСтраницыРелизов = РезультатПроверки.АдресПерехода;
	
	Если РезультатПроверки.Состояние = "Актуальная" Тогда
		ЭлементСтатуса.ЦветТекста = Новый Цвет(34, 139, 34);
	ИначеЕсли РезультатПроверки.Состояние = "ДоступноОбновление" Тогда
		ЭлементСтатуса.ЦветТекста = Новый Цвет(204, 102, 0);
	ИначеЕсли РезультатПроверки.Состояние = "НовееРелиза" Тогда
		ЭлементСтатуса.ЦветТекста = Новый Цвет(28, 85, 174);
	Иначе
		ЭлементСтатуса.ЦветТекста = WebЦвета.Silver;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьОбновлениеОбработкиНаСервере()
	
	Возврат РеквизитФормыВЗначение("Объект").ПолучитьСтатусПроверкиОбновления();
	
КонецФункции

&НаКлиенте
Процедура ДекорацияПраваДоступаНажатие(Элемент)
	
	ПараметрыОткрытия = Новый Структура("Пользователь", Объект.Пользователь);
	ОткрытьФорму("ОбщаяФорма.ПраваДоступа", ПараметрыОткрытия, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользовательПриИзмененииОбработчик(Элемент, СтруктураПараметров = Неопределено)
	
	ОбъектВыбран = Неопределено;
	
	Если Объект.Пользователь <> ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка") Тогда
		
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			ОбъектВыбран = Истина;
			НайтиРолиВОбъекте(ПолноеИмяОбъекта);
		КонецЕсли;
		
		СтруктураАналитики = ПолучитьАналитикуПользователя(); 
		
		Если СтруктураАналитики <> Неопределено Тогда
			
			Должность 					   = ?(СтруктураАналитики.Свойство("Должность"), СтруктураАналитики.Должность, "Не удалось определить");
			Элементы.Должность.Гиперссылка = ?(СтруктураАналитики.Свойство("Должность"), Истина, Ложь);
			Элементы.Должность.ЦветТекста  = ?(СтруктураАналитики.Свойство("Должность"), Новый Цвет(28, 85, 174), WebЦвета.Красный);
			
			МестоРаботы 					 = ?(СтруктураАналитики.Свойство("Организация"), СтруктураАналитики.Организация, "Не удалось определить");
			Элементы.МестоРаботы.Гиперссылка = ?(СтруктураАналитики.Свойство("Организация"), Истина, Ложь);            
			Элементы.МестоРаботы.ЦветТекста  = ?(СтруктураАналитики.Свойство("Организация"), Новый Цвет(28, 85, 174), WebЦвета.Красный);
			
		КонецЕсли;
		
		УстановитьВидимостьЭлементов();
		СменитьНадписьВыборОбъекта(ОбъектВыбран);
		
	КонецЕсли;
	
	Если ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		
		Если СтруктураПараметров.ИмяТаблицы = "РолиОбъекта" Тогда
			СтрокаКоллекции = РолиОбъекта.Получить(СтруктураПараметров.ИндексСтрокиКоллекции);
			Элементы.РолиОбъекта.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		Иначе 
			СтрокаКоллекции = ТаблицаГруппДоступа.Получить(СтруктураПараметров.ИндексСтрокиКоллекции);
			Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.ОчиститьКешПользователя.Доступность = ?(ЗначениеЗаполнено(Объект.Пользователь) И ИспользуетсяТерминальныйРежим, Истина, Ложь);
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		Элементы.Пользователь.КартинкаКнопкиВыбора = ?(ПользовательОнлайн(Объект.Пользователь, Ложь), БиблиотекаКартинок.ОформлениеКругЗеленый, БиблиотекаКартинок.ОформлениеКругКрасный); 
	КонецЕсли;
	
КонецПроцедуры   

&НаКлиенте                  
Процедура ПользовательПриИзменении(Элемент)
	
	ГруппыЗагружены = Ложь;
	
	Если Элементы.РолиОбъекта.ТекущиеДанные <> Неопределено Тогда
		СтрокаКоллекцииРоли = РолиОбъекта.НайтиПоИдентификатору(Элементы.РолиОбъекта.ТекущаяСтрока);
		ИндексСтрокиКоллекцииРоли = РолиОбъекта.Индекс(СтрокаКоллекцииРоли);
	КонецЕсли; 
	
	Если Элементы.ТаблицаГруппДоступа.ТекущиеДанные <> Неопределено Тогда
		СтрокаКоллекции = ТаблицаГруппДоступа.НайтиПоИдентификатору(Элементы.ТаблицаГруппДоступа.ТекущаяСтрока);
		ИндексСтрокиКоллекции = ТаблицаГруппДоступа.Индекс(СтрокаКоллекции);
		ГруппыЗагружены = Истина;
	КонецЕсли;
	
	ПользовательПриИзмененииОбработчик(Элемент, ИндексСтрокиКоллекцииРоли);
	
	Если ГруппыЗагружены Тогда
		
		Если ИндексСтрокиКоллекции <> Неопределено И ИндексСтрокиКоллекции <> 0 Тогда
			СтрокаКоллекции = ТаблицаГруппДоступа.Получить(ИндексСтрокиКоллекции);
			Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		КонецЕсли;
		
		ТаблицаГруппДоступаПриАктивизацииСтроки(Элементы.ТаблицаГруппДоступа);
		
	КонецЕсли;
	
	Если НЕ ЭтоОбъектМетаданныхВДереве(Элементы.ДеревоКонфигурации.ТекущиеДанные) Тогда
		ОчиститьТаблицыГрупп();
		РолиОбъекта.Очистить();
		Элементы.РолиОбъектовМетаданныхРольПредставление.Заголовок = "Роли выбранного объекта";
	КонецЕсли;
	
КонецПроцедуры

