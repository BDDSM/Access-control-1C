&НаСервереБезКонтекста
Функция ПолучитьАдресТаблицыОшибок(Знач ТаблицаОшибок, УникальникальныйИдентификатор)
	
	Возврат ПоместитьВоВременноеХранилище(ДанныеФормыВЗначение(ТаблицаОшибок, Тип("ТаблицаЗначений")), УникальникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура ВыполнитьАвтоматическийАнализОшибок()
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	
	ТаблицаЖурнала = ТекОбъект.ПолучитьЖурналРегистрации(ПериодПоискаОшибок.ДатаНачала, ПериодПоискаОшибок.ДатаОкончания);
	
	Ответ = ТекОбъект.ПарсингЖурналаРегистрации(ТаблицаЖурнала, ИсправленныеОшибки);
	
	СоответствиеПользователей = Ответ.СоответствиеПользователей;
	СчетчикОшибок             = Ответ.СчетчикОшибок;
	
	ПредложитьИсправлениеОшибки(СоответствиеПользователей);
	
	Если СоответствиеПользователей.Количество() Тогда		
		АдресСоответствияПользователей = ПоместитьВоВременноеХранилище(СоответствиеПользователей, УникальныйИдентификатор);		
		Элементы.ОбнаруженыОшибки.Видимость = Истина;
		Элементы.ОшибокНеОбнаружено.Видимость = Ложь;
		ЭтотОбъект.Команды.ОбнаруженыОшибки.Подсказка = "Обнаружены ошибки прав доступа (" + СчетчикОшибок + ")"; 
	Иначе
		Элементы.ОшибокНеОбнаружено.Видимость = Истина;
		Элементы.ОбнаруженыОшибки.Видимость = Ложь;
		ЭтотОбъект.Команды.ОшибокНеОбнаружено.Подсказка = "Ошибок не обнаружено! Нажмите, чтобы обновить.";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьВТелеграм(ТекстСообщения)
	
	ПолучательID 	= ""; 
	Ключ 			= "";
	Сервер 			= "api.telegram.org";
	
	Команда = "sendMessage";
	
	Ресурс = "bot" + Ключ + "/" + Команда + "?chat_id=" + Формат(ПолучательID, "ЧГ=") + "&text=" + СокрЛП(ТекстСообщения);
	
	Соединение = Новый HTTPСоединение(Сервер,,,,,, Новый ЗащищенноеСоединениеOpenSSL);
	Запрос = Новый HTTPЗапрос(Ресурс); 
	
	Ответ = Соединение.Получить(Запрос);
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	
	ОтветСоотв = ПрочитатьJSON(Чтение, Истина);
	ok = ОтветСоотв["ok"];
	
КонецПроцедуры

&НаСервере
Функция ПодобратьГруппуДоступа(РольСтрокой, ТекОрганизация)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПрофилиГруппДоступаРоли.Ссылка КАК Профиль
	               |ПОМЕСТИТЬ ВТ_Профиль
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |ГДЕ
	               |	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ГруппыДоступа.Ссылка КАК ГруппаДоступа,
	               |	ВТ_Профиль.Профиль КАК Профиль
	               |ИЗ
	               |	ВТ_Профиль КАК ВТ_Профиль
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа КАК ГруппыДоступа
	               |		ПО ВТ_Профиль.Профиль = ГруппыДоступа.Профиль
	               |ГДЕ
	               |	ГруппыДоступа.Наименование ПОДОБНО ""%"" + &Организация + ""%""";
	
	Запрос.УстановитьПараметр("Роль", РольСтрокой);
	Запрос.УстановитьПараметр("Организация", ТекОрганизация.Наименование);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() Тогда
		Возврат Результат[0].ГруппаДоступа;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ПредложитьИсправлениеОшибки(СоответствиеПользователей)
	
	МассивВсехРолей = Новый Массив;
	
	Для Каждого МетаРоль Из Метаданные.Роли Цикл
		МассивВсехРолей.Добавить(МетаРоль);
	КонецЦикла;
	
	Для Каждого СтрокаПользователя Из СоответствиеПользователей Цикл
		
		// В УТ 11.4 не работает (нет организаций)
		Если ИмяКонфигурации = "КА" Тогда
			ТекОрганизация = ПолучитьАналитикуПользователя(СтрокаПользователя.Ключ, Истина).Организация; 
		КонецЕсли;
			
		Для Каждого СтрокаОбъекта Из СтрокаПользователя.Значение Цикл
			
			Если НЕ СтрокаОбъекта.МожноИсправить Тогда
				СтрокаОбъекта.Вставить("ПредложеннаяГруппа", "Нет предложений");
				Продолжить;
			КонецЕсли;
			
			НайденныйОбъект = Метаданные.НайтиПоПолномуИмени(СтрокаОбъекта.ТипМетаданного + "." + СтрокаОбъекта.ИмяМетаданного);	
			
			Если НайденныйОбъект = Неопределено Тогда
				Сообщить("Произошла ошибка парсинга журнала регистрации за период (" + ПериодПоискаОшибок + "). Автоматический режим поиска ошибок отключен.");
				ИспользоватьАвтоПоискОшибок = Ложь;   
				КритическаяОшибка = Истина;
				Прервать;
			КонецЕсли;
			
			МассивРолей = Новый Массив;
			
			Для Каждого МетаРоль Из МассивВсехРолей Цикл
				
				Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда
					
					// Сразу исключим полные права из списка предлагаемых ролей
					Если МетаРоль.Имя <> "ПолныеПрава" Тогда
						МассивРолей.Добавить(МетаРоль);	
						
						СтрокаОбъекта.Вставить("МассивРолей", МассивРолей);
						
						// В УТ 11.4 не работает (нет организаций) 
						Если ИмяКонфигурации = "КА" Тогда 
							ПредложеннаяГруппа = ПодобратьГруппуДоступа(МетаРоль.Имя, ТекОрганизация);
							
							Если ПредложеннаяГруппа <> Неопределено Тогда			
								СтрокаОбъекта.Вставить("ПредложеннаяГруппа", ПредложеннаяГруппа);	
								Прервать;	
							КонецЕсли;
							
							Если НЕ СтрокаОбъекта.Свойство("ПредложеннаяГруппа") Тогда
								СтрокаОбъекта.Вставить("ПредложеннаяГруппа", "Нет предложений");
							КонецЕсли;
						КонецЕсли;
						
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеНастройкиПрограммы(Результат, ДополнительныеПараметры) Экспорт
		
	Если Результат = Неопределено Тогда Возврат; КонецЕсли;
	
	ИспользоватьАвтоПоискОшибок = Результат.ИспользоватьАвтоПоискОшибок;
	
	ДинамическийПериодПоиска = Результат.ДинамическийПериодПоиска;
	
	Если ДинамическийПериодПоиска Тогда
		ПериодПоискаОшибок.ДатаНачала = НачалоДня(ТекущаяДата());
		ПериодПоискаОшибок.ДатаОкончания = КонецДня(ПериодПоискаОшибок.ДатаНачала);
	Иначе
		ПериодПоискаОшибок = Результат.ПериодПоискаОшибок;
	КонецЕсли;
	
	Если ИспользоватьАвтоПоискОшибок Тогда
		ВыполнитьАвтоматическийАнализОшибок();
	Иначе
		Элементы.ОбнаруженыОшибки.Видимость = Ложь;
		Элементы.ОшибокНеОбнаружено.Видимость = Ложь;
	КонецЕсли;
	
	ПоказыватьОрганизациюИДолжность = Результат.ПоказыватьОрганизациюИДолжность;
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		Элементы.ГруппаАналитика.Видимость = ПоказыватьОрганизациюИДолжность;
	КонецЕсли;
	
	УведомлятьОбОшибкахПриОткрытии = Результат.УведомлятьОбОшибкахПриОткрытии;
	ОтключитьПредупреждениеОбОпасныхДействиях = Результат.ОтключитьПредупреждениеОбОпасныхДействиях;
	ПроверятьНаличиеОбновлений = Результат.ПроверятьНаличиеОбновлений;
	ФормироватьОтчетыПоРолямВФоне = Результат.ФормироватьОтчетыПоРолямВФоне;
	ИспользуетсяТерминальныйРежим = Результат.ИспользуетсяТерминальныйРежим;
	
	ИнициализироватьОтображениеВерсии();
	Если ПроверятьНаличиеОбновлений Тогда
		ПодключитьОбработчикОжидания("ПроверитьОбновлениеОбработкиОтложенно", 0.2, Истина);
	КонецЕсли;
	
	Элементы.ОчиститьКешПользователя.Доступность = ?(ИспользуетсяТерминальныйРежим И ЗначениеЗаполнено(Объект.Пользователь), Истина, Ложь); 
	
	СписокМетаданных = Результат.СписокМетаданных;
	ПутьДоПользователей = Результат.ПутьДоПользователей;
	
	
	ЗаполнитьДеревоМетаданных();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоМетаданных()
	
	ОбработатьДеревоМетаданных();
	СоздатьНовоеПустоеДеревоКопированием();
	
КонецПроцедуры
                                     
&НаКлиенте
Процедура ПослеПодтвержденияОчисткаКеша(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = "Отмена" Тогда Возврат; КонецЕсли;
	
	РезультатУдаления = Новый Массив;	
	
	УдалитьФайлыНаСервере(РезультатУдаления, ДополнительныеПараметры.СписокПапок);
	
	ПоказатьПредупреждение(, СтрСоединить(РезультатУдаления, Символы.ПС));
		
	//ОчиститьКешНаСервере(ДополнительныеПараметры.СписокПапок);
	
КонецПроцедуры

&НаСервере
Процедура УдалитьФайлыНаСервере(РезультатУдаления, СписокПапок)

	Для Каждого Каталог Из СписокПапок Цикл
		
		Попытка
			УдалитьФайлы(Каталог);
			РезультатУдаления.Добавить(Каталог + " - Успешно" + Символы.ПС);
		Исключение
			РезультатУдаления.Добавить(Каталог + " - Ошибка" + Символы.ПС + ОписаниеОшибки() + Символы.ПС);
		КонецПопытки;
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьКешНаСервере(СписокПапок)
	
	Попытка	
		Для Каждого Каталог Из СписокПапок Цикл
			УдалитьФайлы(Каталог);
		КонецЦикла;	              
	Исключение                    
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура АктуализироватьСписокМетаданных()
	
	Если СписокМетаданных.Количество() = 0 Тогда
		ЗаполнитьСписокЗначений();
		Возврат;
	КонецЕсли;
	
	Для Каждого ОписаниеКоллекции Из ПолучитьОписаниеКоллекцийМетаданных() Цикл
		
		НайденныйЭлемент = СписокМетаданных.НайтиПоЗначению(ОписаниеКоллекции.Имя);
		
		Если НайденныйЭлемент = Неопределено Тогда
			СписокМетаданных.Добавить(
				ОписаниеКоллекции.Имя,
				ОписаниеКоллекции.Синоним,
				Истина,
				ОписаниеКоллекции.Картинка);
		Иначе
			НайденныйЭлемент.Представление = ОписаниеКоллекции.Синоним;
			НайденныйЭлемент.Картинка = ОписаниеКоллекции.Картинка;
		КонецЕсли;
		
		НайденныйЭлементКартинки = КартинкиМетаданных.НайтиПоЗначению(ОписаниеКоллекции.ИмяТипаОбъекта);
		Если НайденныйЭлементКартинки = Неопределено Тогда
			КартинкиМетаданных.Добавить(
				ОписаниеКоллекции.ИмяТипаОбъекта,
				ОписаниеКоллекции.Синоним,
				Истина,
				ОписаниеКоллекции.Картинка);
		Иначе
			НайденныйЭлементКартинки.Представление = ОписаниеКоллекции.Синоним;
			НайденныйЭлементКартинки.Картинка = ОписаниеКоллекции.Картинка;
		КонецЕсли;
		
	КонецЦикла;
	
	НайденныйЭлемент = СписокМетаданных.НайтиПоЗначению("Перечисления");
	Если НайденныйЭлемент <> Неопределено Тогда
		СписокМетаданных.Удалить(НайденныйЭлемент);
	КонецЕсли;
	
	НайденныйЭлементКартинки = КартинкиМетаданных.НайтиПоЗначению("Перечисление");
	Если НайденныйЭлементКартинки <> Неопределено Тогда
		КартинкиМетаданных.Удалить(НайденныйЭлементКартинки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьДеревоМетаданных()
	
	АктуализироватьСписокМетаданных();
	
	ОтборЗадан = Ложь;
	
	Для Каждого Мета Из СписокМетаданных Цикл
		Если НЕ Мета.Пометка Тогда
			ОтборЗадан = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ОтборЗадан Тогда
		ЗначениеВДанныеФормы(ДеревоМетаданныхКонфигурации(, Истина), ДеревоКонфигурации);
	Иначе
		ЗначениеВДанныеФормы(ДеревоМетаданныхКонфигурации(), ДеревоКонфигурации);
	КонецЕсли;
	
	ДеревоФормы = РеквизитФормыВЗначение("ДеревоКонфигурации");
	
	СортироватьСтрокиДереваМетаданных(ДеревоФормы.Строки);
	
	ЗначениеВРеквизитФормы(ДеревоФормы, "ДеревоКонфигурации");
	
КонецПроцедуры

&НаСервере
Процедура СоздатьГруппуИПрофильАвтоНаСервере(Имя, ДополнительныеПараметры)
	
	СсылкаНовогоПрофиля = Справочники.ПрофилиГруппДоступа.ПолучитьСсылку();
	
	ОбъектПрофиль = Справочники.ПрофилиГруппДоступа.СоздатьЭлемент();
	ОбъектПрофиль.УстановитьСсылкуНового(СсылкаНовогоПрофиля);
		
	ОбъектПрофиль.Наименование = Имя;
	
	ИдентификаторРоли = ДополнительныеПараметры.ИдентификаторРоли;
	Если ИдентификаторРоли = Неопределено Тогда
		ШаблонСообщения = НСтр("ru = 'Не был найден идентификатор для роли [%1] в метаданных [%2].'");
		ТекстСообщения  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонСообщения,
																				  СтрЗаменить(Строка(ИдентификаторРоли), " (Роль)", ""), 
																				  Метаданные.Справочники.ИдентификаторыОбъектовМетаданных.Имя);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПараметрыОтбора = Новый Структура("Роль", ИдентификаторРоли);
	НайденныеСтроки = ОбъектПрофиль.Роли.НайтиСтроки(ПараметрыОтбора);
	Если НайденныеСтроки.Количество() = 0 Тогда
		НовСтрока = ОбъектПрофиль.Роли.Добавить();
		НовСтрока.Роль = ИдентификаторРоли;
	КонецЕсли;
	
	ОбъектГруппыДоступа = Справочники.ГруппыДоступа.СоздатьЭлемент();
	ОбъектГруппыДоступа.Наименование = Имя;
	ОбъектГруппыДоступа.Профиль = СсылкаНовогоПрофиля;
	
	НовСтрока = ОбъектГруппыДоступа.Пользователи.Добавить();
	НовСтрока.Пользователь = Объект.Пользователь;
		
	Попытка 
		ОбъектПрофиль.Записать();
		ОбъектГруппыДоступа.Записать();
		
		ТекстСообщения = НСтр("ru = 'Группа и профиль были успешно созданы.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
		РолиОбъектаВыборНаСервере(ДополнительныеПараметры.Роль);
	Исключение
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'При засии были обнаружены ошибки: '") + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры 

&НаКлиенте 
Процедура ПослеВводаИмениГруппыИПрофиля(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьСовпадения = ВыполнитьПоискГруппИПрофилейПоИмени(Результат);
	
	Если ЕстьСовпадения Тогда
		ТекстСообщения = НСтр("ru = 'Уже есть группа или профиль с таким наименованием, выберите другое имя.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		СоздатьГруппуИПрофильАвто(Неопределено);
	Иначе
		СоздатьГруппуИПрофильАвтоНаСервере(Результат, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

