&НаСервере
Процедура НайтиРолиВОбъекте(ИмяОбъекта = "", РольПустышка = Неопределено)
		
	РолиОбъекта.Очистить();
	
 	Если РольПустышка <> Неопределено Тогда
		
		Для Каждого Колонка Из Элементы.РолиОбъекта.ПодчиненныеЭлементы Цикл
			Колонка.Видимость = Ложь;	
		КонецЦикла;
		
		Элементы.РолиОбъекта.ПодчиненныеЭлементы.РолиОбъектовМетаданныхПризнакНаличияРоли.Видимость = Истина;
		Элементы.РолиОбъекта.ПодчиненныеЭлементы.РолиОбъектовМетаданныхРольПредставление.Видимость = Истина;
		
		НоваяСтрока = РолиОбъекта.Добавить();
		НоваяСтрока.НаименованиеРоли = РольПустышка.Имя;
		НоваяСтрока.КартинкаРоли = Истина;
		НоваяСтрока.Роль = РольПустышка.Имя;
		НоваяСтрока.РольПредставление = РольПустышка.Синоним;
			
		Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
			
			Для Каждого СтрокаРоли Из РолиОбъекта Цикл
				
				СтрокаРоли.ПризнакНаличияРоли = ЕстьРоль(СтрокаРоли.Роль, Объект.Пользователь);
				
				Если СтрокаРоли.ПризнакНаличияРоли = Ложь Тогда
					СтрокаРоли.ПризнакНаличияРоли = ЕстьРольПользователя(СтрокаРоли.Роль, Объект.Пользователь);
				КонецЕсли;	
				
			КонецЦикла;
			
		КонецЕсли;
		
		Элементы.РолиОбъектовМетаданныхРольПредставление.Заголовок = "Роль не включает в себя ни одного объекта метаданных";
		
		Возврат;
		
	КонецЕсли;
	
	ЭлементыРолейОбъекта = Элементы.РолиОбъекта.ПодчиненныеЭлементы;
	СброситьЗаголовкиКолонокПравОбъекта();
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхЧтение.Видимость 		   = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхИзменение.Видимость 		   = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхДобавление.Видимость		   = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхУдаление.Видимость		   = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхРедактирование.Видимость    = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхПроведение.Видимость 	   = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхИспользование.Видимость     = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхУправлениеИтогами.Видимость = Истина;
	ЭлементыРолейОбъекта.РолиОбъектовМетаданныхПросмотр.Видимость 		   = Истина;
	
	//TODO: Проверить и удалить.
	//ИтоговаяТаблица = Новый ТаблицаЗначений;
	//ИтоговаяТаблица.Колонки.Добавить("МетаРоль", Новый ОписаниеТипов("ОбъектМетаданных"));
	//
	//// Базовые права
	//ИтоговаяТаблица.Колонки.Добавить("Чтение", Новый ОписаниеТипов("Булево"));
	//ИтоговаяТаблица.Колонки.Добавить("Изменение", Новый ОписаниеТипов("Булево"));
	//ИтоговаяТаблица.Колонки.Добавить("Добавление", Новый ОписаниеТипов("Булево"));
	//ИтоговаяТаблица.Колонки.Добавить("Удаление", Новый ОписаниеТипов("Булево"));
	//
	//// + Обработки и отчеты
	//ИтоговаяТаблица.Колонки.Добавить("Использование", Новый ОписаниеТипов("Булево"));
	//
	//// + Справочники
	//ИтоговаяТаблица.Колонки.Добавить("Просмотр", Новый ОписаниеТипов("Булево"));
	//ИтоговаяТаблица.Колонки.Добавить("Редактирование", Новый ОписаниеТипов("Булево"));
	//	
	//// + Документы
	//ИтоговаяТаблица.Колонки.Добавить("Проведение", Новый ОписаниеТипов("Булево"));
		
	Если ПустаяСтрока(ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЭтоОбъектПравДоступа(ИмяОбъекта) Тогда
		Возврат;
	КонецЕсли;
	
	НайденныйОбъект = НайтиОбъектМетаданныхПоПолномуИмени(ИмяОбъекта);
	
	Если НайденныйОбъект = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НачалоТочки = СтрНайти(ИмяОбъекта, ".") - 1;
	ВидОбъекта = Сред(ИмяОбъекта, 0, НачалоТочки);
	
	МассивВсехРолей = Новый Массив;
	
	Для Каждого МетаРоль Из Метаданные.Роли Цикл
		МассивВсехРолей.Добавить(МетаРоль);
	КонецЦикла;
	
	ДобавляемыеПрава = Новый Соответствие;
	ДобавляемыеПрава.Вставить(ВидОбъекта);
	ОсновныеПрава = "Чтение, Использование, Просмотр";
	ДополнительныеПрава = "Изменение, Добавление, Просмотр, Редактирование, Удаление, Проведение, УправлениеИтогами";
	  
	Для Каждого МетаданныеПрав Из ДобавляемыеПрава Цикл
		
		УдаляемыеКлючиОсновные = Новый Структура;
		УдаляемыеКлючиДополнительные = Новый Структура;
		
		ПраваДоступа = Новый Структура("ОсновныеПрава, ДополнительныеПрава");
		ПраваДоступа.ОсновныеПрава = Новый Структура(ОсновныеПрава);
		ПраваДоступа.ДополнительныеПрава = Новый Структура(ДополнительныеПрава);
		
		Если МетаданныеПрав.Ключ = "Обработка" Или МетаданныеПрав.Ключ = "Отчет" Или
			МетаданныеПрав.Ключ = "HTTPСервис" Или МетаданныеПрав.Ключ = "WebСервис" Или
			МетаданныеПрав.Ключ = "СервисИнтеграции" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Чтение, Просмотр");
			
			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Редактирование, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "Справочник" Или МетаданныеПрав.Ключ = "ПланВидовХарактеристик" Или 
			      МетаданныеПрав.Ключ = "ПланСчетов" Или МетаданныеПрав.Ключ = "ПланВидовРасчета" Или
				  МетаданныеПрав.Ключ = "ПланОбмена" Или
				  МетаданныеПрав.Ключ = "БизнесПроцесс" Или МетаданныеПрав.Ключ = "Задача" Тогда
				  
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "Документ" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "РегистрРасчета" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Добавление, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "ЖурналДокументов" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Редактирование, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "РегистрСведений" Или МетаданныеПрав.Ключ = "РегистрНакопления" Или 
				  МетаданныеПрав.Ключ = "РегистрБухгалтерии" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Добавление, Удаление, Проведение");
			
		ИначеЕсли МетаданныеПрав.Ключ = "Подсистема" Или МетаданныеПрав.Ключ = "ОбщаяКоманда" Или МетаданныеПрав.Ключ = "ОбщаяФорма" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Чтение"); 

			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Просмотр, Редактирование, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "ЖурналыДокументов" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Редактирование, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "Константа" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");  

			УдаляемыеКлючиДополнительные = Новый Структура("Добавление, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "КритерийОтбора" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Чтение");
			
			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Редактирование, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "ОбщийРеквизит" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Чтение");
			
			УдаляемыеКлючиДополнительные = Новый Структура("Изменение, Добавление, Просмотр, Удаление, Проведение, УправлениеИтогами");
			
		ИначеЕсли МетаданныеПрав.Ключ = "ПараметрСеанса" Тогда
			
			ПраваДоступа.ОсновныеПрава = Новый Структура("Чтение, Изменение");
			ПраваДоступа.ДополнительныеПрава = Новый Структура;
			
		ИначеЕсли МетаданныеПрав.Ключ = "ВнешнийИсточникДанных" Тогда
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");
			
			УдаляемыеКлючиДополнительные = Новый Структура("Добавление, Удаление, Проведение, УправлениеИтогами, Редактирование");
			
		Иначе
			
			УдаляемыеКлючиОсновные = Новый Структура("Использование, Просмотр");
			
			УдаляемыеКлючиДополнительные = Новый Структура("Проведение, УправлениеИтогами");
			
		КонецЕсли;
		
		УдалитьКлючиСтруктуры(Истина, УдаляемыеКлючиОсновные, ПраваДоступа, "ОсновныеПрава");
		УдалитьКлючиСтруктуры(Истина, УдаляемыеКлючиДополнительные, ПраваДоступа, "ДополнительныеПрава");
				
		ДобавляемыеПрава[МетаданныеПрав.Ключ] = Новый Структура("ОсновныеПрава, ДополнительныеПрава",
						    					ПраваДоступа.ОсновныеПрава, ПраваДоступа.ДополнительныеПрава);
							
		ПраваДоступа = Неопределено;
		
	КонецЦикла;
	
	Если ВидОбъекта = "ПараметрСеанса" Тогда
		
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхИспользование.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхПросмотр.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхДобавление.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхУдаление.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхРедактирование.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхПроведение.Видимость = Ложь;
		ЭлементыРолейОбъекта.РолиОбъектовМетаданныхУправлениеИтогами.Видимость = Ложь;
		
	КонецЕсли;
	 
	Для Каждого МетаРоль Из МассивВсехРолей Цикл
		
		ЕстьПрава = Ложь;
		
		Для Каждого ОсновнаяРоль Из ДобавляемыеПрава[ВидОбъекта].ОсновныеПрава Цикл
			Если ЕстьПравоДоступаОбъекта(ИмяПраваПлатформыДляКолонки(ВидОбъекта, ОсновнаяРоль.Ключ), НайденныйОбъект, МетаРоль) Тогда
				ЕстьПрава = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЕстьПрава Тогда
			Для Каждого ДополнительнаяРоль Из ДобавляемыеПрава[ВидОбъекта].ДополнительныеПрава Цикл
				Если ЕстьПравоДоступаОбъекта(ИмяПраваПлатформыДляКолонки(ВидОбъекта, ДополнительнаяРоль.Ключ), НайденныйОбъект, МетаРоль) Тогда
					ЕстьПрава = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если НЕ ЕстьПрава Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = РолиОбъекта.Добавить();
		НоваяСтрока.НаименованиеРоли = МетаРоль.Имя;
		НоваяСтрока.КартинкаРоли = Истина;
		НоваяСтрока.Роль = МетаРоль.Имя;
		НоваяСтрока.РольПредставление = ?(МетаРоль.Синоним = "",
			МетаРоль.Имя + " (у роли отсутствует синоним в конфигураторе, необходимо его заполнить для корректного отображения).",
			МетаРоль.Синоним);
		
		Для Каждого ОсновнаяРоль Из ДобавляемыеПрава[ВидОбъекта].ОсновныеПрава Цикл
			
			ЕстьПравоКолонки = ЕстьПравоДоступаОбъекта(
				ИмяПраваПлатформыДляКолонки(ВидОбъекта, ОсновнаяРоль.Ключ),
				НайденныйОбъект,
				МетаРоль);
			НоваяСтрока[ОсновнаяРоль.Ключ] = ЕстьПравоКолонки;
			УдалитьКлючиСтруктуры(Ложь, УдаляемыеКлючиДополнительные, Неопределено, ОсновнаяРоль.Ключ, ЕстьПравоКолонки);
			
		КонецЦикла;
		
		Для Каждого ДополнительнаяРоль Из ДобавляемыеПрава[ВидОбъекта].ДополнительныеПрава Цикл
			
			ЕстьПравоКолонки = ЕстьПравоДоступаОбъекта(
				ИмяПраваПлатформыДляКолонки(ВидОбъекта, ДополнительнаяРоль.Ключ),
				НайденныйОбъект,
				МетаРоль);
			НоваяСтрока[ДополнительнаяРоль.Ключ] = ЕстьПравоКолонки;
			
			ЭлементыРолейОбъекта["РолиОбъектовМетаданныхПросмотр"].Видимость = НоваяСтрока.Просмотр;
			
			УдалитьКлючиСтруктуры(Ложь, УдаляемыеКлючиДополнительные, Неопределено, ДополнительнаяРоль.Ключ, ЕстьПравоКолонки);
			УдалитьКлючиСтруктуры(Ложь, УдаляемыеКлючиОсновные, Неопределено, ДополнительнаяРоль.Ключ, ЕстьПравоКолонки);
			
		КонецЦикла;
		
		Для Каждого УдаленнаяРольОсновная Из УдаляемыеКлючиОсновные Цикл
			ЭлементыРолейОбъекта["РолиОбъектовМетаданных" + УдаленнаяРольОсновная.Ключ].Видимость = Ложь;
		КонецЦикла;
		
		Для Каждого УдаленнаяРольДополнительная Из УдаляемыеКлючиДополнительные Цикл
			ЭлементыРолейОбъекта["РолиОбъектовМетаданных" + УдаленнаяРольДополнительная.Ключ].Видимость = Ложь;
		КонецЦикла;
		
	КонецЦикла;
	
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		
		Для Каждого СтрокаРоли Из РолиОбъекта Цикл
			
			СтрокаРоли.ПризнакНаличияРоли = ЕстьРоль(СтрокаРоли.Роль, Объект.Пользователь);
			
			Если СтрокаРоли.ПризнакНаличияРоли = Ложь Тогда
				СтрокаРоли.ПризнакНаличияРоли = ЕстьРольПользователя(СтрокаРоли.Роль, Объект.Пользователь);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Элементы.РолиОбъектовМетаданныхРольПредставление.Заголовок = "Роли выбранного объекта (" + РолиОбъекта.Количество() + ")";
	
	ДозаполнитьТаблицуРолей();
	
	Если РолиОбъекта.Количество() > 0 Тогда
		РолиОбъектаВыборНаСервере(РолиОбъекта[0].Роль);
	Иначе
		ТаблицаГруппДоступа.Очистить();
		ТаблицаПрофилей.Очистить();
		ВидыДоступа.Очистить();
		ЗначенияДоступа.Очистить();
		ТаблицаЗначенияДоступа.Очистить();
		СброситьЗаголовкиТаблицГруппИПрофилей();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьКлючиСтруктуры(УдалитьВЦикле, СписокКлючей, сткУдаления, ИмяКлюча, ЕстьПрава = Ложь)
	
	Если УдалитьВЦикле Тогда
		
		Если СписокКлючей = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Для Каждого Ключи Из СписокКлючей Цикл
			
			сткУдаления[ИмяКлюча].Удалить(Ключи.Ключ);	
			
		КонецЦикла;
	Иначе
		Если ЕстьПрава И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СписокКлючей, ИмяКлюча) Тогда
			СписокКлючей.Удалить(ИмяКлюча);	
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТаблицыГрупп()
	
	ОчиститьТаблицыОграниченийДоступа();
	
	ТаблицаГруппДоступа.Очистить();
	ТаблицаПрофилей.Очистить();
	СброситьЗаголовкиТаблицГруппИПрофилей();
	
КонецПроцедуры

&НаСервере
Процедура СброситьЗаголовкиТаблицГруппИПрофилей()
	
	Элементы.ТаблицаГруппДоступаГруппаДоступа.Заголовок = "Группы доступа";
	Элементы.ТаблицаПрофилейПрофиль.Заголовок = "Профили";
	
КонецПроцедуры

&НаСервере
Процедура РолиОбъектаВыборНаСервере(ВыбраннаяРоль)
	
	
	// Найдем группы и профили, в которых состоит выбранная роль
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПрофилиГруппДоступаРоли.Ссылка КАК Профиль
	               |ПОМЕСТИТЬ ВТ_Профиль
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |ГДЕ
	               |	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	               |	И НЕ ПрофилиГруппДоступаРоли.Ссылка.ПометкаУдаления
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ГруппыДоступа.Ссылка КАК ГруппаДоступа,
	               |	ВТ_Профиль.Профиль КАК Профиль
	               |ИЗ
	               |	ВТ_Профиль КАК ВТ_Профиль
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа КАК ГруппыДоступа
	               |		ПО ВТ_Профиль.Профиль = ГруппыДоступа.Профиль
	               |ГДЕ
	               |	НЕ ГруппыДоступа.ПометкаУдаления
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Профиль.Профиль КАК Профиль
	               |ИЗ
	               |	ВТ_Профиль КАК ВТ_Профиль";
	
	Запрос.УстановитьПараметр("Роль", ВыбраннаяРоль);
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	ТаблицаПрофилей.Загрузить(ПакетЗапросов[ПакетЗапросов.Вграница()].Выгрузить());
	ТаблицаГруппДоступа.Загрузить(ПакетЗапросов[ПакетЗапросов.Вграница()- 1].Выгрузить());	
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		
		// Найдем группы и профили, в которых состоит выбранный пользователь
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ГруппыДоступа.Ссылка КАК ГруппаДоступа,
		|	ГруппыДоступа.Наименование КАК Наименование,
		|	ГруппыДоступа.Профиль.Наименование КАК ПрофильНаименование,
		|	ГруппыДоступа.Комментарий КАК Комментарий,
		|	ГруппыДоступа.Ответственный КАК Ответственный,
		|	ГруппыДоступа.Профиль КАК Профиль
		|ПОМЕСТИТЬ ВТ_ГруппыДоступа
		|ИЗ
		|	Справочник.ГруппыДоступа КАК ГруппыДоступа
		|ГДЕ
		|	НЕ ГруппыДоступа.ПометкаУдаления
		|	И НЕ ГруппыДоступа.Профиль.ПометкаУдаления
		|	И ИСТИНА В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА
		|			ИЗ
		|				Справочник.ГруппыДоступа.Пользователи КАК ПользователиГруппДоступа
		|			ГДЕ
		|				ПользователиГруппДоступа.Ссылка = ГруппыДоступа.Ссылка
		|				И НЕ(ПользователиГруппДоступа.Пользователь <> &Пользователь
		|						И НЕ ПользователиГруппДоступа.Пользователь В
		|								(ВЫБРАТЬ
		|									СоставыГруппПользователей.ГруппаПользователей
		|								ИЗ
		|									РегистрСведений.СоставыГруппПользователей КАК СоставыГруппПользователей
		|								ГДЕ
		|									СоставыГруппПользователей.Пользователь = &Пользователь)))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ГруппыДоступа.Профиль КАК Профиль
		|ИЗ
		|	ВТ_ГруппыДоступа КАК ВТ_ГруппыДоступа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ГруппыДоступа.ГруппаДоступа КАК ГруппаДоступа
		|ИЗ
		|	ВТ_ГруппыДоступа КАК ВТ_ГруппыДоступа";
		
		Запрос.УстановитьПараметр("Пользователь", Объект.Пользователь);
		
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		
		ГруппыДоступаТекПользователя = ПакетЗапросов[ПакетЗапросов.Вграница()].Выгрузить().ВыгрузитьКолонку("ГруппаДоступа");
		ПрофилиТекПользователя = ПакетЗапросов[ПакетЗапросов.Вграница() - 1].Выгрузить().ВыгрузитьКолонку("Профиль");
		
		Для Каждого СтрокаГруппы Из ГруппыДоступаТекПользователя Цикл
			
			СостоитВГруппе = ТаблицаГруппДоступа.НайтиСтроки(Новый Структура("ГруппаДоступа", СтрокаГруппы));
			
			Если СостоитВГруппе.Количество() Тогда
				СостоитВГруппе[0].ПризнакНаличияГруппы = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СтрокаПрофиля Из ПрофилиТекПользователя Цикл
			
			СостоитВПрофиле = ТаблицаПрофилей.НайтиСтроки(Новый Структура("Профиль", СтрокаПрофиля));
			
			Если СостоитВПрофиле.Количество() Тогда
				СостоитВПрофиле[0].ПризнакНаличияПрофиля = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		ТаблицаГруппДоступа.Сортировать("ПризнакНаличияГруппы УБЫВ");
		ТаблицаПрофилей.Сортировать("ПризнакНаличияПрофиля УБЫВ");	
		
	КонецЕсли;
	
	Элементы.ТаблицаГруппДоступаГруппаДоступа.Заголовок = "Группы доступа (" + ТаблицаГруппДоступа.Количество() + ")";
	Элементы.ТаблицаПрофилейПрофиль.Заголовок = "Профили (" + ТаблицаПрофилей.Количество() + ")";
	
КонецПроцедуры

&НаСервере
Функция ПолучитьАналитикуПользователя(ТекПользователь = Неопределено, ПрограммнаяОбработка = Ложь)
	
	Если ИмяКонфигурации = "УТ" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтруктураАналитики = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Сотрудники.Ссылка КАК Сотрудник,
	               |	ФизическиеЛица.Ссылка КАК ФизЛицо,
	               |	Пользователи.Ссылка КАК Пользователь,
	               |	Сотрудники.ГоловнаяОрганизация КАК ГоловнаяОрганизация
	               |ИЗ
	               |	Справочник.Пользователи КАК Пользователи
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	               |			ПО (Сотрудники.ФизическоеЛицо = ФизическиеЛица.Ссылка)
	               |		ПО Пользователи.ФизическоеЛицо = ФизическиеЛица.Ссылка
	               |ГДЕ
	               |	Пользователи.Ссылка = &Пользователь
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ГруппыПользователейСостав.Ссылка КАК Группа
	               |ИЗ
	               |	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	               |ГДЕ
	               |	ГруппыПользователейСостав.Пользователь = &Пользователь";
	
	Если ПрограммнаяОбработка = Ложь Тогда
		
		Запрос.УстановитьПараметр("Пользователь", Объект.Пользователь);
		
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		
		ТаблицаРезультата = ПакетЗапросов[ПакетЗапросов.Вграница()- 1].Выгрузить();
		
		ГруппыПользователя.Загрузить(ПакетЗапросов[ПакетЗапросов.Вграница()].Выгрузить());
		
		Если ТаблицаРезультата.Количество() Тогда
			СтруктураАналитики.Вставить("Организация", ТаблицаРезультата[0].ГоловнаяОрганизация);
			
			Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.КадровыйУчет") <> Неопределено Тогда  
				МодульКадровыйУчет = ОбщегоНазначения.ОбщийМодуль("КадровыйУчет");
				СтруктураАналитики.Вставить("Должность", МодульКадровыйУчет.КадровыеДанныеСотрудников(Истина, ТаблицаРезультата[0].Сотрудник, "Должность", ТекущаяДата())[0].Должность);
			КонецЕсли;
			
		КонецЕсли;	
		
	Иначе		
		
		Запрос.УстановитьПараметр("Пользователь", ТекПользователь);
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		ТаблицаРезультата = ПакетЗапросов[ПакетЗапросов.Вграница()- 1].Выгрузить();
		
		Если ТаблицаРезультата.Количество() Тогда
			СтруктураАналитики.Вставить("Организация", ТаблицаРезультата[0].ГоловнаяОрганизация);	
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ СтруктураАналитики.Свойство("Организация") Тогда
		СтруктураАналитики.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	КонецЕсли;
	
	Если НЕ СтруктураАналитики.Свойство("Должность") Тогда
		СтруктураАналитики.Вставить("Должность", Справочники.Должности.ПустаяСсылка());		
	КонецЕсли;
	
	Возврат СтруктураАналитики; 
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаполнитьТаблицуОшибок(ТаблицаОшибок, АдресТаблицыОшибок, Знач ТаблицаИдентификаторовИБПользователей)
	
	Таблица = НайтиУжеИсправленныеОшибки(ПолучитьИзВременногоХранилища(АдресТаблицыОшибок), ТаблицаИдентификаторовИБПользователей);
	
	ТаблицаОшибок.Загрузить(Таблица);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НайтиУжеИсправленныеОшибки(Таблица, ТаблицаИдентификаторовИБПользователей)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Ошибка КАК Ошибка,
	|	Таблица.Пользователь КАК Пользователь,
	|	Таблица.ТаблицаОшибки КАК ТаблицаОшибки,
	|	Таблица.ДатаОшибки КАК ДатаОшибки,
	|	Таблица.ПредложеннаяГруппа КАК ПредложеннаяГруппа,
	|	Таблица.Комментарий КАК Комментарий,
	|	Таблица.СкрытьОшибку КАК СкрытьОшибку
	|ПОМЕСТИТЬ втТаблицаОшибок
	|ИЗ
	|	&Таблица КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПользователей.Пользователь,
	|	ТаблицаПользователей.ИдентификаторИБ
	|ПОМЕСТИТЬ втТаблицаПользователей
	|ИЗ
	|	&ТаблицаПользователей КАК ТаблицаПользователей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТаблицаОшибок.Ошибка КАК Ошибка,
	|	втТаблицаОшибок.Пользователь КАК Пользователь,
	|	втТаблицаОшибок.ТаблицаОшибки КАК ТаблицаОшибки,
	|	втТаблицаОшибок.ДатаОшибки КАК ДатаОшибки,
	|	втТаблицаОшибок.ПредложеннаяГруппа КАК ПредложеннаяГруппа,
	|	втТаблицаОшибок.Комментарий КАК Комментарий,
	|	втТаблицаОшибок.СкрытьОшибку КАК СкрытьОшибку,
	|	ИСТИНА КАК ЗаписьНеИсправлена
	|ПОМЕСТИТЬ втИтог
	|ИЗ
	|	втТаблицаОшибок КАК втТаблицаОшибок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втИтог.Ошибка КАК Ошибка,
	|	втИтог.Пользователь КАК Пользователь,
	|	втИтог.ТаблицаОшибки КАК ТаблицаОшибки,
	|	втИтог.ДатаОшибки КАК ДатаОшибки,
	|	втИтог.ПредложеннаяГруппа КАК ПредложеннаяГруппа,
	|	втИтог.Комментарий КАК Комментарий,
	|	втИтог.СкрытьОшибку КАК СкрытьОшибку,
	|	втИтог.ЗаписьНеИсправлена КАК ЗаписьНеИсправлена
	|ИЗ
	|	втИтог КАК втИтог
	|ГДЕ
	|	втИтог.ЗаписьНеИсправлена";
	Запрос.УстановитьПараметр("Таблица", Таблица);
	Запрос.УстановитьПараметр("ТаблицаПользователей", ТаблицаИдентификаторовИБПользователей.Выгрузить());
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции 

&НаКлиенте
Процедура УстановитьВидимостьЭлементов()
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда	
		Элементы.НазначитьГруппы.Доступность			= Истина;
		//Элементы.ДекорацияПраваДоступа.Доступность	= Истина;
		Элементы.ОткрытьПраваДоступа.Доступность 	 	= Истина;
		//Элементы.РедактироватьОграничения.Доступность = Истина;
		Элементы.ГруппаАналитика.Видимость			 	= ?(ПоказыватьОрганизациюИДолжность, Истина, Ложь);
		Элементы.ЗапуститьПодПользователем.Доступность  = Истина;
		Элементы.КнопкаРазвернуть.Доступность 			= Истина;  
		Элементы.КнопкаРазвернуть.Видимость 			= Истина; 
		
		Элементы.ГруппаКнопокРазвернуто.Видимость  = Ложь;
		Элементы.ГруппаКнопокРазвернуто2.Видимость = Ложь;
		Элементы.КнопкаСвернуть.Видимость 		   = Ложь;
		
	Иначе
		СкрытьВидимостьПравДоступаПользователя();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СменитьНадписьВыборОбъекта(ОбъектВыбран = Неопределено)
	
	Если ОбъектВыбран = Истина Тогда
		Элементы.ВыбранныйПользователь.Видимость = Ложь;
		Элементы.ВыбранныйОбъект.Видимость = Истина;
		Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Зеленый;
		
		Если Элементы.ДеревоКонфигурации.ТекущиеДанные <> Неопределено Тогда
			Элементы.ДекорацияКартинкаМетаданных.Картинка = Элементы.ДеревоКонфигурации.ТекущиеДанные.Картинка; 
			
			МассивИсключений = Новый Массив;	
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "Константа"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "ОбщаяФорма"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "ОбщаяКоманда"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "Подсистема"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "ЖурналДокументов"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "ПараметрСеанса"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "ОбщийРеквизит"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "WebСервис"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "HTTPСервис"));
			МассивИсключений.Добавить(СтрНайти(Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя, "СервисИнтеграции"));
			
			ИсключениеНайдено = МассивИсключений.Найти(1);
			
			Элементы.НайтиСвязиОбъекта.Доступность = ?(ИсключениеНайдено = Неопределено, Истина, Ложь);
			Элементы.НайтиСвязиОбъекта1.Доступность = ?(ИсключениеНайдено = Неопределено, Истина, Ложь);
			
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	Элементы.НайтиСвязиОбъекта.Доступность = Ложь;
	Элементы.НайтиСвязиОбъекта1.Доступность = Ложь;
	
	Элементы.ВыбранныйОбъект.Видимость = Истина;
	
	ВыбранныйОбъект = "Выберите объект метаданных, для проверки доступа";
	Элементы.ВыбранныйОбъект.ЦветТекста = WebЦвета.Красный;
	Элементы.ДекорацияКартинкаМетаданных.Картинка = БиблиотекаКартинок.ВнешнийИсточникДанных;
	
	Элементы.ВыбранныйПользователь.Видимость = Ложь;

	Если Элементы.ДеревоКонфигурации.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ДеревоКонфигурации.ТекущиеДанные <> Неопределено Тогда
		
		ПолноеИмяТекущего = Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя;
		
		Если НЕ ЭтоОбъектПравДоступаНаСервере(ПолноеИмяТекущего) Тогда
			ОчиститьТаблицыГрупп();
			РолиОбъекта.Очистить();
			Элементы.РолиОбъектовМетаданныхРольПредставление.Заголовок = "Роли выбранного объекта";
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
	
&НаКлиенте
Функция ЭтоОбъектМетаданныхВДереве(ДанныеСтроки)
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ЭтоОбъектПравДоступаНаСервере(ДанныеСтроки.ПолноеИмя);
	
КонецФункции

&НаСервере
Функция ЭтоОбъектПравДоступаНаСервере(ПолноеИмя)
	
	Возврат ЭтоОбъектПравДоступа(ПолноеИмя);
	
КонецФункции

&НаКлиенте
Функция НайтиИдентификаторСтрокиДереваПоПолномуИмени(СтрокиДерева, ПолноеИмя)
	
	Для Каждого Строка Из СтрокиДерева Цикл
		
		Если Строка.ПолноеИмя = ПолноеИмя Тогда
			Возврат Строка.ПолучитьИдентификатор();
		КонецЕсли;
		
		Идентификатор = НайтиИдентификаторСтрокиДереваПоПолномуИмени(Строка.ПолучитьЭлементы(), ПолноеИмя);
		Если Идентификатор <> Неопределено Тогда
			Возврат Идентификатор;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции
	
&НаКлиенте
Процедура СменитьНадписьВыборПользователя()
	
	Элементы.ВыбранныйПользователь.Видимость = Истина;
	
	ВыбранныйПользователь = "Начните работу с выбора пользователя, роли или ОМ";	
	Элементы.ДекорацияКартинкаМетаданных.Картинка = БиблиотекаКартинок.Настройка;
	
	Элементы.ВыбранныйОбъект.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьВидимостьПравДоступаПользователя()
	
	//Элементы.РедактироватьОграничения.Доступность = Ложь;
	//Элементы.ДекорацияПраваДоступа.Доступность   = Ложь;
	Элементы.ОткрытьПраваДоступа.Доступность 	   = Ложь;
	Элементы.НазначитьГруппы.Доступность 		   = Ложь;	
	Элементы.ГруппаАналитика.Видимость 			   = Ложь;
	Элементы.ЗапуститьПодПользователем.Доступность = Ложь;     
	Элементы.КнопкаРазвернуть.Видимость 		   = Ложь;
	Элементы.КнопкаРазвернуть.Доступность 		   = Ложь;	
	Элементы.ГруппаКнопокРазвернуто.Видимость      = Ложь;
	Элементы.ГруппаКнопокРазвернуто2.Видимость     = Ложь;	
	Элементы.КнопкаСвернуть.Видимость 			   = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьИсключитьИзГруппы(ГруппаДоступа, ВключитьВГруппуДоступа)
	
	Если ТипЗнч(ГруппаДоступа) <> Тип("СправочникСсылка.ГруппыДоступа") ИЛИ НЕ ЗначениеЗаполнено(ГруппаДоступа) Тогда
		Возврат;
	КонецЕсли;
	         
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ГруппаДоступа", 		   ГруппаДоступа);
	ДополнительныеПараметры.Вставить("ВключитьВГруппуДоступа", ВключитьВГруппуДоступа);
	ДополнительныеПараметры.Вставить("Пользователь", 		   Объект.Пользователь);
	ДополнительныеПараметры.Вставить("НеобходимоОбновитьроли", НЕ Элементы.РолиОбъекта.ТекущиеДанные = Неопределено);
	ДополнительныеПараметры.Вставить("ПризнакНаличияГруппы",   НЕ Элементы.ТаблицаГруппДоступа.ТекущиеДанные.ПризнакНаличияГруппы);
	ДополнительныеПараметры.Вставить("ТекущаяГруппаДоступа",   Элементы.ТаблицаГруппДоступа.ТекущиеДанные.ГруппаДоступа);
	ДополнительныеПараметры.Вставить("РольПредставление",      Элементы.РолиОбъекта.ТекущиеДанные.РольПредставление);
	ДополнительныеПараметры.Вставить("КартинкаМета",    	   Элементы.ДеревоКонфигурации.ТекущиеДанные.Картинка);
	ДополнительныеПараметры.Вставить("СинонимМета",    		   Элементы.ДеревоКонфигурации.ТекущиеДанные.Синоним);
	ДополнительныеПараметры.Вставить("ТекущаяРоль",    		   Элементы.РолиОбъекта.ТекущиеДанные.Роль);
	
	Если СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиента().РазделениеВключено
	   И ГруппаДоступа = Объект.ГруппаДоступаАдминистраторы Тогда
		
		ПользователиСлужебныйКлиент.ЗапроситьПарольДляАутентификацииВСервисе(
			Новый ОписаниеОповещения(
				"ВключитьИсключитьИзГруппыЗавершение", ЭтотОбъект, ДополнительныеПараметры),
			ЭтотОбъект,
			Объект.ПарольПользователяСервиса);
		Возврат;
	Иначе
		ВключитьИсключитьИзГруппыЗавершение(Null, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере  
Процедура ИзменитьСоставГруппы(Знач ДополнительныеПараметры, ОписаниеОшибки = "")

	ТекОбъект = РеквизитФормыВЗначение("Объект"); 
	ТекОбъект.ИзменитьСоставГруппы(ДополнительныеПараметры, ОписаниеОшибки);

	ВключитьИсключитьНаСервере(ДополнительныеПараметры.НеобходимоОбновитьРоли, ДополнительныеПараметры.ТекущаяРоль);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораОбъектаОшибки(Результат, ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда		
				
		ВыбранныйОбъект = Результат.Синоним;
		
		Элементы.УказатьОбъектОшибки.Заголовок  = "Объект выбран:";
		Элементы.УказатьОбъектОшибки.ЦветТекста = WebЦвета.ЗеленыйЛес;
		Элементы.УказатьОбъектОшибки.Картинка   = Результат.Картинка;
	
		ЭтотОбъект.ПолноеИмяОбъекта = Результат.ПолноеИмя;
		
		НайтиРолиВОбъекте(ПолноеИмяОбъекта);	
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПослеНазначенияГрупп(Результат, ДополнительныеПараметры) Экспорт
	
	Если Элементы.РолиОбъекта.ТекущиеДанные <> Неопределено Тогда
		РолиОбъектаВыборНаСервере(Элементы.РолиОбъекта.ТекущиеДанные.Роль); 
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВключитьИсключитьИзГруппыЗавершение(НовыйПарольПользователяСервиса, ДополнительныеПараметры) Экспорт
	
	Если НовыйПарольПользователяСервиса = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НовыйПарольПользователяСервиса <> Null Тогда
		Объект.ПарольПользователяСервиса = НовыйПарольПользователяСервиса;
	КонецЕсли;
	
	ОписаниеОшибки = "";
	
	ИзменитьСоставГруппы(ДополнительныеПараметры, ОписаниеОшибки);
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ПоказатьПредупреждение(, ОписаниеОшибки);
	Иначе
		ОповеститьОбИзменении(ДополнительныеПараметры.ГруппаДоступа);
		Оповестить("Запись_ГруппыДоступа", Новый Структура, ДополнительныеПараметры.ГруппаДоступа); 
		
		ЗаписатьВТаблицуИстории(ДополнительныеПараметры.ПризнакНаличияГруппы,
								ДополнительныеПараметры.ТекущаяГруппаДоступа, 
								ДополнительныеПараметры.РольПредставление, 
								ДополнительныеПараметры.КартинкаМета, 
								ДополнительныеПараметры.СинонимМета);
		//ЗаписатьТаблицуВРегистр(ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере                                                             
Процедура НайтиОбъектыНаСервере()
	
	Перем НайденнаяРоль;
	
	ТаблицаВхождений.Очистить();
	
	Для Каждого Роль Из Метаданные.Роли Цикл
		
		Если ВыбраннаяРоль = Роль.Имя Тогда
			НайденнаяРоль = Роль;						
		КонецЕсли;
		
	КонецЦикла;
	
	Если НайденнаяРоль <> Неопределено Тогда
		
		Для Каждого ОписаниеКоллекции Из ПолучитьОписаниеКоллекцийМетаданных() Цикл
			
			Для Каждого ОМ Из Метаданные[ОписаниеКоллекции.Имя] Цикл 
				
				Попытка             
					
					Если ПравоДоступа("Использование", ОМ, НайденнаяРоль) Тогда	 
						
						СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
						
						Если НЕ СтрокаНайдена.Количество() Тогда 
							НоваяСтрока = ТаблицаВхождений.Добавить();
							НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
							НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя();
						КонецЕсли;
						
					КонецЕсли;
					
				Исключение
				КонецПопытки;
				
				Попытка 
					
					СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
					
					Если НЕ СтрокаНайдена.Количество() Тогда      
						
						Если ПравоДоступа("Чтение", ОМ, НайденнаяРоль) Тогда
							НоваяСтрока = ТаблицаВхождений.Добавить();
							НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
							НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя();
						КонецЕсли;                                                 
						
					КонецЕсли;
					
				Исключение
				КонецПопытки;
				
				Попытка 
					
					СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
					
					Если НЕ СтрокаНайдена.Количество() Тогда   
						
						Если ПравоДоступа("Просмотр", ОМ, НайденнаяРоль) Тогда
							НоваяСтрока = ТаблицаВхождений.Добавить();
							НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
							НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя();
						КонецЕсли;                                             
						
					КонецЕсли;
					
				Исключение
				КонецПопытки;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ТаблицаВхождений.Количество() Тогда
		Элементы.УдалитьОтборРоли.Доступность = Истина;
		НайденныеОбъекты = "Найдено: " + Формат(ТаблицаВхождений.Количество(), "ЧГ=0");
	Иначе 		
		НайденныеОбъекты = "Найдено: 0";
		НайтиРолиВОбъекте(, НайденнаяРоль);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоместитьТаблицуВХ(Знач ТаблицаВхождений, АдресВХ)
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаВхождений.Выгрузить(), Новый УникальныйИдентификатор);	
	
КонецФункции

&НаКлиенте
Процедура ПослеВыбораРоли(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяРоль = Результат.Значение;
	
	Если Элементы.ВыбраннаяРоль.СписокВыбора.НайтиПоЗначению(Результат.Значение) = Неопределено Тогда
		Элементы.ВыбраннаяРоль.СписокВыбора.Добавить(Результат.Значение, Результат.Представление,, БиблиотекаКартинок.ЗакрытыйКлюч);
	КонецЕсли;
	
	ПрименитьВыбраннуюРоль();
	
КонецПроцедуры

&НаСервере
Процедура ПослеВыбораРолиНаСервере(ПослеВыбораРоли)

	НайтиОбъектыНаСервере();
	
	ДеревоВДанныеФормы(ПослеВыбораРоли);
	
КонецПроцедуры

&НаСервере
Процедура ДеревоВДанныеФормы(ПослеВыбораРоли = Ложь)
	
	
	КоллекцияСтрок = ДеревоКонфигурации.ПолучитьЭлементы();
	КоллекцияСтрок.Очистить();
	
	СписокМетаданных.Очистить();
	
	МассивОтбора = Новый Массив;
	
	Для Каждого Вхождение Из ТаблицаВхождений Цикл
		МассивОтбора.Добавить(Вхождение.ОбъектМетаданныхПолноеИмя);
	КонецЦикла;
	
	ПараметрыОтбора = ?(ТаблицаВхождений.Количество() Или ПослеВыбораРоли, Новый Структура("ПолноеИмя", МассивОтбора), Неопределено);				
	ЗначениеВДанныеФормы(ДеревоМетаданныхКонфигурации(ПараметрыОтбора,, Истина), ДеревоКонфигурации);

КонецПроцедуры

&НаКлиенте
Процедура ПослеРедактированияОграничений(Результат, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры.ИндексСтрокиКоллекции <> Неопределено Тогда
		СтрокаКоллекции = ТаблицаГруппДоступа.Получить(ДополнительныеПараметры.ИндексСтрокиКоллекции);
		Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
	КонецЕсли;
	
	ВыбраннаяГруппаДоступа = Неопределено;
	ТаблицаГруппДоступаПриАктивизацииСтроки(Элементы.ТаблицаГруппДоступа);
	
	Если ДополнительныеПараметры.ИндексСтрокиОграничения <> Неопределено Тогда
		СтрокаКоллекции = ВидыДоступа.Получить(ДополнительныеПараметры.ИндексСтрокиОграничения);
		Элементы.ВидыДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
	КонецЕсли;
	
	ВидыДоступаПриАктивизацииСтроки(Элементы.ВидыДоступа);
		
КонецПроцедуры

&НаКлиенте
Процедура ПослеПодтвержденияНачалаОтладки(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = "Отмена" Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПользователя = ДанныеПользователяИБ(Объект.Пользователь);
	Если ДанныеПользователя.ПользователяНет Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет указанного пользователя информационной базы");
	КонецЕсли;
	
	СтрокаПараметров = "ENTERPRISE /RunModeManagedApplication " + СтрокаСоединенияИнформационнойБазы() + " /N""" + ДанныеПользователя.ИмяПользователя +  """ /P""123""";
	ОбновитьПарольПользователя(Новый Структура("ИдентификаторПользователяИБ, СохраненыйПароль, СтандартАут",
		ДанныеПользователя.ИдентификаторПользователяИБ, "QL0AFWMIX8NRZTKeof9cXsvbvu8=,QL0AFWMIX8NRZTKeof9cXsvbvu8=", Истина));
		
	СеансНайден = Ложь;
	СчетчикОбработкиОжидания = 1;
	
	ПодключитьОбработчикОжидания("НайтиСеансИВосстановитьПароль", 5);
	ЗапуститьСистему(СтрокаПараметров);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеПользователяИБ(Пользователь)

	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Пользователь.ИдентификаторПользователяИБ);	
	Возврат Новый Структура("ПользователяНет, СтандартАут, СохраненыйПароль, ИмяПользователя, ИдентификаторПользователяИБ",
	ПользовательИБ = Неопределено, ПользовательИБ.АутентификацияСтандартная, ПользовательИБ.СохраняемоеЗначениеПароля,ПользовательИБ.Имя, Пользователь.ИдентификаторПользователяИБ);	

КонецФункции

&НаСервереБезКонтекста
Процедура ОбновитьПарольПользователя(Параметры) Экспорт
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Параметры.ИдентификаторПользователяИБ);
	ПользовательИБ.СохраняемоеЗначениеПароля = Параметры.СохраненыйПароль;
	ПользовательИБ.АутентификацияСтандартная = Параметры.СтандартАут;
	ПользовательИБ.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьПароль(СчетчикОбработкиОжидания = 0) Экспорт
	
	ОтключитьОбработчикОжидания("НайтиСеансИВосстановитьПароль");
	
	Попытка	
		ОбновитьПарольПользователя(ДанныеПользователя);
		
		Если СчетчикОбработкиОжидания < 5 Тогда	
			ПоказатьОповещениеПользователя("Сеанс запущен!",,"Пароль был успешно восстановлен", БиблиотекаКартинок.Успешно, СтатусОповещенияПользователя.Информация);
		Иначе
			ПоказатьОповещениеПользователя("Сеанс не обнаружен!",,"Пароль был успешно восстановлен", БиблиотекаКартинок.Силуэт, СтатусОповещенияПользователя.Информация);
		КонецЕсли;
		
	Исключение
		ПоказатьОповещениеПользователя("Ошибка записи!",, "Восстановить пароль не удалось", БиблиотекаКартинок.Ошибка32, СтатусОповещенияПользователя.Информация);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Предыдущее сохраняемое значение пароля: " + ДанныеПользователя.СохраненыйПароль);
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиСеансИВосстановитьПароль()
	
	Если СчетчикОбработкиОжидания = 5 Тогда
		ВосстановитьПароль(СчетчикОбработкиОжидания);
		Возврат;
	КонецЕсли;
	
	Если НЕ СеансНайден Тогда
		НайтиЗапущенныйСеанс(ИмяКомпьютера());
	Иначе
		ВосстановитьПароль();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НайтиЗапущенныйСеанс(ТекПК)
	
	СчетчикОбработкиОжидания = СчетчикОбработкиОжидания + 1;
	
	СеансыИнформационнойБазы = ПолучитьСеансыИнформационнойБазы();
	
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Объект.Пользователь.ИдентификаторПользователяИБ);
	
	Для Каждого Строка Из СеансыИнформационнойБазы Цикл
		
		Если Строка.Пользователь.УникальныйИдентификатор = ПользовательИБ.УникальныйИдентификатор И Строка.ИмяПриложения = "1CV8C" И Строка.ИмяКомпьютера = ТекПК Тогда
			СеансНайден = Истина;
			Прервать;
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьШаблонНаСервере(СтруктураПараметров)
	
	ГруппаОбъект = СтруктураПараметров.ГруппаДоступа.ПолучитьОбъект();	
	                                                                                                                                             
	ЗначениеУжеЕсть = ГруппаОбъект.ЗначенияДоступа.НайтиСтроки(Новый Структура("ЗначениеДоступа", СтруктураПараметров.ЗначениеДоступа));
	
	Если НЕ ЗначениеУжеЕсть.Количество() И (СтруктураПараметров.ИмяКоманды = "ДобавитьЗначениеВШаблон" ИЛИ СтруктураПараметров.ИмяКоманды = "НовоеЗначениеВШаблон") Тогда
		НоваяСтрока = ГруппаОбъект.ЗначенияДоступа.Добавить();
		НоваяСтрока.ЗначениеДоступа = СтруктураПараметров.ЗначениеДоступа;
		НоваяСтрока.ВидДоступа = СтруктураПараметров.ВидДоступаСсылка;
		ГруппаОбъект.Записать();
	ИначеЕсли ЗначениеУжеЕсть.Количество() И (СтруктураПараметров.ИмяКоманды = "ИсключитьЗначениеИзШаблона" ИЛИ СтруктураПараметров.ИмяКоманды = "УдалитьЗначениеИзШаблона") Тогда		
		ГруппаОбъект.ЗначенияДоступа.Удалить(ЗначениеУжеЕсть[0]);
		ГруппаОбъект.Записать();
	Иначе		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Значение доступа """ + СтруктураПараметров.ЗначениеДоступа + """ уже имеется!");
 	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораОганизации(Результат, ДополнительныеПараметры) Экспорт
	
