&НаСервере
Процедура ДобавитьОписаниеКоллекцииМетаданных(Коллекции, Имя, Синоним, ГруппаОбщие, Порядок, ИмяКартинки, ИмяТипаОбъекта = "")
	
	Если НЕ КоллекцияМетаданныхСуществует(Имя) Тогда
		Возврат;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяТипаОбъекта) Тогда
		ИмяТипаОбъекта = ИмяКартинки;
	КонецЕсли;
	
	Коллекции.Добавить(Новый Структура(
		"Имя, Синоним, ГруппаОбщие, Порядок, Картинка, ИмяТипаОбъекта",
		Имя,
		Синоним,
		ГруппаОбщие,
		Порядок,
		КартинкаКоллекцииМетаданных(ИмяКартинки),
		ИмяТипаОбъекта));
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОписаниеКоллекцийМетаданных()
	
	Коллекции = Новый Массив;
	
	// Группа «Общие» — порядок как в конфигураторе (вкладка «Права» роли).
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "Подсистемы", "Подсистемы", Истина, 1, "Подсистема", "Подсистема");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "ПараметрыСеанса", "Параметры сеанса", Истина, 2, "ПараметрСеанса", "ПараметрСеанса");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "ОбщиеРеквизиты", "Общие реквизиты", Истина, 3, "ОбщийРеквизит", "ОбщийРеквизит");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "ПланыОбмена", "Планы обмена", Истина, 4, "ПланОбмена", "ПланОбмена");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "КритерииОтбора", "Критерии отбора", Истина, 5, "КритерийОтбора", "КритерийОтбора");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "ОбщиеКоманды", "Общие команды", Истина, 6, "ОбщаяКоманда", "ОбщаяКоманда");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "ОбщиеФормы", "Общие формы", Истина, 7, "Форма", "ОбщаяФорма");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "WebСервисы", "Web-сервисы", Истина, 8, "WebСервис", "WebСервис");
	ДобавитьОписаниеКоллекцииМетаданных(Коллекции, "HTTPСервисы", "HTTP-сервисы", Истина, 9, "HTTPСервис", "HTTPСервис");
