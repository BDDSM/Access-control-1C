&НаСервере
Функция КоличествоЭлементовСписка(Список)
	
	Если Список = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	ТипСписка = ТипЗнч(Список);
	
	Если ТипСписка = Тип("Массив")
		ИЛИ ТипСписка = Тип("СписокЗначений")
		ИЛИ ТипСписка = Тип("ФиксированныйМассив") Тогда
		Возврат Список.Количество();
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

&НаСервере
Функция СформироватьТекстСписка(Список, ТекстПусто, Префикс)
	
	КоличествоЭлементов = КоличествоЭлементовСписка(Список);
	
	Если КоличествоЭлементов = 0 Тогда
		Возврат ТекстПусто;
	КонецЕсли;
	
	МаксимумСтрок = 100;
	СтрокиСписка = Новый Массив;
	НомерСтроки = 0;
	
	Для Каждого ЭлементСписка Из Список Цикл
		
		Если НомерСтроки >= МаксимумСтрок Тогда
			Прервать;
		КонецЕсли;
		
		СтрокиСписка.Добавить("• " + Строка(ЭлементСписка));
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
	Текст = Префикс + Формат(КоличествоЭлементов, "ЧГ=0") + Символы.ПС + Символы.ПС
		+ СтрСоединить(СтрокиСписка, Символы.ПС);
	
	Если КоличествоЭлементов > МаксимумСтрок Тогда
		Текст = Текст + Символы.ПС + "… и ещё "
			+ Формат(КоличествоЭлементов - МаксимумСтрок, "ЧГ=0");
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

