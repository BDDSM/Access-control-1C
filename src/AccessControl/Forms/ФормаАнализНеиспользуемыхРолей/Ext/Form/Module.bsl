
#Область ПеременныеКлиента

&НаКлиенте
Перем ПараметрыСинхроннойОперации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Заголовок = "Отчеты по ролям";
	ЗагрузкаДанных = Истина;
	ЗагрузкаМетрик = Ложь;
	ПолеHTML = HTMLСостоянияЗагрузки("Формирование отчётов по ролям…", 5);
	
	Если НЕ Параметры.Свойство("ФормироватьОтчетыПоРолямВФоне", ФормироватьОтчетыПоРолямВФоне) Тогда
		ФормироватьОтчетыПоРолямВФоне = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПодключитьОбработчикОжидания("ЗаполнитьТаблицыРолейОтложенно", ИнтервалОтрисовкиПередЗагрузкойОтчета(), Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТаблицыРолейОтложенно() Экспорт
	
	ЗаполнитьТаблицыРолей(Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Обновить(Команда)
	
	ЗаполнитьТаблицыРолей();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура СтрокаПоискаПриИзменении(Элемент)
	
	СформироватьHTMLДокумент();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ДанныеСобытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АдресСсылки = "";
	
	Если ДанныеСобытия.Свойство("Href", АдресСсылки) Тогда
		// Href получен из структуры события.
	ИначеЕсли ТипЗнч(ДанныеСобытия) = Тип("Строка") Тогда
		АдресСсылки = ДанныеСобытия;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(АдресСсылки) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗагрузкаДанных ИЛИ ЗагрузкаМетрик Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрНачинаетсяС(АдресСсылки, "v8action:expand:") Тогда
		Раздел = Сред(АдресСсылки, СтрДлина("v8action:expand:") + 1);
		ПереключитьРаздел(Раздел, Истина);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:collapse:") Тогда
		Раздел = Сред(АдресСсылки, СтрДлина("v8action:collapse:") + 1);
		ПереключитьРаздел(Раздел, Ложь);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:detail:objects:") Тогда
		ИмяРоли = Сред(АдресСсылки, СтрДлина("v8action:detail:objects:") + 1);
		ПоказатьДеталиОбъектовРоли(ИмяРоли);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:detail:profiles:") Тогда
		ИмяРоли = Сред(АдресСсылки, СтрДлина("v8action:detail:profiles:") + 1);
		ПоказатьДеталиПрофилейРоли(ИмяРоли);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:filter:") Тогда
		ПереключитьОтбор(АдресСсылки);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:legend:expand:") Тогда
		Раздел = Сред(АдресСсылки, СтрДлина("v8action:legend:expand:") + 1);
		ПереключитьЛегендуНаСервере(Раздел, Истина);
	ИначеЕсли СтрНачинаетсяС(АдресСсылки, "v8action:legend:collapse:") Тогда
		Раздел = Сред(АдресСсылки, СтрДлина("v8action:legend:collapse:") + 1);
		ПереключитьЛегендуНаСервере(Раздел, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДеталиОбъектовРоли(ИмяРоли)
	
	Детали = ПолучитьДеталиОбъектовРолиНаСервере(ИмяРоли);
	ПоказатьПредупреждение(, Детали.Текст, , Детали.Заголовок);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДеталиПрофилейРоли(ИмяРоли)
	
	Детали = ПолучитьДеталиПрофилейРолиНаСервере(ИмяРоли);
	ПоказатьПредупреждение(, Детали.Текст, , Детали.Заголовок);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаполнитьТаблицыРолей(ПослеОтрисовки = Ложь)
	
	Если НЕ ФормироватьОтчетыПоРолямВФоне И НЕ ПослеОтрисовки Тогда
		УстановитьHTMLЗагрузкиНаСервере("Формирование отчётов по ролям…", 5);
		ПодключитьОбработчикОжидания("ЗаполнитьТаблицыРолейОтложенно", ИнтервалОтрисовкиПередЗагрузкойОтчета(), Истина);
		Возврат;
	КонецЕсли;
	
	ЗагрузкаДанных = Истина;
	ЗагрузкаМетрик = Ложь;
	УстановитьHTMLЗагрузкиНаСервере("Формирование отчётов по ролям…", 0);
	
	ЗапуститьДлительнуюОперациюКлиент(
		"СформироватьДанныеОтчетовПоРолям",
		Новый Структура,
		"Анализ и контроль доступа: отчёты по ролям",
		"ЗаполнитьТаблицыРолейЗавершение",
		"Формирование отчётов по ролям…",
		Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуЗапускаФона(ТекстОшибки)
	
	Текст = "Не удалось запустить фоновое задание.";
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Текст = Текст + Символы.ПС + ТекстОшибки;
	КонецЕсли;
	
	ПоказатьПредупреждение(, Текст);
	УстановитьHTMLЗагрузкиНаСервере("Фоновое задание недоступно.", 0);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТаблицыРолейЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ЗагрузкаДанных = Ложь;
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, Результат.КраткоеПредставлениеОшибки);
		УстановитьHTMLЗагрузкиНаСервере("Не удалось сформировать отчёты. Нажмите «Обновить».", 0);
		Возврат;
	КонецЕсли;
	
	ПрименитьДанныеОтчетовНаСервере(Результат.АдресРезультата, НЕ ОтложитьОтображениеОтчетаДоПодсчетаМетрик());
	
	Если ОтложитьОтображениеОтчетаДоПодсчетаМетрик() Тогда
		ЗапуститьПодсчетМетрикПослеФормирования();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ОтложитьОтображениеОтчетаДоПодсчетаМетрик()
	
	Возврат НЕ ФормироватьОтчетыПоРолямВФоне;
	
КонецФункции

&НаКлиенте
Функция ТекстПодсчетаМетрикСинхронногоОтчета()
	
	Возврат "Идёт подсчёт метрик ролей…";
	
КонецФункции

&НаКлиенте
Процедура ЗапуститьПодсчетМетрикПослеФормирования()
	
	Если ЗагрузкаМетрик ИЛИ ОбъектыМетаданныхПодсчитаны Тогда
		Возврат;
	КонецЕсли;
	
	НачатьПодсчетОбъектовМетаданных();
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьРаздел(Раздел, Развернуть)
	
	ПереключитьРазделНаСервере(Раздел, Развернуть);
	
	Если НЕ Развернуть Тогда
		СформироватьHTMLДокументНаСервере();
		Возврат;
	КонецЕсли;
	
	Если НЕ ОбъектыМетаданныхПодсчитаны Тогда
		НачатьПодсчетОбъектовМетаданных();
	Иначе
		СформироватьHTMLДокументНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПодсчетОбъектовМетаданных()
	
	Если ЗагрузкаМетрик Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузкаМетрик = Истина;
	ТекстЗагрузкиМетрик = ?(ОтложитьОтображениеОтчетаДоПодсчетаМетрик(),
		ТекстПодсчетаМетрикСинхронногоОтчета(),
		"Подготовка к подсчёту…");
	ПроцентЗагрузкиМетрик = 0;
	УстановитьСостояниеЗагрузкиНаСервере(Ложь, Истина);
	
	Если ФормироватьОтчетыПоРолямВФоне
		И (РазвернутБезПользователей ИЛИ РазвернутВнеПрофилей) Тогда
		СформироватьHTMLДокументНаСервере();
	ИначеЕсли ОтложитьОтображениеОтчетаДоПодсчетаМетрик() Тогда
		УстановитьHTMLЗагрузкиНаСервере(ТекстЗагрузкиМетрик, 0);
	КонецЕсли;
	
	ЗапуститьДлительнуюОперациюКлиент(
		"ПодсчитатьОбъектыМетаданныхОтчетовПоРолям",
		ПараметрыПодсчетаМетрикНаСервере(),
		"Анализ и контроль доступа: метрики ролей",
		"ПодсчетМетрикЗавершение",
		"Подсчёт объектов метаданных для карточек ролей…",
		Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПодсчетМетрикЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ЗагрузкаМетрик = Ложь;
	
	Если Результат = Неопределено Тогда
		СформироватьHTMLДокументНаСервере();
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, Результат.КраткоеПредставлениеОшибки);
		СформироватьHTMLДокументНаСервере();
		Возврат;
	КонецЕсли;
	
	ПрименитьМетрикиОбъектовНаСервере(Результат.АдресРезультата);
	
КонецПроцедуры

&НаКлиенте
Функция ИнтервалОтрисовкиПередЗагрузкойОтчета()
	
	Если НЕ ФормироватьОтчетыПоРолямВФоне Тогда
		Возврат 0.4;
	КонецЕсли;
	
	Возврат 0.15;
	
КонецФункции

&НаКлиенте
Функция ИнтервалОтрисовкиПередСинхроннойОперацией()
	
	Возврат 0.2;
	
КонецФункции

#Область ДлительныеОперации

#Область СинхронноеФормированиеОтчетов

&НаКлиенте
Процедура ВыполнитьОперациюОтчетовСинхронноКлиент(ИмяМетода, ПараметрыПроцедуры, ИмяПроцедурыЗавершения, ЭтоПодсчетМетрик)
	
	ПараметрыСинхроннойОперации = Новый Структура(
		"ИмяМетода, ПараметрыПроцедуры, ИмяПроцедурыЗавершения, ЭтоПодсчетМетрик",
		ИмяМетода, ПараметрыПроцедуры, ИмяПроцедурыЗавершения, ЭтоПодсчетМетрик);
	ПодключитьОбработчикОжидания("ЗапуститьСинхроннуюОперациюОтложенно", ИнтервалОтрисовкиПередСинхроннойОперацией(), Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьСинхроннуюОперациюОтложенно() Экспорт
	
	ОтключитьОбработчикОжидания("ЗапуститьСинхроннуюОперациюОтложенно");
	
	Если ПараметрыСинхроннойОперации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВыполнения = ПараметрыСинхроннойОперации;
	ПараметрыСинхроннойОперации = Неопределено;
	
	РезультатОперации = ВыполнитьОперациюОтчетовСинхронноНаСервере(
		ПараметрыВыполнения.ИмяМетода,
		ПараметрыВыполнения.ПараметрыПроцедуры);
	
	Оповещение = Новый ОписаниеОповещения(ПараметрыВыполнения.ИмяПроцедурыЗавершения, ЭтотОбъект);
	ВыполнитьОбработкуОповещения(Оповещение, РезультатОперации);
	
КонецПроцедуры

&НаСервере
Функция ВыполнитьОперациюОтчетовСинхронноНаСервере(ИмяМетода, ПараметрыПроцедуры)
	
	Результат = Новый Структура("Статус, АдресРезультата, КраткоеПредставлениеОшибки", "Выполнено", "", "");
	
	Попытка
		
		ПараметрыВыполнения = ПараметрыПроцедуры;
		
		Если ПараметрыВыполнения = Неопределено Тогда
			ПараметрыВыполнения = Новый Структура;
		КонецЕсли;
		
		АдресПрогрессаФона = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
		
		Попытка
			ПараметрыВыполнения.Удалить("АдресПрогресса");
		Исключение
		КонецПопытки;
		
		ПараметрыВыполнения.Вставить("АдресПрогресса", АдресПрогрессаФона);
		
		АдресРезультата = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
		ОбъектОбработки = РеквизитФормыВЗначение("Объект");
		
		Если ИмяМетода = "СформироватьДанныеОтчетовПоРолям" Тогда
			ОбъектОбработки.СформироватьДанныеОтчетовПоРолям(ПараметрыВыполнения, АдресРезультата);
		ИначеЕсли ИмяМетода = "ПодсчитатьОбъектыМетаданныхОтчетовПоРолям" Тогда
			ОбъектОбработки.ПодсчитатьОбъектыМетаданныхОтчетовПоРолям(ПараметрыВыполнения, АдресРезультата);
		Иначе
			ВызватьИсключение СтрШаблон("Неизвестный метод отчёта по ролям: %1", ИмяМетода);
		КонецЕсли;
		
		Результат.АдресРезультата = АдресРезультата;
		
	Исключение
		Результат.Статус = "Ошибка";
		Результат.КраткоеПредставлениеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

// По образцу ПоискИУдалениеДублей: сначала ФайловаяСистемаКлиент.ЗагрузитьФайл на сервер,
// затем ВнешнийОтчетОбработка из ПолучитьИзВременногоХранилища(Результат.Хранение).

&НаКлиенте
Процедура ЗапуститьДлительнуюОперациюКлиент(ИмяМетода, ПараметрыПроцедуры, НаименованиеЗадания,
	ИмяПроцедурыЗавершения, ТекстОжидания, ЭтоПодсчетМетрик)
	
	Если НЕ ФормироватьОтчетыПоРолямВФоне Тогда
		ВыполнитьОперациюОтчетовСинхронноКлиент(ИмяМетода, ПараметрыПроцедуры, ИмяПроцедурыЗавершения, ЭтоПодсчетМетрик);
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяМетода", ИмяМетода);
	ДополнительныеПараметры.Вставить("ПараметрыПроцедуры", ПараметрыПроцедуры);
	ДополнительныеПараметры.Вставить("НаименованиеЗадания", НаименованиеЗадания);
	ДополнительныеПараметры.Вставить("ИмяПроцедурыЗавершения", ИмяПроцедурыЗавершения);
	ДополнительныеПараметры.Вставить("ТекстОжидания", ТекстОжидания);
	ДополнительныеПараметры.Вставить("ЭтоПодсчетМетрик", ЭтоПодсчетМетрик);
	
	ДвоичныеДанныеОбработки = ПолучитьКэшДвоичныхДанныхОбработкиНаСервере();
	
	Если ДвоичныеДанныеОбработки <> Неопределено Тогда
		ЗапуститьФоновоеЗаданиеПослеЗагрузкиФайла(ДвоичныеДанныеОбработки, ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	ИмяФайлаОбработки = ПолучитьИмяФайлаОбработкиНаСервере();
	
	Если НЕ ЗначениеЗаполнено(ИмяФайлаОбработки) Тогда
		ЗавершитьОжиданиеЗагрузки(ЭтоПодсчетМетрик);
		ПоказатьОшибкуЗапускаФона("Не удалось определить файл внешней обработки (ИспользуемоеИмяФайла пусто).");
		Возврат;
	КонецЕсли;
	
	ОбработчикОповещения = Новый ОписаниеОповещения("ПослеЗагрузкиФайлаОбработкиНаСервер", ЭтотОбъект,
		ДополнительныеПараметры);
	ОтправитьФайлОбработкиНаСервер(ИмяФайлаОбработки, ОбработчикОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьФоновоеЗаданиеПослеЗагрузкиФайла(ДвоичныеДанныеОбработки, ДополнительныеПараметры)
	
	Задание = ВыполнитьДлительнуюОперациюВФоне(
		ДополнительныеПараметры.ИмяМетода,
		ДополнительныеПараметры.ПараметрыПроцедуры,
		ДополнительныеПараметры.НаименованиеЗадания,
		ДвоичныеДанныеОбработки);
	
	Если НЕ Задание.ИспользоватьФон Тогда
		ЗавершитьОжиданиеЗагрузки(ДополнительныеПараметры.ЭтоПодсчетМетрик);
		ПоказатьОшибкуЗапускаФона(Задание.ПричинаОтказа);
		Возврат;
	КонецЕсли;
	
	ОжидатьДлительнуюОперацию(Задание.Операция, ДополнительныеПараметры.ИмяПроцедурыЗавершения,
		ДополнительныеПараметры.ТекстОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьФайлОбработкиНаСервер(ИмяФайла, ОбработчикОповещения)
	
	ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
	ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;
	ПараметрыЗагрузки.Интерактивно = Ложь;
	ФайловаяСистемаКлиент.ЗагрузитьФайл(ОбработчикОповещения, ПараметрыЗагрузки, ИмяФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗагрузкиФайлаОбработкиНаСервер(Результат, ДополнительныеПараметры) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Результат.Имя) Тогда
		ЗавершитьОжиданиеЗагрузки(ДополнительныеПараметры.ЭтоПодсчетМетрик);
		ПоказатьОшибкуЗапускаФона("Не удалось загрузить файл обработки на сервер для фонового задания.");
		Возврат;
	КонецЕсли;
	
	ДвоичныеДанныеОбработки = ПолучитьИзВременногоХранилища(Результат.Хранение);
	СохранитьКэшДвоичныхДанныхОбработкиНаСервере(ДвоичныеДанныеОбработки);
	ЗапуститьФоновоеЗаданиеПослеЗагрузкиФайла(ДвоичныеДанныеОбработки, ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьОжиданиеЗагрузки(ЭтоПодсчетМетрик)
	
	Если ЭтоПодсчетМетрик Тогда
		ЗагрузкаМетрик = Ложь;
		СформироватьHTMLДокументНаСервере();
	Иначе
		ЗагрузкаДанных = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьИмяФайлаОбработкиНаСервере()
	
	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	
	Попытка
		Возврат ОбъектОбработки.ИспользуемоеИмяФайла;
	Исключение
		Попытка
			Возврат ОбъектОбработки.ИспользуемоеИмяФайла();
		Исключение
			Возврат "";
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ВыполнитьДлительнуюОперациюВФоне(ИмяМетода, ПараметрыПроцедуры, НаименованиеЗадания,
	ДвоичныеДанныеОбработки)
	
	РезультатЗапуска = Новый Структура("ИспользоватьФон, Операция, ПричинаОтказа",
		Ложь, Неопределено, "");
	
	Если Метаданные.ОбщиеМодули.Найти("ДлительныеОперации") = Неопределено Тогда
		РезультатЗапуска.ПричинаОтказа = "Подсистема длительных операций БСП недоступна.";
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	Если ДвоичныеДанныеОбработки = Неопределено Тогда
		РезультатЗапуска.ПричинаОтказа = "Не удалось получить двоичные данные внешней обработки для фонового задания.";
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	ИмяПроцедуры = РеквизитФормыВЗначение("Объект").Метаданные().ПолноеИмя() + ".МодульОбъекта." + ИмяМетода;
	
	НастройкиЗапуска = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	НастройкиЗапуска.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	НастройкиЗапуска.ВнешнийОтчетОбработка = ДвоичныеДанныеОбработки;
	
	РезультатЗапуска.ИспользоватьФон = Истина;
	РезультатЗапуска.Операция = ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыПроцедуры, НастройкиЗапуска);
	
	Возврат РезультатЗапуска;
	
КонецФункции

&НаСервере
Функция ПараметрыПодсчетаМетрикНаСервере()
	
	ПараметрыЗадания = Новый Структура;
	ПараметрыЗадания.Вставить("АдресТаблицыБезПользователей",
		ПоместитьВоВременноеХранилище(
			ТаблицаРолейВТаблицуЗначений(ТаблицаРолейБезПользователей),
			УникальныйИдентификатор));
	ПараметрыЗадания.Вставить("АдресТаблицыВнеПрофилей",
		ПоместитьВоВременноеХранилище(
			ТаблицаРолейВТаблицуЗначений(ТаблицаРолейВнеПрофилей),
			УникальныйИдентификатор));
	
	Возврат ПараметрыЗадания;
	
КонецФункции

&НаСервере
Функция ТаблицаРолейВТаблицуЗначений(ТаблицаФормы)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Роль");
	Результат.Колонки.Добавить("Синоним");
	Результат.Колонки.Добавить("Комментарий");
	Результат.Колонки.Добавить("КоличествоПрофилей");
	Результат.Колонки.Добавить("КоличествоПрав");
	
	Для Каждого СтрокаДанных Из ТаблицаФормы Цикл
		ЗаполнитьЗначенияСвойств(Результат.Добавить(), СтрокаДанных);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура СохранитьКэшДвоичныхДанныхОбработкиНаСервере(ДвоичныеДанныеОбработки)
	
	Если ДвоичныеДанныеОбработки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АдресДвоичныхДанныхОбработки = ПоместитьВоВременноеХранилище(ДвоичныеДанныеОбработки, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКэшДвоичныхДанныхОбработкиНаСервере()
	
	Если НЕ ЗначениеЗаполнено(АдресДвоичныхДанныхОбработки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат ПолучитьИзВременногоХранилища(АдресДвоичныхДанныхОбработки);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаКлиенте
Процедура ОжидатьДлительнуюОперацию(ДлительнаяОперация, ИмяПроцедурыЗавершения, ТекстОжидания)
	
	Если ДлительнаяОперация = Неопределено Тогда
		ВыполнитьОбработкуОповещения(ИмяПроцедурыЗавершения, Неопределено);
		Возврат;
	КонецЕсли;
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ТекстСообщения = ТекстОжидания;
	
	Оповещение = Новый ОписаниеОповещения(ИмяПроцедурыЗавершения, ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ПрименитьДанныеОтчетовНаСервере(АдресРезультата, ОтображатьОтчет = Истина)
	
	Данные = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	ТаблицаРолейБезПользователей.Очистить();
	ТаблицаРолейВнеПрофилей.Очистить();
	
	Для Каждого СтрокаДанных Из Данные.ТаблицаРолейБезПользователей Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаРолейБезПользователей.Добавить(), СтрокаДанных);
	КонецЦикла;
	
	Для Каждого СтрокаДанных Из Данные.ТаблицаРолейВнеПрофилей Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаРолейВнеПрофилей.Добавить(), СтрокаДанных);
	КонецЦикла;
	
	ВсегоРолейКонфигурации = Данные.ВсегоРолейКонфигурации;
	КоличествоБезПользователей = Данные.КоличествоБезПользователей;
	КоличествоВнеПрофилей = Данные.КоличествоВнеПрофилей;
	ОбъектыМетаданныхПодсчитаны = Ложь;
	ОтборБезОбъектовБезПользователей = Ложь;
	ОтборБезПрофилейБезПользователей = Ложь;
	ОтборБезОбъектовВнеПрофилей = Ложь;
	ЛегендаРазвернутаБезПользователей = Ложь;
	ЛегендаРазвернутаВнеПрофилей = Ложь;
	РазвернутБезПользователей = Ложь;
	РазвернутВнеПрофилей = Ложь;
	
	ЗагрузкаДанных = Ложь;
	
	Если ОтображатьОтчет Тогда
		СформироватьHTMLДокумент();
		УстановитьВидимостьПоиска();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьМетрикиОбъектовНаСервере(АдресРезультата)
	
	Данные = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	ПрименитьКоличествоПравИзТаблицы(ТаблицаРолейБезПользователей, Данные.ТаблицаРолейБезПользователей);
	ПрименитьКоличествоПравИзТаблицы(ТаблицаРолейВнеПрофилей, Данные.ТаблицаРолейВнеПрофилей);
	ОбъектыМетаданныхПодсчитаны = Истина;
	
	ЗагрузкаМетрик = Ложь;
	СформироватьHTMLДокумент();
	УстановитьВидимостьПоиска();
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьКоличествоПравИзТаблицы(ТаблицаФормы, ТаблицаРезультата)
	
	КоличествоПоРолям = Новый Соответствие;
	
	Для Каждого СтрокаРезультата Из ТаблицаРезультата Цикл
		КоличествоПоРолям.Вставить(СтрокаРезультата.Роль, СтрокаРезультата.КоличествоПрав);
	КонецЦикла;
	
	Для Каждого СтрокаРоли Из ТаблицаФормы Цикл
		КоличествоПрав = КоличествоПоРолям[СтрокаРоли.Роль];
		Если КоличествоПрав <> Неопределено Тогда
			СтрокаРоли.КоличествоПрав = КоличествоПрав;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеЗагрузкиНаСервере(ЗагрузкаДанныхФлаг, ЗагрузкаМетрикФлаг)
	
	ЗагрузкаДанных = ЗагрузкаДанныхФлаг;
	ЗагрузкаМетрик = ЗагрузкаМетрикФлаг;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьHTMLЗагрузкиНаСервере(Текст, Процент)
	
	ПолеHTML = HTMLСостоянияЗагрузки(Текст, Процент);
	
КонецПроцедуры

&НаСервере
Процедура СформироватьHTMLДокументНаСервере()
	
	СформироватьHTMLДокумент();
	
КонецПроцедуры

&НаСервере
Процедура ПереключитьРазделНаСервере(Раздел, Развернуть)
	
	Если Раздел = "БезПользователей" Тогда
		РазвернутБезПользователей = Развернуть;
	ИначеЕсли Раздел = "ВнеПрофилей" Тогда
		РазвернутВнеПрофилей = Развернуть;
	Иначе
		Возврат;
	КонецЕсли;
	
	УстановитьВидимостьПоиска();
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьОтбор(АдресСсылки)
	
	НуженПодсчетОбъектов = ПереключитьОтборНаСервере(АдресСсылки);
	
	Если НуженПодсчетОбъектов И НЕ ОбъектыМетаданныхПодсчитаны Тогда
		НачатьПодсчетОбъектовМетаданных();
	Иначе
		СформироватьHTMLДокументНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПереключитьОтборНаСервере(АдресСсылки)
	
	Префикс = "v8action:filter:";
	Хвост = Сред(АдресСсылки, СтрДлина(Префикс) + 1);
	Части = СтрРазделить(Хвост, ":", Ложь);
	
	Если Части.Количество() < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Раздел = Части[0];
	ИмяОтбора = Части[1];
	НуженПодсчетОбъектов = Ложь;
	
	Если Раздел = "БезПользователей" Тогда
		
		Если ИмяОтбора = "БезОбъектов" Тогда
			ОтборБезОбъектовБезПользователей = НЕ ОтборБезОбъектовБезПользователей;
			НуженПодсчетОбъектов = ОтборБезОбъектовБезПользователей;
		ИначеЕсли ИмяОтбора = "БезПрофилей" Тогда
			ОтборБезПрофилейБезПользователей = НЕ ОтборБезПрофилейБезПользователей;
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	ИначеЕсли Раздел = "ВнеПрофилей" Тогда
		
		Если ИмяОтбора = "БезОбъектов" Тогда
			ОтборБезОбъектовВнеПрофилей = НЕ ОтборБезОбъектовВнеПрофилей;
			НуженПодсчетОбъектов = ОтборБезОбъектовВнеПрофилей;
		Иначе
			Возврат Ложь;
		КонецЕсли;
		
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Возврат НуженПодсчетОбъектов;
	
КонецФункции

&НаСервере
Процедура ПереключитьЛегендуНаСервере(Раздел, Развернуть)
	
	Если Раздел = "БезПользователей" Тогда
		ЛегендаРазвернутаБезПользователей = Развернуть;
	ИначеЕсли Раздел = "ВнеПрофилей" Тогда
		ЛегендаРазвернутаВнеПрофилей = Развернуть;
	Иначе
		Возврат;
	КонецЕсли;
	
	СформироватьHTMLДокумент();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоиска()
	
	Элементы.СтрокаПоиска.Видимость = РазвернутБезПользователей ИЛИ РазвернутВнеПрофилей;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьHTMLДокумент()
	
	Если ЗагрузкаДанных ИЛИ ЗагрузкаМетрик Тогда
		Возврат;
	КонецЕсли;
	
	ТекстПоиска = НРег(СокрЛП(СтрокаПоиска));
	
	ТекстHTML = "<!DOCTYPE html><html><head><meta charset=""utf-8"">";
	ТекстHTML = ТекстHTML + СтилиHTMLДокумента();
	ТекстHTML = ТекстHTML + "</head><body>";
	ТекстHTML = ТекстHTML + РазделОтчетаHTML(
		"БезПользователей",
		"Роли без пользователей",
		"Роли конфигурации, которые не назначены ни одному пользователю через группы и профили доступа.",
		ТаблицаРолейБезПользователей,
		РазвернутБезПользователей,
		ТекстПоиска);
	ТекстHTML = ТекстHTML + РазделОтчетаHTML(
		"ВнеПрофилей",
		"Роли вне профилей",
		"Роли конфигурации, которые не входят ни в один профиль групп доступа. "
			+ "Часто такие роли назначаются программно.",
		ТаблицаРолейВнеПрофилей,
		РазвернутВнеПрофилей,
		ТекстПоиска);
	ТекстHTML = ТекстHTML + "</body></html>";
	ПолеHTML = ТекстHTML;
	
КонецПроцедуры

&НаСервере
Функция РазделОтчетаHTML(ИдентификаторРаздела, ЗаголовокРаздела, ОписаниеРаздела, ТаблицаРолей, Развернут, ТекстПоиска)
	
	КоличествоНайдено = ПодсчитатьРолиРаздела(ТаблицаРолей, ИдентификаторРаздела);
	Процент = ?(ВсегоРолейКонфигурации = 0, 0, Окр(100 * КоличествоНайдено / ВсегоРолейКонфигурации, 1));
	КлассРежима = ?(ИдентификаторРаздела = "ВнеПрофилей", "mode-outside", "mode-unused");
	
	Если Развернут Тогда
		ТекстКнопки = "Свернуть";
		АдресКнопки = "v8action:collapse:" + ИдентификаторРаздела;
	Иначе
		ТекстКнопки = "Детальный просмотр";
		АдресКнопки = "v8action:expand:" + ИдентификаторРаздела;
	КонецЕсли;
	
	Результат =
	"<section class=""report-section " + КлассРежима + """>
	|	<div class=""page-header " + КлассРежима + """>
	|		<div class=""page-title"">" + ЭкранироватьHTML(ЗаголовокРаздела) + "</div>
	|		<div class=""page-desc"">" + ЭкранироватьHTML(ОписаниеРаздела) + "</div>
	|		" + ФильтрыРазделаHTML(ИдентификаторРаздела) + "
	|		<div class=""stats"">
	|			<div class=""stat-card stat-found"">
	|				<div class=""stat-value"">" + ФорматКоличестваМетрики(КоличествоНайдено) + "</div>
	|				<div class=""stat-label"">найдено</div>
	|			</div>
	|			<div class=""stat-card"">
	|				<div class=""stat-value"">" + ФорматКоличестваМетрики(ВсегоРолейКонфигурации) + "</div>
	|				<div class=""stat-label"">всего ролей</div>
	|			</div>
	|			<div class=""stat-card stat-share"">
	|				<div class=""stat-value"">" + Формат(Процент, "ЧН=0; ЧГ=0") + "%</div>
	|				<div class=""stat-label"">доля от конфигурации</div>
	|			</div>
	|		</div>
	|		<a class=""expand-btn"" href=""" + АдресКнопки + """>" + ЭкранироватьHTML(ТекстКнопки) + "</a>";
	
	Если Развернут Тогда
		Результат = Результат + ЛегендаРазделаHTML(ИдентификаторРаздела);
	КонецЕсли;
	
	Результат = Результат + "
	|	</div>";
	
	Если Развернут Тогда
		
		Результат = Результат + "<div class=""roles"">";
		
		Если ЗагрузкаМетрик Тогда
			Результат = Результат + HTMLИндикаторПрогресса(ТекстЗагрузкиМетрик, ПроцентЗагрузкиМетрик, Истина);
			Результат = Результат + "</div></section>";
			Возврат Результат;
		КонецЕсли;
		
		Отфильтровано = 0;
		
		Для Каждого СтрокаРоли Из ТаблицаРолей Цикл
			
			Если НЕ СтрокаРолиПодходитПоОтборам(СтрокаРоли, ИдентификаторРаздела) Тогда
				Продолжить;
			КонецЕсли;
			
			Если НЕ СтрокаПодходитПоПоиску(СтрокаРоли, ТекстПоиска) Тогда
				Продолжить;
			КонецЕсли;
			
			Отфильтровано = Отфильтровано + 1;
			Результат = Результат + КарточкаРолиHTML(СтрокаРоли, ИдентификаторРаздела);
			
		КонецЦикла;
		
		Если Отфильтровано = 0 Тогда
			Результат = Результат + "<div class=""empty-state"">По текущему отбору роли не найдены.</div>";
		КонецЕсли;
		
		Результат = Результат + "</div>";
		
	КонецЕсли;
	
	Результат = Результат + "</section>";
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция КарточкаРолиHTML(СтрокаРоли, ИдентификаторРаздела)
	
	КлассКарточки = ?(ИдентификаторРаздела = "ВнеПрофилей", "role-card outside", "role-card unused");
	Синоним = ЭкранироватьHTML(СтрокаРоли.Синоним);
	ИмяРоли = ЭкранироватьHTML(СтрокаРоли.Роль);
	КомментарийHTML = "";
	
	Если ЗначениеЗаполнено(СтрокаРоли.Комментарий) Тогда
		КомментарийHTML = "<div class=""role-comment"">" + ЭкранироватьHTML(СтрокаРоли.Комментарий) + "</div>";
	КонецЕсли;
	
	Метрики = МетрикиРолиHTML(СтрокаРоли, ИдентификаторРаздела);
	
	Возврат
	"<article class=""" + КлассКарточки + """>
	|	<div class=""role-head"">
	|		<div class=""role-title"">" + Синоним + "</div>
	|		<div class=""role-name"">" + ИмяРоли + "</div>
	|	</div>
	|	" + Метрики + "
	|	" + КомментарийHTML + "
	|</article>";
	
КонецФункции

&НаСервере
Функция ФильтрыРазделаHTML(ИдентификаторРаздела)
	
	Результат =
	"<div class=""filters"">
	|	<div class=""filters-title"">Отбор</div>
	|	<div class=""filters-list"">";
	
	Если ИдентификаторРаздела = "БезПользователей" Тогда
		
		Результат = Результат + ФильтрЧипHTML(
			"БезПользователей",
			"БезОбъектов",
			"Показать не назначенные ни на один объект метаданных",
			ОтборБезОбъектовБезПользователей);
		Результат = Результат + ФильтрЧипHTML(
			"БезПользователей",
			"БезПрофилей",
			"Показать не состоящие ни в одном профиле",
			ОтборБезПрофилейБезПользователей);
		
	Иначе
		
		Результат = Результат + ФильтрЧипHTML(
			"ВнеПрофилей",
			"БезОбъектов",
			"Показать не назначенные ни на один объект метаданных",
			ОтборБезОбъектовВнеПрофилей);
		
	КонецЕсли;
	
	Результат = Результат + "
	|	</div>
	|</div>";
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ФильтрЧипHTML(Раздел, ИмяОтбора, Текст, Активен)
	
	Класс = ?(Активен, "filter-chip filter-chip-active", "filter-chip");
	Адрес = "v8action:filter:" + Раздел + ":" + ИмяОтбора;
	
	Возврат "<a class=""" + Класс + """ href=""" + Адрес + """>" + ЭкранироватьHTML(Текст) + "</a>";
	
КонецФункции

&НаСервере
Функция ОтборыРазделаАктивны(ИдентификаторРаздела)
	
	Если ИдентификаторРаздела = "БезПользователей" Тогда
		Возврат ОтборБезОбъектовБезПользователей ИЛИ ОтборБезПрофилейБезПользователей;
	КонецЕсли;
	
	Возврат ОтборБезОбъектовВнеПрофилей;
	
КонецФункции

&НаСервере
Функция СтрокаРолиПодходитПоОтборам(СтрокаРоли, ИдентификаторРаздела)
	
	Если НЕ ОтборыРазделаАктивны(ИдентификаторРаздела) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ОтборБезОбъектовАктивен(ИдентификаторРаздела) Тогда
		
		Если НЕ ОбъектыМетаданныхПодсчитаны Тогда
			// До завершения фонового подсчёта отбор по объектам не применяем — иначе все роли с нулём.
		ИначеЕсли СтрокаРоли.КоличествоПрав <> 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИдентификаторРаздела = "БезПользователей"
		И ОтборБезПрофилейБезПользователей
		И СтрокаРоли.КоличествоПрофилей <> 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ОтборБезОбъектовАктивен(ИдентификаторРаздела)
	
	Если ИдентификаторРаздела = "БезПользователей" Тогда
		Возврат ОтборБезОбъектовБезПользователей;
	КонецЕсли;
	
	Возврат ОтборБезОбъектовВнеПрофилей;
	
КонецФункции

&НаСервере
Функция ПодсчитатьРолиРаздела(ТаблицаРолей, ИдентификаторРаздела)
	
	Количество = 0;
	
	Для Каждого СтрокаРоли Из ТаблицаРолей Цикл
		
		Если СтрокаРолиПодходитПоОтборам(СтрокаРоли, ИдентификаторРаздела) Тогда
			Количество = Количество + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Количество;
	
КонецФункции

&НаСервере
Функция ЛегендаРазделаHTML(ИдентификаторРаздела)
	
	ЛегендаРазвернута = ЛегендаРазвернутаРаздела(ИдентификаторРаздела);
	
	Если ЛегендаРазвернута Тогда
		АдресПереключателя = "v8action:legend:collapse:" + ИдентификаторРаздела;
		ПодписьПереключателя = "Скрыть расшифровку";
		ТелоЛегенды = ТелоЛегендыРазделаHTML(ИдентификаторРаздела);
	Иначе
		АдресПереключателя = "v8action:legend:expand:" + ИдентификаторРаздела;
		ПодписьПереключателя = "Показать расшифровку меток";
		ТелоЛегенды = "";
	КонецЕсли;
	
	Возврат
	"<div class=""legend"">
	|	<a class=""legend-toggle"" href=""" + АдресПереключателя + """>" + ЭкранироватьHTML(ПодписьПереключателя) + "</a>
	|	" + ТелоЛегенды + "
	|</div>";
	
КонецФункции

&НаСервере
Функция ЛегендаРазвернутаРаздела(ИдентификаторРаздела)
	
	Если ИдентификаторРаздела = "БезПользователей" Тогда
		Возврат ЛегендаРазвернутаБезПользователей;
	КонецЕсли;
	
	Возврат ЛегендаРазвернутаВнеПрофилей;
	
КонецФункции

&НаСервере
Функция ТелоЛегендыРазделаHTML(ИдентификаторРаздела)
	
	Если ИдентификаторРаздела = "ВнеПрофилей" Тогда
		
		Возврат
		"<div class=""legend-body"">
		|	<div class=""legend-item"">
		|		<span class=""metric metric-muted legend-sample"">0 объектов метаданных</span>
		|		<span class=""legend-text"">объекты конфигурации, на которые у роли есть права (как при отборе роли на главной форме). Нажмите на значок в карточке, чтобы увидеть список.</span>
		|	</div>
		|</div>";
		
	КонецЕсли;
	
	Возврат
	"<div class=""legend-body"">
	|	<div class=""legend-item"">
	|		<span class=""metric metric-muted legend-sample"">0 объектов метаданных</span>
	|		<span class=""legend-text"">объекты конфигурации, на которые у роли есть права (как при отборе роли на главной форме). Нажмите на значок в карточке, чтобы увидеть список.</span>
	|	</div>
	|	<div class=""legend-item"">
	|		<span class=""metric metric-muted legend-sample"">0 профилей</span>
	|		<span class=""legend-text"">профили групп доступа, куда включена роль, но без назначенных пользователей. Нажмите на значок в карточке, чтобы увидеть список.</span>
	|	</div>
	|</div>";
	
КонецФункции

&НаСервере
Функция МетрикиРолиHTML(СтрокаРоли, ИдентификаторРаздела)
	
	ТекстОбъектов = ФорматКоличестваМетрики(СтрокаРоли.КоличествоПрав) + " "
		+ ЧислоОбъектовСклонение(СтрокаРоли.КоличествоПрав) + " метаданных";
	КлассОбъектов = ?(СтрокаРоли.КоличествоПрав = 0, "metric metric-muted", "metric metric-rights");
	АдресОбъектов = "v8action:detail:objects:" + СтрокаРоли.Роль;
	
	Результат = "<div class=""metrics"">"
		+ "<a class=""" + КлассОбъектов + " metric-link"" href=""" + АдресОбъектов + """>"
		+ ЭкранироватьHTML(ТекстОбъектов) + "</a>";
	
	Если ИдентификаторРаздела = "БезПользователей" Тогда
		ТекстПрофилей = ФорматКоличестваМетрики(СтрокаРоли.КоличествоПрофилей) + " "
			+ ЧислоПрофилейСклонение(СтрокаРоли.КоличествоПрофилей);
		КлассПрофилей = ?(СтрокаРоли.КоличествоПрофилей = 0, "metric metric-muted", "metric metric-profiles");
		АдресПрофилей = "v8action:detail:profiles:" + СтрокаРоли.Роль;
		Результат = Результат
			+ "<a class=""" + КлассПрофилей + " metric-link"" href=""" + АдресПрофилей + """>"
			+ ЭкранироватьHTML(ТекстПрофилей) + "</a>";
	КонецЕсли;
	
	Результат = Результат + "</div>";
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ФорматКоличестваМетрики(Количество)
	
	// ЧН=0 — явно показывать ноль (без этого Формат(0, "ЧГ=0") часто даёт пустую строку).
	Возврат Формат(Количество, "ЧН=0; ЧГ=0");
	
КонецФункции

