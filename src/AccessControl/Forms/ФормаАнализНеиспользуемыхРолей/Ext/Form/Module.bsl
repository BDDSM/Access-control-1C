&НаСервере
Функция HTMLИндикаторПрогресса(Текст, Процент, ВСтрокуРаздела = Ложь)
	
	Процент = Макс(0, Мин(100, Процент));
	КлассОболочки = ?(ВСтрокуРаздела, "loading-inline", "loading-wrap");
	
	Возврат
	"<div class=""" + КлассОболочки + """>
	|	<div class=""loading-title"">" + ЭкранироватьHTML(Текст) + "</div>
	|	<div class=""loading-bar""><div class=""loading-bar-fill"" style=""width:" + Формат(Процент, "ЧГ=0") + "%""></div></div>
	|</div>";
	
КонецФункции

&НаСервере
Функция HTMLСостоянияЗагрузки(Текст, Процент)
	
	Возврат
	"<!DOCTYPE html><html><head><meta charset=""utf-8"">" + СтилиHTMLДокумента()
		+ "</head><body>" + HTMLИндикаторПрогресса(Текст, Процент, Ложь) + "</body></html>";
	
КонецФункции

&НаСервере
Функция СтрокаПодходитПоПоиску(СтрокаРоли, ТекстПоиска)
	
	Если ПустаяСтрока(ТекстПоиска) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Образец = НРег(СтрокаРоли.Роль) + " " + НРег(СтрокаРоли.Синоним) + " " + НРег(СтрокаРоли.Комментарий);
	Возврат СтрНайти(Образец, ТекстПоиска) > 0;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭкранироватьHTML(Текст)
	
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	Результат = СтрЗаменить(Текст, "&", "&amp;");
	Результат = СтрЗаменить(Результат, "<", "&lt;");
	Результат = СтрЗаменить(Результат, ">", "&gt;");
	Результат = СтрЗаменить(Результат, """", "&quot;");
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПолучитьДеталиОбъектовРолиНаСервере(ИмяРоли)
	
	Результат = Новый Структура("Заголовок, Текст", "Объекты метаданных", "");
	СинонимРоли = ИмяРоли;
	РольМета = Метаданные.Роли.Найти(ИмяРоли);
	
	Если РольМета <> Неопределено Тогда
		СинонимРоли = РольМета.Синоним;
	КонецЕсли;
	
	Результат.Заголовок = "Объекты метаданных: " + СинонимРоли;
	
	Если Метаданные.РегистрыСведений.Найти("ПраваРолей") = Неопределено Тогда
		Результат.Текст = "Регистр «Права ролей» недоступен в этой конфигурации.";
		Возврат Результат;
	КонецЕсли;
	
	МассивОбъектов = ЗаполнитьМассивОбъектовРолиИзРегистра(ИмяРоли);
	
	Если КоличествоЭлементовСписка(МассивОбъектов) = 0 И РольМета <> Неопределено Тогда
		МассивОбъектов = ПолучитьСписокОбъектовРолиПравоДоступа(РольМета);
		Если МассивОбъектов = Неопределено Тогда
			МассивОбъектов = Новый Массив;
		КонецЕсли;
	КонецЕсли;
	
	Результат.Текст = СформироватьТекстСписка(МассивОбъектов,
		"Для роли не найдено объектов метаданных с правами доступа.",
		"Найдено объектов: ");
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПолучитьДеталиПрофилейРолиНаСервере(ИмяРоли)
	
	Результат = Новый Структура("Заголовок, Текст", "Профили доступа", "");
	СинонимРоли = ИмяРоли;
	РольМета = Метаданные.Роли.Найти(ИмяРоли);
	
	Если РольМета <> Неопределено Тогда
		СинонимРоли = РольМета.Синоним;
	КонецЕсли;
	
	Результат.Заголовок = "Профили групп доступа: " + СинонимРоли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПрофилиГруппДоступаРоли.Ссылка.Наименование КАК Профиль
	|ИЗ
	|	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|ГДЕ
	|	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	|	И НЕ ПрофилиГруппДоступаРоли.Ссылка.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Профиль";
	Запрос.УстановитьПараметр("Роль", ИмяРоли);
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
	Исключение
		УстановитьПривилегированныйРежим(Ложь);
		Результат.Текст = "Справочник «Профили групп доступа» недоступен в этой конфигурации.";
		Возврат Результат;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	МассивПрофилей = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Профиль) Тогда
			МассивПрофилей.Добавить(Строка(Выборка.Профиль));
		КонецЕсли;
	КонецЦикла;
	
	Результат.Текст = СформироватьТекстСписка(МассивПрофилей,
		"Роль не входит ни в один профиль групп доступа.",
		"Найдено профилей: ");
	
	Возврат Результат;
	
КонецФункции

