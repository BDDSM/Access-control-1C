Функция ПолучитьПоследнийРелизСGitHub()
	
	Сервер = "api.github.com";
	Ресурс = "/repos/VorozhbitDM/Access-control-1C/releases/latest";
	ТаймаутСекунд = 10;
	
	Соединение = Новый HTTPСоединение(Сервер,,,,, ТаймаутСекунд, Новый ЗащищенноеСоединениеOpenSSL);
	Запрос = Новый HTTPЗапрос(Ресурс);
	Запрос.Заголовки.Вставить("User-Agent", "AccessControl-1C/" + ВерсияОбработки());
	Запрос.Заголовки.Вставить("Accept", "application/vnd.github+json");
	
	Ответ = Соединение.Получить(Запрос);
	
	Если Ответ.КодСостояния <> 200 Тогда
		ВызватьИсключение "HTTP " + Формат(Ответ.КодСостояния, "ЧГ=0") + " при запросе последнего релиза.";
	КонецЕсли;
	
	Тело = Ответ.ПолучитьТелоКакСтроку();
	
	Если ПустаяСтрока(Тело) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(Тело);
	Данные = ПрочитатьJSON(Чтение, Истина);
	
	ТегВерсии = ЗначениеПоляJSON(Данные, "tag_name");
	АдресРелиза = ЗначениеПоляJSON(Данные, "html_url");
	
	Если НЕ ЗначениеЗаполнено(ТегВерсии) Тогда
		ВызватьИсключение "В ответе GitHub (HTTP 200) нет поля tag_name.";
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТегВерсии", ТегВерсии);
	Результат.Вставить("АдресРелиза", ?(ЗначениеЗаполнено(АдресРелиза), АдресРелиза, URLСтраницыРелизов()));
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеПоляJSON(ДанныеJSON, ИмяПоля)
	
	Если ДанныеJSON = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(ДанныеJSON) = Тип("Структура") И ДанныеJSON.Свойство(ИмяПоля) Тогда
		Возврат ДанныеJSON[ИмяПоля];
	КонецЕсли;
	
	Если ТипЗнч(ДанныеJSON) = Тип("Соответствие") Тогда
		Значение = ДанныеJSON.Получить(ИмяПоля);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		Возврат ДанныеJSON[ИмяПоля];
	Исключение
		Возврат "";
	КонецПопытки;
	
КонецФункции

Функция НормализоватьСтрокуВерсии(СтрокаВерсии)
	
	Результат = СокрЛП(СтрокаВерсии);
	
	Если ПустаяСтрока(Результат) Тогда
		Возврат "";
	КонецЕсли;
	
	Если Лев(НРег(Результат), 1) = "v" Тогда
		Результат = СокрЛП(Сред(Результат, 2));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СравнитьВерсии(Версия1, Версия2)
	
	Части1 = РазобратьВерсиюНаЧисла(Версия1);
	Части2 = РазобратьВерсиюНаЧисла(Версия2);
	МаксИндекс = Макс(Части1.ВГраница(), Части2.ВГраница());
	
	Для Индекс = 0 По МаксИндекс Цикл
		
		Число1 = ?(Индекс <= Части1.ВГраница(), Части1[Индекс], 0);
		Число2 = ?(Индекс <= Части2.ВГраница(), Части2[Индекс], 0);
		
		Если Число1 < Число2 Тогда
			Возврат -1;
		ИначеЕсли Число1 > Число2 Тогда
			Возврат 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

Функция РазобратьВерсиюНаЧисла(СтрокаВерсии)
	
	Нормализованная = НормализоватьСтрокуВерсии(СтрокаВерсии);
	ЧастиСтроки = СтрРазделить(Нормализованная, ".", Ложь);
	Результат = Новый Массив;
	
	Для Каждого Часть Из ЧастиСтроки Цикл
		
		ЧисловаяЧасть = "";
		
		Для Позиция = 1 По СтрДлина(Часть) Цикл
			
			Символ = Сред(Часть, Позиция, 1);
			
			Если Символ >= "0" И Символ <= "9" Тогда
				ЧисловаяЧасть = ЧисловаяЧасть + Символ;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Результат.Добавить(?(ЗначениеЗаполнено(ЧисловаяЧасть), Число(ЧисловаяЧасть), 0));
		
	КонецЦикла;
	
	Если Результат.Количество() = 0 Тогда
		Результат.Добавить(0);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

