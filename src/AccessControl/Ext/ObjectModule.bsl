#Область ДлительныеОперацииОтчетов

Функция ПолучитьНастройкиДлительныхОперацийОтчетов() Экспорт
	
	Настройки = Новый Структура;
	Настройки.Вставить("ИспользоватьФон", Ложь);
	Настройки.Вставить("ВерсияБСП", "");
	Настройки.Вставить("ПричинаОтказа", "");
	
	Если Метаданные.ОбщиеМодули.Найти("СтандартныеПодсистемыСервер") = Неопределено
		ИЛИ Метаданные.ОбщиеМодули.Найти("ДлительныеОперации") = Неопределено Тогда
		Настройки.ПричинаОтказа = "Подсистема длительных операций БСП недоступна.";
		Возврат Настройки;
	КонецЕсли;
	
	ВерсияБСП = СтандартныеПодсистемыСервер.ВерсияБиблиотеки();
	Настройки.ВерсияБСП = ВерсияБСП;
	
	Если СравнитьВерсии(ВерсияБСП, "3.1.5") < 0 Тогда
		Настройки.ПричинаОтказа = "Требуется БСП 3.1.5 или новее (текущая: " + Лев(ВерсияБСП, 10) + ").";
		Возврат Настройки;
	КонецЕсли;
	
	Настройки.ИспользоватьФон = Истина;
	
	Возврат Настройки;
	
КонецФункции

// Двоичные данные .epf обязательны для ВнешнийОтчетОбработка в ДлительныеОперации.
//
// Параметры:
//  АдресИзВременногоХранилища - Строка - адрес, помещённый на клиенте;
//  СсылкаДопОбработки - СправочникСсылка.ДополнительныеОтчетыИОбработки - при запуске из БСП.
//
Функция ПолучитьДвоичныеДанныеОбработкиДляФона(ОбработкаОбъект, АдресИзВременногоХранилища = "",
	СсылкаДопОбработки = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(АдресИзВременногоХранилища) Тогда
		ДанныеИзХранилища = ПолучитьИзВременногоХранилища(АдресИзВременногоХранилища);
		Если ТипЗнч(ДанныеИзХранилища) = Тип("ДвоичныеДанные") Тогда
			Возврат ДанныеИзХранилища;
		КонецЕсли;
	КонецЕсли;
	
	ДвоичныеДанные = ДвоичныеДанныеОбработкиИзСправочникаПоСсылке(СсылкаДопОбработки);
	
	Если ДвоичныеДанные <> Неопределено Тогда
		Возврат ДвоичныеДанные;
	КонецЕсли;
	
	ДвоичныеДанные = ДвоичныеДанныеПоИспользуемомуИмениФайлаОбъекта(ЭтотОбъект);
	
	Если ДвоичныеДанные <> Неопределено Тогда
		Возврат ДвоичныеДанные;
	КонецЕсли;
	
	Если ОбработкаОбъект <> ЭтотОбъект Тогда
		ДвоичныеДанные = ДвоичныеДанныеПоИспользуемомуИмениФайлаОбъекта(ОбработкаОбъект);
		Если ДвоичныеДанные <> Неопределено Тогда
			Возврат ДвоичныеДанные;
		КонецЕсли;
	КонецЕсли;
	
	ИмяОбъекта = ОбработкаОбъект.Метаданные().Имя;
	ДвоичныеДанные = ДвоичныеДанныеОбработкиИзСправочника(ИмяОбъекта);
	
	Если ДвоичныеДанные <> Неопределено Тогда
		Возврат ДвоичныеДанные;
	КонецЕсли;
	
	ДвоичныеДанные = ДвоичныеДанныеОбработкиЧерезЗапись(ЭтотОбъект);
	
	Если ДвоичныеДанные <> Неопределено Тогда
		Возврат ДвоичныеДанные;
	КонецЕсли;
	
	Возврат ДвоичныеДанныеОбработкиЧерезЗапись(ОбработкаОбъект);
	
КонецФункции

Функция ДвоичныеДанныеПоИспользуемомуИмениФайлаОбъекта(ОбработкаОбъект)
	
	Попытка
		Возврат ДвоичныеДанныеПоИспользуемомуИмениФайла(ОбработкаОбъект.ИспользуемоеИмяФайла());
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// ИспользуемоеИмяФайла() — путь к .epf или адрес e1cib/tempstorage с двоичными данными.
Функция ДвоичныеДанныеПоИспользуемомуИмениФайла(ИспользуемоеИмя) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ИспользуемоеИмя) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если СтрНачинаетсяС(НРег(ИспользуемоеИмя), "e1cib") Тогда
		ДанныеИзХранилища = ПолучитьИзВременногоХранилища(ИспользуемоеИмя);
		Если ТипЗнч(ДанныеИзХранилища) = Тип("ДвоичныеДанные") Тогда
			Возврат ДанныеИзХранилища;
		КонецЕсли;
		Возврат Неопределено;
	КонецЕсли;
	
	ФайлОбработки = Новый Файл(ИспользуемоеИмя);
	
	Если ФайлОбработки.Существует() Тогда
		Возврат Новый ДвоичныеДанные(ИспользуемоеИмя);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ДвоичныеДанныеОбработкиИзСправочникаПоСсылке(СсылкаДопОбработки)
	
	Если НЕ ЗначениеЗаполнено(СсылкаДопОбработки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		
		Если Метаданные.ОбщиеМодули.Найти("ОбщегоНазначения") <> Неопределено Тогда
			ХранилищеОбработки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаДопОбработки, "ХранилищеОбработки");
			Если ХранилищеОбработки <> Неопределено Тогда
				Возврат ХранилищеОбработки.Получить();
			КонецЕсли;
		КонецЕсли;
		
		ХранилищеОбработки = СсылкаДопОбработки.ХранилищеОбработки;
		Если ХранилищеОбработки <> Неопределено Тогда
			Возврат ХранилищеОбработки.Получить();
		КонецЕсли;
		
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция ДвоичныеДанныеОбработкиИзСправочника(ИмяОбъектаОбработки)
	
	Если Метаданные.Справочники.Найти("ДополнительныеОтчетыИОбработки") = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДополнительныеОтчетыИОбработки.ХранилищеОбработки КАК ХранилищеОбработки
		|ИЗ
		|	Справочник.ДополнительныеОтчетыИОбработки КАК ДополнительныеОтчетыИОбработки
		|ГДЕ
		|	НЕ ДополнительныеОтчетыИОбработки.ПометкаУдаления
		|	И (ДополнительныеОтчетыИОбработки.ИмяОбъекта = &ИмяОбъекта
		|		ИЛИ ДополнительныеОтчетыИОбработки.ИмяОбъекта ПОДОБНО &ИмяОбъектаПодобно)";
		Запрос.УстановитьПараметр("ИмяОбъекта", ИмяОбъектаОбработки);
		Запрос.УстановитьПараметр("ИмяОбъектаПодобно", "%" + ИмяОбъектаОбработки + "%");
		
		УстановитьПривилегированныйРежим(Истина);
		Выборка = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);
		
		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ХранилищеОбработки) Тогда
			Возврат Выборка.ХранилищеОбработки.Получить();
		КонецЕсли;
		
	Исключение
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция ДвоичныеДанныеОбработкиЧерезЗапись(ОбработкаОбъект)
	
	Попытка
		ИмяВременногоФайла = КаталогВременныхФайлов()
			+ ПолучитьРазделительПути()
			+ "AC_"
			+ СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "")
			+ ".epf";
		ОбработкаОбъект.Записать(ИмяВременногоФайла);
		ДвоичныеДанные = Новый ДвоичныеДанные(ИмяВременногоФайла);
		УдалитьФайлы(ИмяВременногоФайла);
		Возврат ДвоичныеДанные;
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

// Запуск фонового задания для внешней обработки (как в типовых обработках БСП).
//
// Параметры:
//  ИмяМетода - Строка - экспортная процедура модуля объекта без префикса;
//  ПолноеИмяОбработки - Строка - Метаданные().ПолноеИмя() текущей обработки;
//  ДвоичныеДанныеОбработки - ДвоичныеДанные, Неопределено - файл .epf для фонового задания.
//
Функция ЗапуститьДлительнуюОперациюОтчетов(ИмяМетода, ПараметрыПроцедуры, ИдентификаторФормы, НаименованиеЗадания,
	ПолноеИмяОбработки, ДвоичныеДанныеОбработки = Неопределено) Экспорт
	
	Настройки = ПолучитьНастройкиДлительныхОперацийОтчетов();
	РезультатЗапуска = Новый Структура("ИспользоватьФон, Операция, ПричинаОтказа, Настройки",
		Ложь, Неопределено, Настройки.ПричинаОтказа, Настройки);
	
	Если НЕ Настройки.ИспользоватьФон Тогда
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПолноеИмяОбработки) Тогда
		РезультатЗапуска.ПричинаОтказа = "Не удалось определить полное имя обработки.";
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	ИмяПроцедуры = ПолноеИмяОбработки + ".МодульОбъекта." + ИмяМетода;
	
	Если ДвоичныеДанныеОбработки = Неопределено Тогда
		РезультатЗапуска.ПричинаОтказа = "Не удалось получить двоичные данные внешней обработки для фонового задания.";
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеЗадания;
	ПараметрыВыполнения.ВнешнийОтчетОбработка = ДвоичныеДанныеОбработки;
	УстановитьСвойствоПараметровДлительнойОперации(ПараметрыВыполнения, "ПрерватьВыполнениеЕслиЗакрытаФорма", Истина);
	
	Операция = ДлительныеОперации.ВыполнитьВФоне(ИмяПроцедуры, ПараметрыПроцедуры, ПараметрыВыполнения);
	
	РезультатЗапуска.ИспользоватьФон = Истина;
	РезультатЗапуска.Операция = Операция;
	РезультатЗапуска.ПричинаОтказа = "";
	
	Возврат РезультатЗапуска;
	
КонецФункции

Процедура УстановитьСвойствоПараметровДлительнойОперации(ПараметрыВыполнения, ИмяСвойства, Значение)
	
	Попытка
		ПараметрыВыполнения[ИмяСвойства] = Значение;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область ОтчетыПоРолям

Процедура СформироватьДанныеОтчетовПоРолям(Параметры, АдресРезультата) Экспорт
	
	ДлительныеОперации.СообщитьПрогресс(0, "Подготовка отчётов по ролям…");
	
	ТаблицаРолейБезПользователей = НоваяТаблицаРолейОтчета();
	ТаблицаРолейВнеПрофилей = ТаблицаРолейБезПользователей.Скопировать();
	
	ВсегоРолейКонфигурации = Метаданные.Роли.Количество();
	
	ДлительныеОперации.СообщитьПрогресс(10, "Загрузка данных о назначениях…");
	
	ИспользуемыеСПользователями = ПолучитьИменаИспользуемыхРолейОтчета("БезПользователей");
	ИспользуемыеВПрофилях = ПолучитьИменаИспользуемыхРолейОтчета("ВнеПрофилей");
	ПрофилиПоРолям = ПолучитьКоличествоПрофилейПоРолямОтчета();
	
	ДлительныеОперации.СообщитьПрогресс(25, "Анализ ролей конфигурации…");
	
	Индекс = 0;
	
	Для Каждого РольМета Из Метаданные.Роли Цикл
		
		Индекс = Индекс + 1;
		
		Если Индекс % 25 = 0 И ВсегоРолейКонфигурации > 0 Тогда
			Процент = 25 + Окр(55 * Индекс / ВсегоРолейКонфигурации);
			ДлительныеОперации.СообщитьПрогресс(Процент,
				СтрШаблон("Анализ ролей: %1 из %2…", Индекс, ВсегоРолейКонфигурации));
		КонецЕсли;
		
		Если ИспользуемыеСПользователями[РольМета.Имя] = Неопределено Тогда
			НоваяСтрока = ТаблицаРолейБезПользователей.Добавить();
			ЗаполнитьСтрокуРолиОтчета(НоваяСтрока, РольМета, ПрофилиПоРолям);
		КонецЕсли;
		
		Если ИспользуемыеВПрофилях[РольМета.Имя] = Неопределено Тогда
			НоваяСтрока = ТаблицаРолейВнеПрофилей.Добавить();
			ЗаполнитьСтрокуРолиОтчета(НоваяСтрока, РольМета, ПрофилиПоРолям);
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаРолейБезПользователей.Сортировать("Синоним");
	ТаблицаРолейВнеПрофилей.Сортировать("Синоним");
	
	ДлительныеОперации.СообщитьПрогресс(85, "Загрузка прав из регистра…");
	
	ОбъектыПоРолям = ПолучитьКоличествоПравПоРолямОтчета();
	ЗаполнитьКоличествоОбъектовОтчета(ТаблицаРолейБезПользователей, ОбъектыПоРолям);
	ЗаполнитьКоличествоОбъектовОтчета(ТаблицаРолейВнеПрофилей, ОбъектыПоРолям);
	
	ДлительныеОперации.СообщитьПрогресс(95, "Завершение…");
	
	Результат = Новый Структура;
	Результат.Вставить("ВсегоРолейКонфигурации", ВсегоРолейКонфигурации);
	Результат.Вставить("ТаблицаРолейБезПользователей", ТаблицаРолейБезПользователей);
	Результат.Вставить("ТаблицаРолейВнеПрофилей", ТаблицаРолейВнеПрофилей);
	Результат.Вставить("КоличествоБезПользователей", ТаблицаРолейБезПользователей.Количество());
	Результат.Вставить("КоличествоВнеПрофилей", ТаблицаРолейВнеПрофилей.Количество());
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	ДлительныеОперации.СообщитьПрогресс(100, "Готово");
	
КонецПроцедуры

Процедура ПодсчитатьОбъектыМетаданныхОтчетовПоРолям(Параметры, АдресРезультата) Экспорт
	
	ТаблицаРолейБезПользователей = ТаблицаРолейОтчетаИзВременногоХранилища(Параметры.АдресТаблицыБезПользователей);
	ТаблицаРолейВнеПрофилей = ТаблицаРолейОтчетаИзВременногоХранилища(Параметры.АдресТаблицыВнеПрофилей);
	
	ДлительныеОперации.СообщитьПрогресс(0, "Загрузка прав из регистра…");
	
	ОбъектыПоРолям = ПолучитьКоличествоПравПоРолямОтчета();
	ВсегоРолей = КоличествоСтрокТаблицыРолей(ТаблицаРолейБезПользователей)
		+ КоличествоСтрокТаблицыРолей(ТаблицаРолейВнеПрофилей);
	Обработано = 0;
	
	ДлительныеОперации.СообщитьПрогресс(5, "Дополнение через ПравоДоступа…");
	
	Обработано = ДополнитьОбъектыПоРолямПравоДоступаОтчета(ОбъектыПоРолям, ТаблицаРолейБезПользователей, Обработано, ВсегоРолей);
	ДополнитьОбъектыПоРолямПравоДоступаОтчета(ОбъектыПоРолям, ТаблицаРолейВнеПрофилей, Обработано, ВсегоРолей);
	
	ЗаполнитьКоличествоОбъектовОтчета(ТаблицаРолейБезПользователей, ОбъектыПоРолям);
	ЗаполнитьКоличествоОбъектовОтчета(ТаблицаРолейВнеПрофилей, ОбъектыПоРолям);
	
	ДлительныеОперации.СообщитьПрогресс(100, "Готово");
	
	Результат = Новый Структура;
	Результат.Вставить("ТаблицаРолейБезПользователей", ТаблицаРолейБезПользователей);
	Результат.Вставить("ТаблицаРолейВнеПрофилей", ТаблицаРолейВнеПрофилей);
	
	ПоместитьВоВременноеХранилище(Результат, АдресРезультата);
	
КонецПроцедуры

Функция НоваяТаблицаРолейОтчета()
	
	ТаблицаРолей = Новый ТаблицаЗначений;
	ТаблицаРолей.Колонки.Добавить("Роль");
	ТаблицаРолей.Колонки.Добавить("Синоним");
	ТаблицаРолей.Колонки.Добавить("Комментарий");
	ТаблицаРолей.Колонки.Добавить("КоличествоПрофилей");
	ТаблицаРолей.Колонки.Добавить("КоличествоПрав");
	
	Возврат ТаблицаРолей;
	
КонецФункции

Функция ТаблицаРолейОтчетаИзВременногоХранилища(Адрес)
	
	Данные = ПолучитьИзВременногоХранилища(Адрес);
	УдалитьИзВременногоХранилища(Адрес);
	
	Возврат ПривестиКТаблицеРолейОтчета(Данные);
	
КонецФункции

Функция ПривестиКТаблицеРолейОтчета(Данные)
	
	Если Данные = Неопределено Тогда
		Возврат НоваяТаблицаРолейОтчета();
	КонецЕсли;
	
	Если ТипЗнч(Данные) = Тип("ТаблицаЗначений") Тогда
		Возврат Данные;
	КонецЕсли;
	
	Результат = НоваяТаблицаРолейОтчета();
	
	Для Каждого СтрокаДанных Из Данные Цикл
		ЗаполнитьЗначенияСвойств(Результат.Добавить(), СтрокаДанных);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КоличествоСтрокТаблицыРолей(Таблица)
	
	Если Таблица = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(Таблица) = Тип("ТаблицаЗначений") Тогда
		Возврат Таблица.Количество();
	КонецЕсли;
	
	Количество = 0;
	
	Для Каждого СтрокаДанных Из Таблица Цикл
		Количество = Количество + 1;
	КонецЦикла;
	
	Возврат Количество;
	
КонецФункции

Процедура ЗаполнитьСтрокуРолиОтчета(СтрокаРоли, РольМета, ПрофилиПоРолям)
	
	СтрокаРоли.Роль = РольМета.Имя;
	СтрокаРоли.Синоним = РольМета.Синоним;
	СтрокаРоли.Комментарий = РольМета.Комментарий;
	
	КоличествоПрофилей = ПрофилиПоРолям[РольМета.Имя];
	СтрокаРоли.КоличествоПрофилей = ?(КоличествоПрофилей = Неопределено, 0, КоличествоПрофилей);
	СтрокаРоли.КоличествоПрав = 0;
	
КонецПроцедуры

Процедура ЗаполнитьКоличествоОбъектовОтчета(ТаблицаРолей, ОбъектыПоРолям)
	
	Для Каждого СтрокаРоли Из ТаблицаРолей Цикл
		КоличествоОбъектов = ОбъектыПоРолям[СтрокаРоли.Роль];
		СтрокаРоли.КоличествоПрав = ?(КоличествоОбъектов = Неопределено, 0, КоличествоОбъектов);
	КонецЦикла;
	
КонецПроцедуры

Функция ДополнитьОбъектыПоРолямПравоДоступаОтчета(ОбъектыПоРолям, ТаблицаРолей, Обработано, ВсегоРолей)
	
	Для Каждого СтрокаРоли Из ТаблицаРолей Цикл
		
		Обработано = Обработано + 1;
		
		Если ВсегоРолей > 0 И Обработано % 3 = 0 Тогда
			Процент = 5 + Окр(90 * Обработано / ВсегоРолей);
			ДлительныеОперации.СообщитьПрогресс(Процент,
				СтрШаблон("Подсчёт объектов метаданных: %1 из %2…", Обработано, ВсегоРолей));
		КонецЕсли;
		
		КоличествоИзРегистра = ОбъектыПоРолям[СтрокаРоли.Роль];
		
		Если КоличествоИзРегистра <> Неопределено И КоличествоИзРегистра > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		РольМета = Метаданные.Роли.Найти(СтрокаРоли.Роль);
		
		Если РольМета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ОбъектыПоРолям.Вставить(СтрокаРоли.Роль, ПодсчитатьОбъектыРолиПравоДоступаОтчета(РольМета));
		
	КонецЦикла;
	
	Возврат Обработано;
	
КонецФункции

Функция ПолучитьКоличествоПравПоРолямОтчета()
	
	Результат = Новый Соответствие;
	
	Если Метаданные.РегистрыСведений.Найти("ПраваРолей") = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПраваРолей.Роль.Имя КАК Роль,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПраваРолей.ОбъектМетаданных) КАК КоличествоПрав
	|ИЗ
	|	РегистрСведений.ПраваРолей КАК ПраваРолей
	|
	|СГРУППИРОВАТЬ ПО
	|	ПраваРолей.Роль.Имя";
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Роль, Выборка.КоличествоПрав);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПодсчитатьОбъектыРолиПравоДоступаОтчета(РольМета)
	
	СписокОбъектов = ПолучитьСписокОбъектовРолиПравоДоступаОтчета(РольМета);
	
	Если СписокОбъектов = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат СписокОбъектов.Количество();
	
КонецФункции

Функция ПолучитьСписокОбъектовРолиПравоДоступаОтчета(РольМета)
	
	СписокОбъектов = Новый Массив;
	УжеДобавлено = Новый Соответствие;
	
	Для Каждого ИмяКоллекции Из ИменаКоллекцийОбъектовМетаданныхОтчета() Цикл
		
		Попытка
			КоллекцияМетаданных = Метаданные[ИмяКоллекции];
		Исключение
			Продолжить;
		КонецПопытки;
		
		Для Каждого ОбъектМетаданных Из КоллекцияМетаданных Цикл
			
			Если НЕ ОбъектМетаданныхСодержитПраваРолиОтчета(ОбъектМетаданных, РольМета) Тогда
				Продолжить;
			КонецЕсли;
			
			Попытка
				ПредставлениеОбъекта = ОбъектМетаданных.ПолноеИмя();
			Исключение
				Продолжить;
			КонецПопытки;
			
			Если УжеДобавлено[ПредставлениеОбъекта] <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			УжеДобавлено.Вставить(ПредставлениеОбъекта, Истина);
			СписокОбъектов.Добавить(ПредставлениеОбъекта);
			
		КонецЦикла;
		
	КонецЦикла;
	
	СписокДляСортировки = Новый СписокЗначений;
	
	Для Каждого ПредставлениеОбъекта Из СписокОбъектов Цикл
		СписокДляСортировки.Добавить(ПредставлениеОбъекта);
	КонецЦикла;
	
	СписокДляСортировки.СортироватьПоЗначению();
	
	Результат = Новый Массив;
	
	Для Каждого ЭлементСписка Из СписокДляСортировки Цикл
		Результат.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОбъектМетаданныхСодержитПраваРолиОтчета(ОбъектМетаданных, РольМета)
	
	Попытка
		Если ПравоДоступа("Использование", ОбъектМетаданных, РольМета) Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Попытка
		Если ПравоДоступа("Чтение", ОбъектМетаданных, РольМета) Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Попытка
		Если ПравоДоступа("Просмотр", ОбъектМетаданных, РольМета) Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

