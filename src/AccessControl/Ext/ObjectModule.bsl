// Проверка актуальности версии на GitHub (releases/latest).
// Возвращает структуру: Состояние, Заголовок, Подсказка, ЭтоГиперссылка, АдресПерехода.
Функция ПолучитьСтатусПроверкиОбновления() Экспорт
	
	ТекущаяВерсия = ВерсияОбработки();
	АдресРелизов = URLСтраницыРелизов();
	
	Попытка
		ДанныеРелиза = ПолучитьПоследнийРелизСGitHub();
	Исключение
		Возврат РезультатПриСбоеПроверки(ТекущаяВерсия, АдресРелизов, ОписаниеОшибки());
	КонецПопытки;
	
	Если ДанныеРелиза = Неопределено Тогда
		Возврат РезультатПриСбоеПроверки(ТекущаяВерсия, АдресРелизов, "Сервер обновлений не ответил или вернул пустой ответ.");
	КонецЕсли;
	
	ПоследняяВерсия = НормализоватьСтрокуВерсии(ДанныеРелиза.ТегВерсии);
	АдресРелиза = ДанныеРелиза.АдресРелиза;
	
	Если НЕ ЗначениеЗаполнено(ПоследняяВерсия) Тогда
		Возврат РезультатПриСбоеПроверки(ТекущаяВерсия, АдресРелизов, "Не удалось определить номер последней версии в ответе GitHub.");
	КонецЕсли;
	
	Сравнение = СравнитьВерсии(ТекущаяВерсия, ПоследняяВерсия);
	АдресПерехода = ?(ЗначениеЗаполнено(АдресРелиза), АдресРелиза, АдресРелизов);
	
	Если Сравнение = 0 Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Состояние", "Актуальная");
		Результат.Вставить("Заголовок", "Актуальная версия");
		Результат.Вставить("Подсказка", "Установлена последняя опубликованная версия на GitHub (" + ПоследняяВерсия + ")."
			+ Символы.ПС + "Страница релизов: " + АдресРелизов);
		Результат.Вставить("ЭтоГиперссылка", Ложь);
		Результат.Вставить("АдресПерехода", АдресРелизов);
		
	ИначеЕсли Сравнение < 0 Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Состояние", "ДоступноОбновление");
		Результат.Вставить("Заголовок", "Доступно обновление (" + ПоследняяВерсия + ")");
		Результат.Вставить("Подсказка", "Ваша версия: " + ТекущаяВерсия + ", на GitHub опубликована " + ПоследняяВерсия + "."
			+ Символы.ПС + "Нажмите, чтобы открыть страницу релиза.");
		Результат.Вставить("ЭтоГиперссылка", Истина);
		Результат.Вставить("АдресПерехода", АдресПерехода);
		
	Иначе
		
		// Локальная сборка новее последнего релиза на GitHub (например, 4.6 при релизе 4.5).
		Результат = Новый Структура;
		Результат.Вставить("Состояние", "НовееРелиза");
		Результат.Вставить("Заголовок", "на GitHub: " + ПоследняяВерсия);
		Результат.Вставить("Подсказка", "Ваша версия: " + ТекущаяВерсия + "."
			+ " Последний опубликованный релиз на GitHub: " + ПоследняяВерсия + "."
			+ Символы.ПС + "Нажмите, чтобы открыть страницу релизов.");
		Результат.Вставить("ЭтоГиперссылка", Истина);
		Результат.Вставить("АдресПерехода", АдресПерехода);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

