Функция ПолучитьТипыОшибок() 
	
	ЗначениеКонстанты = Неопределено;
	
	Попытка
		ЗначениеКонстанты = Константы.УД_ТипОшибокДляУведомленийОбОшибках_tg.Получить();
	Исключение
		ЗначениеКонстанты = Неопределено;
	КонецПопытки;
	
	Если ЗначениеКонстанты = Неопределено Тогда
		ПометкиТаблицыУровней = Новый Структура("Первая, Вторая", Ложь, Ложь);
	Иначе
		ПометкиТаблицыУровней = Новый Структура("Первая, Вторая");
		
		РазделеннаяСтрока = СтрРазделить(ЗначениеКонстанты, ";");
		
		ПометкиТаблицыУровней.Первая = ?(РазделеннаяСтрока.Количество() > 0 И РазделеннаяСтрока[0] = "Истина", Истина, Ложь);
		ПометкиТаблицыУровней.Вторая = ?(РазделеннаяСтрока.Количество() > 1 И РазделеннаяСтрока[1] = "Истина", Истина, Ложь);
	КонецЕсли;
	
	Возврат ПометкиТаблицыУровней;
	
КонецФункции

Функция СоздатьПодложкуДляЖурнала(Колонки)
	
	масКолонок = СтрРазделить(Колонки, ",");
	
	Таблица = Новый ТаблицаЗначений;
	
	Для Каждого Колонка Из масКолонок Цикл
		
		Если Колонка = "Данные" Или Колонка = "Метаданные" Или Колонка = "ПредставлениеМетаданных" Тогда
			Продолжить;
		КонецЕслИ;
		
		Если Колонка = "Дата" Тогда
			ТипКолонки = ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя);
		Иначе
			ТипКолонки = ОбщегоНазначения.ОписаниеТипаСтрока(500);
		КонецЕсли;
		
		Таблица.Колонки.Добавить(Колонка, ТипКолонки);
	КонецЦикла;
	
	Возврат Таблица;
	
КонецФункции

Функция ПолучитьТекущегоПользователя(ПользовательСтроки) Экспорт
	
	ИмяПользователяСтрокой = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Новый УникальныйИдентификатор(ПользовательСтроки)).ПолноеИмя;
	Возврат Справочники.Пользователи.НайтиПоНаименованию(ИмяПользователяСтрокой);
	
КонецФункции

Функция ОбъектУжеИзвестен(СтруктураМетаданных, КлючПользователя)
	
	ОбъектУжеЕсть = Ложь;
	
	Для Каждого Мета Из КлючПользователя Цикл		
		Если Мета.ТипМетаданного = СтруктураМетаданных.ТипМетаданного И Мета.ИмяМетаданного = СтруктураМетаданных.ИмяМетаданного Тогда			
			ОбъектУжеЕсть = Истина;
			Прервать;			
		КонецЕсли;		
	КонецЦикла;		
	
	Возврат ОбъектУжеЕсть;
	
КонецФункции

Функция ПользовательВключенВГруппуДоступа(ГруппаДоступа, Пользователь)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппаДоступа", ГруппаДоступа);
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИСТИНА КАК ЗначениеИстина
	|ИЗ
	|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	|ГДЕ
	|	ГруппыДоступаПользователи.Ссылка = &ГруппаДоступа
	|	И ГруппыДоступаПользователи.Пользователь = &Пользователь";
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

Функция РазрешеноИзменениеСоставаПользователейГруппы(ГруппаДоступа)
	
	Если ПользовательИБПолноправный Тогда
		Возврат Истина;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппаДоступа",              ГруппаДоступа);
	Запрос.УстановитьПараметр("АвторизованныйПользователь", Пользователи.АвторизованныйПользователь());
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЗначениеИстина
	|ИЗ
	|	Справочник.ГруппыДоступа КАК ГруппыДоступа
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СоставыГруппПользователей КАК СоставыГруппПользователей
	|		ПО (СоставыГруппПользователей.Пользователь = &АвторизованныйПользователь)
	|			И (СоставыГруппПользователей.ГруппаПользователей = ГруппыДоступа.Ответственный)
	|			И (ГруппыДоступа.Ссылка = &ГруппаДоступа)";
	
	Возврат НЕ Запрос.Выполнить().Пустой();
	
КонецФункции

