&НаКлиенте
Процедура УпрощенныйРежимПриИзменении(Элемент)
	
	СтруктураПрав = Новый Структура("СписокПрав_Документы, СписокПрав_Справочники, СписокПрав_РегистрыСведений, СписокПрав_РегистрыНакопления, СписокПрав_РегистрыБухгалтерии, СписокПрав_Константы, СписокПрав_ЖурналыДокументов, СписокПрав_ПланыВидовХарактеристик, СписокПрав_ПланыСчетов, СписокПрав_ПланыОбмена, СписокПрав_БизнесПроцессы, СписокПрав_Задачи");
	
	Для Каждого ПравоОбъекта Из СтруктураПрав Цикл
		
		Для Каждого Право Из ЭтотОбъект[ПравоОбъекта.Ключ] Цикл
			Право.Пометка = ?(УпрощенныйРежим, ?(Право.Значение = "Чтение" ИЛИ Право.Значение = "Просмотр", УпрощенныйРежим, НЕ УпрощенныйРежим), НЕ УпрощенныйРежим);
		КонецЦикла;
		
		ОбновитьКолонкиТаблицы(ПравоОбъекта.Ключ);
		
	КонецЦикла;  
	
	Элементы.ГруппаНастройки.Видимость = НЕ УпрощенныйРежим И Элементы.ГруппаТекстЗапроса.Видимость;
	
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
		ВыполнитьАнализНаСервере(ТекстЗапроса);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПользовательПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(ТекстЗапроса) Тогда
		ВыполнитьАнализНаСервере(ТекстЗапроса);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьВНовомОкне(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ТекстЗапроса", ТекстЗапроса);
	ПараметрыОткрытия.Вставить("УпрощенныйРежим", УпрощенныйРежим);
	
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаПарсерЗапроса", ПараметрыОткрытия, ЭтотОбъект); 
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти
