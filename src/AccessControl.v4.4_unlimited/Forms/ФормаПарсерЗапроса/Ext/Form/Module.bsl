		КолонкаПометки.ПутьКДанным = ИмяСписка + ".Пометка";
  
		КолонкаЗначения = Элементы.Добавить(ИмяСписка + "Значение", Тип("ПолеФормы"), ТаблицаСписка);
		КолонкаЗначения.Вид = ВидПоляФормы.ПолеВвода;
		КолонкаЗначения.ПутьКДанным = ИмяСписка + ".Значение";

		КолонкаПредставления = Элементы.Добавить(ИмяСписка + "Представление", Тип("ПолеФормы"), ТаблицаСписка);
		КолонкаПредставления.Вид = ВидПоляФормы.ПолеВвода;
		КолонкаПредставления.ПутьКДанным = ИмяСписка + ".Представление";
		
