  
#Область ОбработчикиСобытий   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ТекущаяДата() >= Дата('2035.07.15 00:00:01') ИЛИ ТекущаяДатаСеанса() >= Дата('2035.07.15 00:00:01') Тогда
		Сообщить(НСтр("ru = 'Закончился срок действия пробного периода. Если вы заинтересованы в дальнейшем использовании продукта, 
		|обратитесь по адресу эл. почты ""denqiqtp@gmail.com"".
		|https://github.com/VorozhbitDM/Access-control-1C'"));
		
		Для Каждого Эл Из Элементы Цикл
			
			Если ТипЗнч(Эл) = Тип("ПолеФормы") Тогда
				Эл.ТолькоПросмотр = Истина;
			ИначеЕсли ТипЗнч(Эл) = Тип("КнопкаФормы") Тогда
				Эл.Доступность = Ложь;
			КонецЕсли;
			
		КонецЦикла;
		Отказ = Истина; 
		Возврат;
	КонецЕсли;
	
	УпрощенныйРежим = Истина;
	
	Если Параметры.Свойство("Пользователь") Тогда
		Пользователь = ?(Параметры.Пользователь = Справочники.Пользователи.ПустаяСсылка(), ПараметрыСеанса.АвторизованныйПользователь, Параметры.Пользователь);
	КонецЕсли;
	
	Если Параметры.Свойство("УпрощенныйРежим") И ЗначениеЗаполнено(Параметры.ТекстЗапроса) Тогда
		УпрощенныйРежим = Параметры.УпрощенныйРежим; 
		ТекстЗапроса = Параметры.ТекстЗапроса;
	КонецЕсли;
	
	ДобавитьСпискиПрав();
	
	ЗаполнитьСпискиПрав();
	
	СоздатьТаблицыЗначений();
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УпрощенныйРежимПриИзменении(Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура СписокПравПриПриИзмененииНаСервере(ИмяСпискаПрав)
	ОбновитьКолонкиТаблицы(ИмяСпискаПрав);
КонецПроцедуры

&НаКлиенте
Процедура СписокПравПриИзменении(Элемент)
	СписокПравПриПриИзмененииНаСервере(Элемент.Имя);
КонецПроцедуры

#КонецОбласти     

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыполнитьАнализ(Команда)
	
	Если ТекстЗапроса = "" Тогда
		Возврат;
	КонецЕсли;   
	
	ВыполнитьАнализНаСервере(ТекстЗапроса);

КонецПроцедуры 

&НаКлиенте
Процедура ОчиститьТекстЗапроса(Команда)
	
	ТекстЗапроса = "";
	
КонецПроцедуры

&НаКлиенте
Процедура РежимПросмотра(Команда)
	
	ЭлементыСкрыты = БиблиотекаКартинок.ПоказатьПароль;
	ЭлементыВидны =  БиблиотекаКартинок.СкрытьПароль;
	
	Элементы.РежимПросмотра.Картинка = ?(Элементы.РежимПросмотра.Картинка = ЭлементыВидны, ЭлементыСкрыты, ЭлементыВидны);
	Элементы.ГруппаТекстЗапроса.Видимость = ?(Элементы.РежимПросмотра.Картинка = ЭлементыВидны, Ложь, Истина);
	Элементы.ГруппаНастройки.Видимость = Элементы.ГруппаТекстЗапроса.Видимость И НЕ УпрощенныйРежим;
	
КонецПроцедуры     

&НаКлиенте
Процедура ОткрытьКонструкторЗапроса(Команда)
	
	КонструкторЗапроса = Новый КонструкторЗапроса(СокрЛП(ТекстЗапроса));
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияКонструктораЗапроса", ЭтотОбъект);
	КонструкторЗапроса.Показать(ОписаниеОповещения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ВыполнитьАнализНаСервере(РазбираемыйТекстЗапроса)
	
	ПоляВыбора.Очистить();
	ТипыОбъектов.Очистить();
	ЭтотОбъект["ПраваДокументы"].Очистить(); 
	
	СтруктураИменТаблиц = Новый Структура("ПраваБизнесПроцессы, ПраваВнешниеИсточникиДанных, ПраваДокументы, ПраваЖурналыДокументов, ПраваЗадачи, ПраваКонстанты, ПраваПланыВидовРасчета, ПраваПланыВидовХарактеристик, ПраваПланыОбмена, ПраваПланыСчетов, ПраваРегистрыБухгалтерии, ПраваРегистрыНакопления, ПраваРегистрыРасчета, ПраваРегистрыСведений, ПраваСправочники");
	Для Каждого ИмяТаблицы Из СтруктураИменТаблиц Цикл
		ЭтотОбъект[ИмяТаблицы.Ключ].Очистить();
	КонецЦикла;
		
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(РазбираемыйТекстЗапроса);
	
	Для Каждого Запрос Из СхемаЗапроса.ПакетЗапросов Цикл
		
		Для Каждого Оператор Из Запрос.Операторы Цикл
			
			// Заполняем типы выбираемых полей
			Для Каждого ВыбираемоеПоле Из Оператор.ВыбираемыеПоля Цикл
				
				Если СтрНайти(ВыбираемоеПоле, " ")
					ИЛИ СтрНайти(ВыбираемоеПоле, Символы.ПС)
					ИЛИ СтрНайти(ВыбираемоеПоле, Символы.Таб)
					ИЛИ СтрНайти(ВыбираемоеПоле, "(")
					ИЛИ СтрНайти(ВыбираемоеПоле, ")")
					ИЛИ СтрНайти(ВыбираемоеПоле, "-")
					Тогда
					
					ЧастиПоляСУсловием = ПолучитьЧастиПоляСУсловием(ВыбираемоеПоле);
					
					МассивПолей = Новый Массив;
					
					Для Каждого ЧастьПоляСУсловием Из ЧастиПоляСУсловием Цикл
						
						Если СтрРазделить(ЧастьПоляСУсловием, ".").Количество() > 1 Тогда
							ЗаменитьИточникВыбираемогоПоля(ЧастьПоляСУсловием, Оператор.Источники); 
							ДобавитьПолеВСписок(ЧастьПоляСУсловием)
						КонецЕсли;
						
					КонецЦикла;
					
				Иначе
					
					Если СтрРазделить(ВыбираемоеПоле, ".", Ложь).Количество() > 1 Тогда 
						ЗаменитьИточникВыбираемогоПоля(ВыбираемоеПоле, Оператор.Источники);
						ДобавитьПолеВСписок(ВыбираемоеПоле)
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ПоляВыбора.СортироватьПоПредставлению();
	
	Для Каждого ПолеВыбора Из ПоляВыбора Цикл
		РазобратьСтроку(ПолеВыбора.Значение);
	КонецЦикла;
	
	ОбновитьВидимостьЭлементовФормы();
	
КонецПроцедуры
                                                            
&НаСервере                                                                                               
Функция ПолучитьЧастиПоляСУсловием(ВыбираемоеПоле)
	
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, " ", "#");
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, Символы.Таб, "#");
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, Символы.ПС, "#");
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "(", "#");
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, ")", "#");
	ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "-", "#");
	
	Если НЕ СтрНайти(ВыбираемоеПоле, "Справочник.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "Документ.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "РегистрНакопления.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "РегистрСведений.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "РегистрБухгалтерии.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "РегистрРасчета.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "Перечисление.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "Константа.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "Задача.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "ПланОбмена.") = 0
		ИЛИ НЕ СтрНайти(ВыбираемоеПоле, "КритерийОтбора.") = 0
		Тогда
		
		ПозицияНачала = Неопределено;
		
		Если НЕ СтрНайти(ВыбираемоеПоле, "Справочник.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "Справочник.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "Документ.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "Документ.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "РегистрНакопления.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "РегистрНакопления.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "РегистрСведений.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "РегистрСведений.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "РегистрБухгалтерии.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "РегистрБухгалтерии.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "РегистрРасчета.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "РегистрРасчета.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "Перечисление.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "Перечисление.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "Константа.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "Константа.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "Задача.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "Задача.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "ПланОбмена.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "ПланОбмена.");
		ИначеЕсли НЕ СтрНайти(ВыбираемоеПоле, "КритерийОтбора.") = 0 Тогда
			ПозицияНачала = СтрНайти(ВыбираемоеПоле, "КритерийОтбора.");
		КонецЕсли;
		
		Если ПозицияНачала = Неопределено Тогда
			Возврат СтрРазделить(ВыбираемоеПоле, "#", Ложь);	
		КонецЕсли;
		
		ПозицияНачала = ПозицияНачала - 1;
		
		Если Сред(ВыбираемоеПоле, ПозицияНачала, 1) = " "
			ИЛИ Сред(ВыбираемоеПоле, ПозицияНачала, 1) = "#"
			ИЛИ Сред(ВыбираемоеПоле, ПозицияНачала, 1) = Символы.Таб
			ИЛИ Сред(ВыбираемоеПоле, ПозицияНачала, 1) = Символы.ПС 
			Тогда
			
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "Справочник.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "Документ.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "РегистрНакопления.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "РегистрСведений.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "РегистрБухгалтерии.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "РегистрРасчета.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "Перечисление.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "Константа.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "Задача.", "#");
			ВыбираемоеПоле = СтрЗаменить(ВыбираемоеПоле, "КритерийОтбора.", "#");
			
			ПолучитьЧастиПоляСУсловием(ВыбираемоеПоле);
			
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат СтрРазделить(ВыбираемоеПоле, "#", Ложь);
	
КонецФункции

&НаСервере
Процедура ЗаменитьИточникВыбираемогоПоля(ВыбираемоеПоле, Источники)
	
	ЧастиВыбираемогоПоля = СтрРазделить(ВыбираемоеПоле, ".", Ложь);
	
	Если ЧастиВыбираемогоПоля.Количество() < 2 Тогда // Полагаем, что это параметр или примитивный тип
		Возврат;
	КонецЕсли;
	
	НайденныйИсточник = Источники.НайтиПоПсевдониму(ЧастиВыбираемогоПоля[0]);
	Если НайденныйИсточник = Неопределено Тогда
		Сообщить("Не найден источник значения: " + ВыбираемоеПоле);
		Возврат;
	КонецЕсли;
	
	Источник = НайденныйИсточник.Источник;
	Если ТипЗнч(Источник) = Тип("ВложенныйЗапросСхемыЗапроса") Тогда
		ТекстВложенногоЗапроса = Источник.Запрос.ПолучитьТекстЗапроса();
		ВыполнитьАнализНаСервере(ТекстВложенногоЗапроса);
	Иначе
		ЧастиВыбираемогоПоля[0] = Источник.ИмяТаблицы;
	КонецЕсли;
	
	ВыбираемоеПоле = СтрСоединить(ЧастиВыбираемогоПоля, ".");
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьПолеВСписок(Поле)
	
	Поле = УстановитьКорректноеИмяБазовогоТипа(Поле);
	
	Если ПоляВыбора.НайтиПоЗначению(Поле) = Неопределено Тогда
		ПоляВыбора.Добавить(Поле);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция УстановитьКорректноеИмяБазовогоТипа(Поле)

	ЧастиСтроки = СтрРазделить(Поле, ".");
	
	ТипИсточника = ЧастиСтроки[0];
	
	Если ТипИсточника = "КритерийОтбора" Тогда
		ТипИсточника = "КритерииОтбора";
	ИначеЕсли ТипИсточника = "ПланОбмена" Тогда
		ТипИсточника = "ПланыОбмена";
	ИначеЕсли ТипИсточника = "Константа" Тогда
		ТипИсточника = "Константы";
	ИначеЕсли ТипИсточника = "Справочник" Тогда
		ТипИсточника = "Справочники";
	ИначеЕсли ТипИсточника = "Документ" Тогда
		ТипИсточника = "Документы";
	ИначеЕсли ТипИсточника = "ЖурналДокументов" Тогда
		ТипИсточника = "ЖурналыДокументов";
	ИначеЕсли ТипИсточника = "Перечисление" Тогда
		ТипИсточника = "Перечисления";
	ИначеЕсли ТипИсточника = "ПланВидовХарактеристик" Тогда
		ТипИсточника = "ПланыВидовХарактеристик";
	ИначеЕсли ТипИсточника = "РегистрСведений" Тогда
		ТипИсточника = "РегистрыСведений";
	ИначеЕсли ТипИсточника = "РегистрНакопления" Тогда
		ТипИсточника = "РегистрыНакопления";
	ИначеЕсли ТипИсточника = "БизнесПроцесс" Тогда
		ТипИсточника = "БизнесПроцессы";
	ИначеЕсли ТипИсточника = "РегистрБухгалтерии" Тогда
		ТипИсточника = "РегистрыБухгалтерии";
	ИначеЕсли ТипИсточника = "Задача" Тогда
		ТипИсточника = "Задачи";
	ИначеЕсли ТипИсточника = "ВнешнийИсточникДанных" Тогда
		ТипИсточника = "сфпВнешнийИсточникДанныхИсторииЗвонков";
	ИначеЕсли ТипИсточника = "ПланСчетов" Тогда
		ТипИсточника = "ПланыСчетов";
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не найдет тип источника: " + ТипИсточника;
		Сообщение.Сообщить();
	КонецЕсли;
	
	ЧастиСтроки[0] = ТипИсточника;
	
	Возврат СтрСоединить(ЧастиСтроки, ".");
	
КонецФункции

&НаСервере
Процедура РазобратьСтроку(Строка)

	ЧастиСтроки = СтрРазделить(Строка, ".");
	
	БазовыйТипМетаданных = ЧастиСтроки[0];
	ИмяОбъекта = ЧастиСтроки[1];
	
	Попытка
		ОбъектМетаданных = Метаданные[БазовыйТипМетаданных][ИмяОбъекта];
	Исключение
		Сообщить("Пропуск метаданных: " + БазовыйТипМетаданных + ". Объект: " + ИмяОбъекта);
		Возврат;
	КонецПопытки;

	ЧастиСтроки.Удалить(0);
	ЧастиСтроки.Удалить(0); 
	
	Индекс = 0;
	
	//Если БазовыйТипМетаданных = "РегистрыСведений"
	//	ИЛИ БазовыйТипМетаданных = "РегистрыНакопления"
	//	ИЛИ БазовыйТипМетаданных = "РегистрыБухгалтерии"
	//	ИЛИ БазовыйТипМетаданных = "РегистрыРасчета"
	//	Тогда
	//	
	//	Для Каждого Тип Из ОбъектМетаданных.СтандартныеРеквизиты.Регистратор.Тип.Типы() Цикл 
	//		ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс, ЧастиСтроки);	
	//	КонецЦикла;
	//	
	//КонецЕсли;
	
	Пока Индекс <= ЧастиСтроки.Количество() - 1 Цикл
		
		ПолучитьОбъектыМетаданных(ОбъектМетаданных, Индекс, ЧастиСтроки);
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Процедура ПолучитьОбъектыМетаданных(ОбъектМетаданных, Индекс, ЧастиСтроки)
	
	Если ОбъектМетаданных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	БазовыйТипОбъекта = ОбщегоНазначения.ИмяБазовогоТипаПоОбъектуМетаданных(ОбъектМетаданных);
	
	Если БазовыйТипОбъекта = "Перечисления" Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЭтотОбъект["Права" + БазовыйТипОбъекта].НайтиСтроки(Новый Структура("ПолноеИмя", ОбъектМетаданных.ПолноеИмя())).Количество() Тогда
		
		НС = ЭтотОбъект["Права" + БазовыйТипОбъекта].Добавить();
		НС.ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
		НС.ИмяОбъекта = ОбъектМетаданных.Синоним;
		
		Для Каждого Право Из ЭтотОбъект["СписокПрав_" + БазовыйТипОбъекта] Цикл
			
			Если НЕ Право.Пометка Тогда
				Продолжить;
			КонецЕсли;
			
			НС[Право.Значение] = ПроверитьРолиПользователя(ОбъектМетаданных, Право.Значение);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если Индекс > ЧастиСтроки.Количество() - 1 Тогда
		Возврат;
	КонецЕсли;
	
	//////////////////////////////////////////////////////////////////////////////////
	Если БазовыйТипОбъекта = "Константы" Тогда  
		
		Для Каждого Тип Из ОбъектМетаданных.Тип.Типы() Цикл 
			ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);
		КонецЦикла;
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "КритерииОтбора" Тогда // Состав  
		
		НайденныйОбъект = Неопределено;
		
		КоллекцияЗначенийСвойстваОбъектаМетаданных = ОбъектМетаданных.Состав;
		
		Для Каждого ЗначениеСвойстваОбъектаМетаданных Из КоллекцияЗначенийСвойстваОбъектаМетаданных Цикл 
			
			Для Каждого Тип Из ЗначениеСвойстваОбъектаМетаданных.Тип.Типы() Цикл 
				ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);
			КонецЦикла;
			
		КонецЦикла;;                      
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "РегистрыНакопления" // Измерения, Ресурсы, Реквизиты 
		ИЛИ БазовыйТипОбъекта = "РегистрыСведений"
		ИЛИ БазовыйТипОбъекта = "РегистрыБухгалтерии"
		ИЛИ БазовыйТипОбъекта = "РегистрыРасчета"
		Тогда
		
		НайденныйОбъект = Неопределено;
		
		МассивИменКоллекций = Новый Массив;
		МассивИменКоллекций.Добавить("Измерения");
		МассивИменКоллекций.Добавить("Ресурсы");
		МассивИменКоллекций.Добавить("Реквизиты");
		
		Если ЧастиСтроки[Индекс] = "Регистратор" Тогда 
			Для Каждого Тип Из ОбъектМетаданных.СтандартныеРеквизиты.Регистратор.Тип.Типы() Цикл 
				ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
			КонецЦикла;
		КонецЕсли;
		
		Для Каждого ИмяКоллекции Из МассивИменКоллекций Цикл 
			
			ЭтоВиртуальнаяТаблица = Ложь;
			ИмяВиртуальнойТаблицы = "";
			
			Если ЧастиСтроки[Индекс] = "ОстаткиИОбороты"
				ИЛИ ЧастиСтроки[Индекс] = "Остатки" 
				ИЛИ ЧастиСтроки[Индекс] = "Обороты" 
				ИЛИ ЧастиСтроки[Индекс] = "СрезПервых" 
				ИЛИ ЧастиСтроки[Индекс] = "СрезПоследних" 
				ИЛИ ЧастиСтроки[Индекс] = "ДвиженияССубконто" 
				ИЛИ ЧастиСтроки[Индекс] = "Обороты" 
				ИЛИ ЧастиСтроки[Индекс] = "ОборотыДтКт" 
				ИЛИ ЧастиСтроки[Индекс] = "Субконто" 
				Тогда
				
				ЭтоВиртуальнаяТаблица = Истина;
				ИмяВиртуальнойТаблицы = ЧастиСтроки[Индекс];
				
				Продолжить;
				
			КонецЕсли;
			
			НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
			
			Если НЕ НайденныйОбъект = Неопределено Тогда
				
				Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
					ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "Задачи" Тогда // Измерения, Ресурсы, Реквизиты  
		
		НайденныйОбъект = Неопределено;
		
		МассивИменКоллекций = Новый Массив;
		МассивИменКоллекций.Добавить("РеквизитыАдресации");
		МассивИменКоллекций.Добавить("Реквизиты");
		МассивИменКоллекций.Добавить("ТабличныеЧасти");
		
		Для Каждого ИмяКоллекции Из МассивИменКоллекций Цикл 
			
			Если ИмяКоллекции = "ТабличныеЧасти" Тогда
				НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
				Если НЕ НайденныйОбъект = Неопределено Тогда
					
					Если НЕ Индекс < ЧастиСтроки.Количество() - 1 Тогда
						Продолжить;
					КонецЕсли;
					
					НайденныйОбъект = НайденныйОбъект.Реквизиты.Найти(ЧастиСтроки[Индекс + 1]);
					
					Если НЕ НайденныйОбъект = Неопределено Тогда
						
						Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
							ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 2, ЧастиСтроки);	
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЕсли;
			Иначе
				НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
			КонецЕсли;
			
			Если НЕ НайденныйОбъект = Неопределено Тогда
				
				Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
					ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;                      
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "ВнешниеИсточникиДанных" Тогда // Измерения, Ресурсы, Реквизиты  
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "Справочники"
		ИЛИ БазовыйТипОбъекта = "Документы"   
		ИЛИ БазовыйТипОбъекта = "ПланыОбмена"   
		ИЛИ БазовыйТипОбъекта = "БизнесПроцессы"   
		ИЛИ БазовыйТипОбъекта = "ЖурналыДокументов"   
		ИЛИ БазовыйТипОбъекта = "ПланыВидовХарактеристик" Тогда 
		
		НайденныйОбъект = Неопределено;
		
		МассивИменКоллекций = Новый Массив;
		МассивИменКоллекций.Добавить("Реквизиты");
		МассивИменКоллекций.Добавить("ТабличныеЧасти");
		
		Если БазовыйТипОбъекта = "ЖурналыДокументов" Тогда 
			МассивИменКоллекций = Новый Массив;
			МассивИменКоллекций.Добавить("Графы");
		КонецЕсли;
		
		Для Каждого ИмяКоллекции Из МассивИменКоллекций Цикл 
			
			Если ИмяКоллекции = "ТабличныеЧасти" Тогда
				НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
				Если НЕ НайденныйОбъект = Неопределено Тогда
					
					Если НЕ Индекс < ЧастиСтроки.Количество() - 1 Тогда
						Продолжить;
					КонецЕсли;
					
					НайденныйОбъект = НайденныйОбъект.Реквизиты.Найти(ЧастиСтроки[Индекс + 1]);
					
					Если НЕ НайденныйОбъект = Неопределено Тогда
						
						Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
							ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 2, ЧастиСтроки);	
						КонецЦикла;
						
					КонецЕсли;
					
				КонецЕсли;
			Иначе
				НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
			КонецЕсли;
			
			Если НЕ НайденныйОбъект = Неопределено Тогда
				
				Если БазовыйТипОбъекта = "ЖурналыДокументов" Тогда 
					
					Для Каждого Ссылка Из НайденныйОбъект.Ссылки Цикл
						
						Для Каждого Тип Из Ссылка.Тип.Типы() Цикл 
							ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
						КонецЦикла;
						
					КонецЦикла;
					
				Иначе
					
					Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
						ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;                     
		
		//////////////////////////////////////////////////////////////////////////////////
	ИначеЕсли БазовыйТипОбъекта = "ПланыСчетов" Тогда // Реквизиты, ПризнакиУчета, ПризнакиУчетаСубконто   
		
		НайденныйОбъект = Неопределено;
		
		МассивИменКоллекций = Новый Массив;
		МассивИменКоллекций.Добавить("Реквизиты");
		МассивИменКоллекций.Добавить("ПризнакиУчета");
		МассивИменКоллекций.Добавить("ПризнакиУчетаСубконто");
		
		Для Каждого Тип Из ОбъектМетаданных.ВидыСубконто.Тип.Типы() Цикл 
			ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
		КонецЦикла;
		
		Для Каждого ИмяКоллекции Из МассивИменКоллекций Цикл 
			
			НайденныйОбъект = ОбъектМетаданных[ИмяКоллекции].Найти(ЧастиСтроки[Индекс]);
			
			Если НЕ НайденныйОбъект = Неопределено Тогда
				
				Для Каждого Тип Из НайденныйОбъект.Тип.Типы() Цикл 
					ПолучитьОбъектыМетаданных(Метаданные.НайтиПоТипу(Тип), Индекс + 1, ЧастиСтроки);	
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;                      
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСПравами

&НаСервере
Функция ПроверитьРолиПользователя(ОбъектМета, Право)
	
	МассивВсехРолей = Новый Массив;
	
	Для Каждого МетаРоль Из Метаданные.Роли Цикл
		МассивВсехРолей.Добавить(МетаРоль);
	КонецЦикла;
	
	МассивРолейНаПроверку = Новый Массив;
	
	Для Каждого МетаРоль Из МассивВсехРолей Цикл
		
		Если ПравоДоступа(Право, ОбъектМета, МетаРоль) Тогда	
			МассивРолейНаПроверку.Добавить(МетаРоль);	
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивРолейНаПроверку.Количество() Тогда
		
		Для Каждого СтрокаРоли Из МассивРолейНаПроверку Цикл
			
			ПризнакНаличияРоли = ЕстьРоль(СтрокаРоли.Имя, Пользователь);
			
			Если ПризнакНаличияРоли Тогда
				Возврат Истина;
			Иначе
				ПризнакНаличияРоли = ЕстьРольПользователя(СтрокаРоли.Имя, Пользователь);
			КонецЕсли; 
			
			Если ПризнакНаличияРоли Тогда
				Возврат Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		Возврат Ложь;
		
	КонецЕсли;
		
КонецФункции    
        
&НаСервере
Функция ЕстьРоль(ИмяРоли, Пользователь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК Поле1,
	|	ГруппыДоступаПользователи.Ссылка КАК Ссылка,
	|	ГруппыДоступаПользователи.Пользователь КАК Пользователь
	|ИЗ
	|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступаРоли.Ссылка
	|ГДЕ
	|	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	|	И ГруппыДоступаПользователи.Пользователь В
	|			(ВЫБРАТЬ
	|				ГруппыПользователейСостав.Ссылка КАК ГруппаПользователей
	|			ИЗ
	|				Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|			ГДЕ
	|				ГруппыПользователейСостав.Пользователь = &Пользователь)";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Роль", ИмяРоли);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ?(РезультатЗапроса.Пустой(), Ложь, Истина);
	
КонецФункции

&НаСервере
Функция ЕстьРольПользователя(ИмяРоли, Пользователь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	1 КАК Поле1
	|ИЗ
	|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступаРоли.Ссылка
	|ГДЕ
	|	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	|	И ГруппыДоступаПользователи.Пользователь = &Пользователь
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1
	|ИЗ
	|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступаРоли.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейСостав
	|		ПО ГруппыДоступаПользователи.Пользователь = ГруппыПользователейСостав.Пользователь
	|ГДЕ
	|	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	|	И ГруппыПользователейСостав.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Роль", ИмяРоли);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ?(РезультатЗапроса.Пустой(), Ложь, Истина);
	
КонецФункции 

#КонецОбласти

#Область ОбработчикиЗаполненияФормы

&НаСервере
Процедура ДобавитьСпискиПрав()
	
	СписокБазовыхТипов = ПолучитьСписокБазовыхТипов();
	
	ДобавляемыРеквизиты = Новый Массив;
	
	Для Каждого ИмяСписка Из СписокБазовыхТипов Цикл
		
		ИмяСписка = "СписокПрав_" + ИмяСписка;
		
		ДобавляемыРеквизиты.Добавить(Новый РеквизитФормы(ИмяСписка, Новый ОписаниеТипов("СписокЗначений")));
		
	КонецЦикла;
	
	ИзменитьРеквизиты(ДобавляемыРеквизиты);
	
	Для Каждого ИмяБазовогоТипа Из СписокБазовыхТипов Цикл
		
		ИмяСписка = "СписокПрав_" + ИмяБазовогоТипа;
		
		Группа = ЭтаФорма.Элементы.Добавить("Группа" + ИмяСписка, Тип("ГруппаФормы"), Элементы.ГруппаНастройки);
		Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок = ИмяБазовогоТипа;
		Группа.Отображение = ОтображениеОбычнойГруппы.ОбычноеВыделение;
		Группа.ОтображатьЗаголовок = Истина; 
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		Группа.РастягиватьПоГоризонтали = Истина;
		Группа.ОтображениеУправления = ОтображениеУправленияОбычнойГруппы.Картинка;
		Группа.Поведение = ПоведениеОбычнойГруппы.Свертываемая;
		Группа.Скрыть();

		ТаблицаСписка = Элементы.Добавить(ИмяСписка, Тип("ТаблицаФормы"), Группа);
