&НаСервере
Функция ПолучитьКартинкуМета(Имя)
	
	СоответствиеКартинок = Новый Соответствие; 
	 
	СтрокаИмен = "Справочники,Документы,РегистрыСведений,РегистрыНакопления,РегистрыБухгалтерии,РегистрыРасчета,Константы," +
		"ЖурналыДокументов,ПланыВидовХарактеристик,ПланыСчетов,ПланыВидовРасчета,БизнесПроцессы," +
		"Задачи,ВнешниеИсточникиДанных,ПланыОбмена";
	СтрокаКартинок = "Справочник,Документ,РегистрСведений,РегистрНакопления,РегистрБухгалтерии,РегистрРасчета,Константа," +
		"ЖурналДокументов,ПланВидовХарактеристик,ПланСчетов,ПланВидовРасчета,БизнесПроцесс," +
		"Задача,ВнешнийИсточникДанных,ПланОбмена"; 
	
	МассивИмен = СтрРазделить(СтрокаИмен, ",");
	МассивКартинок = СтрРазделить(СтрокаКартинок, ",");
	
	Итер = 0;
	Пока Итер < МассивИмен.Количество() Цикл
		СоответствиеКартинок.Вставить(МассивИмен[Итер], МассивКартинок[Итер]); 
		Итер = Итер + 1;
	КонецЦикла;
	
	Возврат СоответствиеКартинок.Получить(Имя);
	
КонецФункции

&НаСервере
Процедура СоздатьТаблицыЗначений()
	
	СписокБазовыхТипов = ПолучитьСписокБазовыхТипов();
	
	ДобавляемыРеквизиты = Новый Массив;
	
	Для Каждого Имя Из СписокБазовыхТипов Цикл
		
		ИмяТаблицы = "Права" + Имя;
		ИмяКолонки = "ПолноеИмя";
		ИмяМетаОбъекта = "ИмяОбъекта";
		
		ДобавляемыРеквизиты.Добавить(Новый РеквизитФормы(ИмяТаблицы, Новый ОписаниеТипов("ТаблицаЗначений")));
		ДобавляемыРеквизиты.Добавить(Новый РеквизитФормы(ИмяКолонки, Новый ОписаниеТипов("Строка"), ИмяТаблицы));
		ДобавляемыРеквизиты.Добавить(Новый РеквизитФормы(ИмяМетаОбъекта, Новый ОписаниеТипов("Строка"), ИмяТаблицы));
		
	КонецЦикла;
	
	ИзменитьРеквизиты(ДобавляемыРеквизиты);
	
	Для Каждого Имя Из СписокБазовыхТипов Цикл
		
		ИмяТаблицы = "Права" + Имя;
		ИмяКолонки = "ПолноеИмя";
		
		//
		ГруппаГоризонт = ЭтаФорма.Элементы.Добавить("ГруппаГоризонт" + ИмяТаблицы, Тип("ГруппаФормы"), Элементы.ГруппаТипыОбъектовИПрава);
		ГруппаГоризонт.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаГоризонт.Заголовок = Имя + "Горизонт";
		ГруппаГоризонт.ОтображатьЗаголовок = Ложь;
		ГруппаГоризонт.Видимость = Ложь;
		
		ДекорацияКартинка = ЭтаФорма.Элементы.Добавить("КартинкаМета" + Имя, Тип("ДекорацияФормы"), ГруппаГоризонт);
		ДекорацияКартинка.Вид = ВидДекорацииФормы.Картинка;
		ДекорацияКартинка.Картинка = БиблиотекаКартинок[ПолучитьКартинкуМета(Имя)];
		ДекорацияКартинка.РазмерКартинки = РазмерКартинки.Растянуть;
		
		ДекорацияИмя = ЭтаФорма.Элементы.Добавить("ЗаголовокМета" + Имя, Тип("ДекорацияФормы"), ГруппаГоризонт);
		ДекорацияИмя.Вид = ВидДекорацииФормы.Надпись;
		ДекорацияИмя.Заголовок = Имя; 
		ДекорацияИмя.Шрифт = Новый Шрифт(,, Истина);
		ДекорацияИмя.ЦветТекста = WebЦвета.ЗеленыйЛес;
		//
		
		Группа = ЭтаФорма.Элементы.Добавить("Группа" + ИмяТаблицы, Тип("ГруппаФормы"), Элементы.ГруппаТипыОбъектовИПрава);
		Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		Группа.Заголовок = Имя;
		Группа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		Группа.ОтображатьЗаголовок = Ложь; 
		Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		Группа.РастягиватьПоГоризонтали = Истина;
		Группа.ОтображениеУправления = ОтображениеУправленияОбычнойГруппы.Картинка;
		
		ТаблицаФормы = Элементы.Добавить(ИмяТаблицы, Тип("ТаблицаФормы"), Группа);
		ТаблицаФормы.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ТаблицаФормы.ПутьКДанным = ИмяТаблицы;
		ТаблицаФормы.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Авто;
		ТаблицаФормы.ВариантУправленияВысотой = ВариантУправленияВысотойТаблицы.ПоСодержимому;
		ТаблицаФормы.АвтоМаксимальнаяВысота = Ложь;
		ТаблицаФормы.АвтоМаксимальнаяВысотаВСтрокахТаблицы = Ложь;
		ТаблицаФормы.ТолькоПросмотр = Истина;
		ТаблицаФормы.Видимость = Ложь;
		
		НовыйЭлемент = Элементы.Добавить(ИмяТаблицы + ИмяКолонки, Тип("ПолеФормы"), ТаблицаФормы);       
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным = ИмяТаблицы + "." + ИмяКолонки; 
		НовыйЭлемент.Видимость = Ложь;
		
		НовыйЭлемент = Элементы.Добавить(ИмяТаблицы + "ИмяОбъекта", Тип("ПолеФормы"), ТаблицаФормы);       
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным = ИмяТаблицы +  "." + "ИмяОбъекта";
		НовыйЭлемент.Заголовок = "Имя объекта";
		
		СоздатьКолонкиТаблиц("СписокПрав_" + Имя, "Права" + Имя);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКолонкиТаблицы(ИмяСписка)

	СписокПрав = ЭтотОбъект[ИмяСписка];
	
	УдаляемыеРеквизиты = Новый Массив;

	ИмяТаблицы = "Права" + СтрРазделить(ИмяСписка, "_")[1];
	
	РеквизитыТаблицы = ПолучитьРеквизиты(ИмяТаблицы);
	
	Для Каждого РеквизитТаблицы Из РеквизитыТаблицы Цикл
		
		Если РеквизитТаблицы.Имя = "ПолноеИмя" ИЛИ РеквизитТаблицы.Имя = "ИмяОбъекта" Тогда
			Продолжить;
		КонецЕсли;
		
		Элементы.Удалить(Элементы[РеквизитТаблицы.Путь + РеквизитТаблицы.Имя]);
		
		УдаляемыеРеквизиты.Добавить(РеквизитТаблицы.Путь + "." + РеквизитТаблицы.Имя);
		
	КонецЦикла;
	
	ИзменитьРеквизиты(, УдаляемыеРеквизиты);
	
	СоздатьКолонкиТаблиц(ИмяСписка, РеквизитТаблицы.Путь);
	
	ОбновитьВидимостьЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьКолонкиТаблиц(ИмяСписка, Путь)
	
	СписокПрав = ЭтотОбъект[ИмяСписка];
	
	ДобавляемыРеквизиты = Новый Массив;
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("Булево"));
	ОписаниеТипов = Новый ОписаниеТипов(МассивТипов);
	
	Для Каждого Право Из СписокПрав Цикл
		Если Право.Пометка Тогда 
			ДобавляемыРеквизиты.Добавить(Новый РеквизитФормы(Право.Значение, ОписаниеТипов, Путь));
		КонецЕсли;
	КонецЦикла;
	
	ИзменитьРеквизиты(ДобавляемыРеквизиты);
	
	Для Каждого Право Из СписокПрав Цикл
		Если Право.Пометка Тогда 
			НовыйЭлементФормы = Элементы.Добавить(Путь + Право.Значение, Тип("ПолеФормы"), Элементы[Путь]);
			НовыйЭлементФормы.Вид = ВидПоляФормы.ПолеКартинки;
			НовыйЭлементФормы.ПутьКДанным = Путь + "." + Право.Значение;
			НовыйЭлементФормы.Заголовок = Право.Представление;
			НовыйЭлементФормы.КартинкаЗначений = БиблиотекаКартинок.ОформлениеФлажок;
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимостьЭлементовФормы()
	
	СписокБазовыхТипов = ПолучитьСписокБазовыхТипов();
	
	Для Каждого Имя Из СписокБазовыхТипов Цикл
		ИмяТаблицы = "Права" + Имя;    
		ТаблицаЗаполнена = ЭтотОбъект[ИмяТаблицы].Количество();
		Элементы[ИмяТаблицы].Видимость = ТаблицаЗаполнена;
		Элементы["ГруппаГоризонт" + ИмяТаблицы].Видимость = ТаблицаЗаполнена;
	КонецЦикла;
	
КонецПроцедуры

