&НаСервере
Функция ПолучитьКартинкуИзСоответствияИмен(Ключ)
	 
	СоответствиеКартинок = Новый Соответствие; 
	 
	СтрокаИмен = "Подсистема,ПиктограммаДеталиВариантаАнализа,Form,Constant,Catalog,DocumentJournal,Document,Report," +
		"DataProcessor,ChartOfCharacteristicTypes,ChartOfCalculationTypes,InformationRegister,AccumulationRegister," +
		"CalculationRegister,BusinessProcess,Task,AccountingRegister";
	СтрокаКартинок = "Подсистема,ПиктограммаДеталиВариантаАнализа,Форма,Константа,Справочник,ЖурналДокументов,Документ," +
		"Отчет,Обработка,ПланВидовХарактеристик,ПланВидовРасчета,РегистрСведений,РегистрНакопления," +
		"РегистрРасчета,БизнесПроцесс,Задача,РегистрБухгалтерии"; 
	
	МассивИмен = СтрРазделить(СтрокаИмен, ",");
	МассивКартинок = СтрРазделить(СтрокаКартинок, ",");
	
	Итер = 0;
	Пока Итер < МассивИмен.Количество() Цикл
		СоответствиеКартинок.Вставить(МассивИмен[Итер], МассивКартинок[Итер]); 
		Итер = Итер + 1;
	КонецЦикла;
	
	Возврат СоответствиеКартинок.Получить(Ключ);
	 
 КонецФункции
 
