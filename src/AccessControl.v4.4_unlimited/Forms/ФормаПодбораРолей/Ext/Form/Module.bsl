&НаКлиенте
Процедура СоздатьНовыйПрофиль(Команда)
	
	НовыйПрофиль = ПолучитьФорму("Справочник.ПрофилиГруппДоступа.Форма.ФормаЭлемента");
	
	Если Элементы.РолиОбъекта.ТекущиеДанные <> Неопределено Тогда
		НовыйПрофиль.Объект.Наименование = Элементы.РолиОбъекта.ТекущиеДанные.РольПредставление;
		КоллекцияСтрок = НовыйПрофиль.ЭтотОбъект.Роли.ПолучитьЭлементы();		
		
		ПоискЗавершен = Ложь;
		Идентификатор = Неопределено;
		
		ОбойтиУровеньДерева(КоллекцияСтрок, Элементы.РолиОбъекта.ТекущиеДанные.НаименованиеРоли, ПоискЗавершен, Идентификатор);
		
		НовыйПрофиль.Модифицированность = Истина;
		
	КонецЕсли;                          
	
	НовыйПрофиль.Открыть(); 
	
	Если Идентификатор <> Неопределено Тогда
		НовыйПрофиль.Элементы.Роли.ТекущаяСтрока = Идентификатор;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовуюГруппу(Команда)
	
	//ПараметрыОткрытия = Новый Структура;
	//ПараметрыОткрытия.Вставить("", );
	
	НоваяГруппа = ПолучитьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента"); 
	
	Если Элементы.РолиОбъекта.ТекущиеДанные <> Неопределено Тогда
		НоваяГруппа.Объект.Наименование = Элементы.РолиОбъекта.ТекущиеДанные.РольПредставление; 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		ЭлементДерева = НоваяГруппа.ПользователиГруппы.ПолучитьЭлементы();
		НовыйПользователь = ЭлементДерева.Добавить();
		НовыйПользователь.Пользователь = Объект.Пользователь;  
		НовыйПользователь.Ссылка = Объект.Пользователь;
		НовыйПользователь.НомерКартинки = 1;
	КонецЕсли;
	
	НоваяГруппа.Открыть();
	НоваяГруппа.Модифицированность = Истина;
	
	//ОткрытьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента",,,, НоваяГруппа.Окно);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбнаруженыОшибки(Команда)
	
	Если КритическаяОшибка Тогда
		Сообщить("Перезапустите обработку и укажите в настройках другую дату поиска ошибок");
		Возврат;
	КонецЕсли;	
	
	ПараметрыОткрытия = Новый Структура("АдресСоответствияПользователей, АдресТаблицыОшибок, ДатаОшибок", 
		АдресСоответствияПользователей, 
		ПолучитьАдресТаблицыОшибок(ТаблицаОшибок, ЭтаФорма.УникальныйИдентификатор), ПериодПоискаОшибок.ДатаНачала);
		
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаАвтоисправление", ПараметрыОткрытия, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПраваДоступа(Команда)
	
	ПараметрыОткрытия = Новый Структура("Пользователь", Объект.Пользователь);
	ОткрытьФорму("ОбщаяФорма.ПраваДоступа", ПараметрыОткрытия, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры 
                                         
&НаКлиенте                                             
Процедура ОчиститьКешПользователя(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Пользователь) Тогда
		ПоказатьПредупреждение(, "Для начала выберите пользователя");		
		Возврат;
	КонецЕсли;
		
	ПользовательОС = ПолучитьПользователяОС(Объект.Пользователь);
	
	Вхождение = СтрНайти(ПользовательОС, "\", НаправлениеПоиска.СКонца, СтрДлина(ПользовательОС), 1);	
	Логин = Прав(ПользовательОС, СтрДлина(ПользовательОС) - Вхождение);
		
	НовыйПуть = ПутьДоПользователей + "\Users\" + Логин + "\AppData";
	
	СеансНайден = Ложь;
	ПользовательОнлайн = ПользовательОнлайн(Объект.Пользователь, СеансНайден);
	
	// Рекомендованные для очистки каталоги
	МассивПутейОчистки = Новый Массив;	
	МассивПутейОчистки.Добавить(НовыйПуть + "\Local\1C\");
	МассивПутейОчистки.Добавить(НовыйПуть + "\Roaming\1C\1cv8\");
	МассивПутейОчистки.Добавить(НовыйПуть + "\Roaming\1C\1cv82\");

	// Отберем только существующие каталоги
	Для Каждого Путь Из МассивПутейОчистки Цикл
		
		Каталог = Новый Файл(Путь);
		
		Если НЕ Каталог.Существует() Тогда
			Индекс = МассивПутейОчистки.Найти(Путь);
			МассивПутейОчистки.Удалить(Индекс);
		КонецЕсли;
		
	КонецЦикла;
	
	КнопкиОтвета = Новый СписокЗначений;
	Если ПользовательОнлайн Тогда 
		КнопкиОтвета.Добавить("Игнорировать предупреждение и продолжить");
		КнопкиОтвета.Добавить("Отмена");
		ОО = Новый ОписаниеОповещения("ПередОчисткойОнлайн", ЭтотОбъект, Новый Структура("СписокПапок", МассивПутейОчистки));        
		ПоказатьВопрос(ОО, "Пользователь онлайн! Для успешной очистки, попросите пользователя выйти из базы или завершите сеанс самостоятельно из опции мониторинга.",                                          
		КнопкиОтвета,,, "Пользователь в сети, продолжить?"); 
	Иначе  
		КнопкиОтвета.Добавить("Подтвердить");
		КнопкиОтвета.Добавить("Отмена");
		ОО = Новый ОписаниеОповещения("ПослеПодтвержденияОчисткаКеша", ЭтотОбъект, Новый Структура("СписокПапок", МассивПутейОчистки));
		ПоказатьВопрос(ОО, "Будут очищены следующие папки:
		|
		|" + СтрСоединить(МассивПутейОчистки, Символы.ПС), КнопкиОтвета,,, "Подтвердите очистку кеша");
	КонецЕсли;

	
КонецПроцедуры  

