	ИначеЕсли ИмяТекТаблицы = "ТаблицаГруппДоступа" Тогда
        ПараметрыОткрытия.Вставить("ОбъектПроверки", Элементы[ИмяТекТаблицы].ТекущиеДанные.ГруппаДоступа);
	ИначеЕсли ИмяТекТаблицы = "ТаблицаПрофилей" Тогда
		ПараметрыОткрытия.Вставить("ОбъектПроверки", Элементы[ИмяТекТаблицы].ТекущиеДанные.Профиль);
