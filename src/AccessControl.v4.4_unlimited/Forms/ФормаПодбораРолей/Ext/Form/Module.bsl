
#Область ОписаниеПеременных

&НаКлиенте
Перем ЭтоОткрытиеФормы, СтрокаБылаПеревыбрана;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	
	МассивОшибок = Новый Массив;
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	
	ТекОбъект.ПроверитьВозможностьЗапуска(Отказ, ЭтотОбъект, МассивОшибок);
	
	Если Отказ Тогда  
		Сообщить(СтрСоединить(МассивОшибок, Символы.ПС));
		Возврат;
	КонецЕсли;
	
	Элементы.ОчиститьКешПользователя.Доступность = Ложь;
	
	Если СтрНайти(Метаданные.Синоним, "Управление торговлей") > 0 Тогда
		ИмяКонфигурации = "УТ";
	ИначеЕсли СтрНайти(Метаданные.Синоним, "Комплексная автоматизация") > 0 Тогда
		ИмяКонфигурации = "КА";
	КонецЕсли;
	
	Объект.ПользовательИБПолноправный = Пользователи.ЭтоПолноправныйПользователь();
	Объект.ГруппаДоступаАдминистраторы = УправлениеДоступом.ГруппаДоступаАдминистраторы();
	
	Элементы.ОбнаруженыОшибки.Видимость = Ложь;
	Элементы.ОшибокНеОбнаружено.Видимость = Ложь;
	Элементы.НайтиСвязиОбъекта.Доступность = Ложь;
	Элементы.НайтиСвязиОбъекта1.Доступность = Ложь;
	
	//КоличествоДнейНазадДляПоискаОшибки = 0;
	
	ТекДата = ТекущаяДатаСеанса();
	
	Если НЕ ЗначениеЗаполнено(ПериодПоискаОшибок.ДатаНачала) Тогда
		ПериодПоискаОшибок.ДатаНачала = НачалоДня(ТекДата); 
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПериодПоискаОшибок.ДатаОкончания) Тогда
		ПериодПоискаОшибок.ДатаОкончания = ТекДата; 
	КонецЕсли;
	
	ОбработатьДеревоМетаданных();
	
	ЗаполнитьСписокРолейМетаданных(Истина);
	
	СоздатьНовоеПустоеДеревоКопированием();
	
	ЗаполнитьТаблицуИдентификаторовИБ();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если ДинамическийПериодПоиска Тогда
		ТекДата = ТекущаяДатаСеанса();
		ПериодПоискаОшибок.ДатаНачала = НачалоДня(ТекДата); 
		ПериодПоискаОшибок.ДатаОкончания = КонецДня(ТекДата); 
	КонецЕсли;
	
	Если ИспользоватьАвтоПоискОшибок Тогда
		ВыполнитьАвтоматическийАнализОшибок();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// Раскоментить при ошибке парсинга ЖР
	ИспользоватьАвтоПоискОшибок = Ложь;
	
	Элементы.ГруппаКнопокРазвернуто.Видимость = Ложь;
	Элементы.ГруппаКнопокРазвернуто2.Видимость = Ложь;
	Элементы.КнопкаСвернуть.Видимость = Ложь;
	
	Если ИспользуетсяТерминальныйРежим И ЗначениеЗаполнено(Объект.Пользователь) Тогда 
		Элементы.ОчиститьКешПользователя.Доступность = Истина;
	КонецЕсли;
	
	ЭтоОткрытиеФормы = 1;
	
	СкрытьВидимостьПравДоступаПользователя();
	
	СменитьНадписьВыборПользователя();
	
	Если СворачиватьТаблицуПрофилейПриОткрытии Тогда
		Элементы.ГруппаТаблицаПрофилей.Скрыть();
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(АдресСоответствияПользователей) И УведомлятьОбОшибкахПриОткрытии Тогда
		ОбнаруженыОшибки(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "НеобходимоВыполнитьАвтоматическоеИсправление" Тогда
		
		ПродолжитьАвтоматическоеИсправление(Параметр.СтрокиДляОбработки);
		
	ИначеЕсли ИмяСобытия = "НеобходимоПеренестиВОбработку" Тогда
		
		Объект.Пользователь = Параметр.Пользователь;
		ПользовательПриИзмененииОбработчик(Неопределено);
		
		Если НЕ ПустаяСтрока(Параметр.Таблица) Тогда
			
			Для Каждого СтрокаДерева Из ДеревоКонфигурации.ПолучитьЭлементы() Цикл
				
				Для Каждого Строка Из СтрокаДерева.ПолучитьЭлементы() Цикл
					
					Если Строка.ПолноеИмя = Параметр.Таблица Тогда 
						Элементы.ДеревоКонфигурации.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ИсторияИзмененияЗакрыта" Тогда
		
		КопияТаблицы = История;
		СинхронизироватьТаблицуИстории(КопияТаблицы, Параметр.АдресТаблицыИстории);
		КопироватьДанныеФормы(КопияТаблицы, История);
		
	ИначеЕсли ИмяСобытия = "ПоказатьОбъектВДереве" Тогда
		
		Для Каждого СтрокаДерева Из ДеревоКонфигурации.ПолучитьЭлементы() Цикл
				
				Для Каждого Строка Из СтрокаДерева.ПолучитьЭлементы() Цикл
					
					Если Строка.ПолноеИмя = Параметр.ТекОбъект Тогда 
						Элементы.ДеревоКонфигурации.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;
		
	ИначеЕсли ИмяСобытия = "ОбработкаИсправленияОшибок" Тогда
		
		ЗафиксироватьИсправлениеОшибок(Параметр.АдресТаблицыОшибок);
		
	КонецЕсли;
	
	Попытка
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметр, "АдресТаблицыОшибок") Тогда
			
			КопияТаблицыОшибок = ТаблицаОшибок;
			ЗаполнитьТаблицуОшибок(КопияТаблицыОшибок, Параметр.АдресТаблицыОшибок, ТаблицаИдентификаторовИБПользователей);
			КопироватьДанныеФормы(КопияТаблицыОшибок, ТаблицаОшибок);
			
			УдалитьИзВременногоХранилища(Параметр.АдресТаблицыОшибок);  
			
			ВыполнитьАвтоматическийАнализОшибок();
			
		КонецЕсли;   
	Исключение
	КонецПопытки;
	
КонецПроцедуры

