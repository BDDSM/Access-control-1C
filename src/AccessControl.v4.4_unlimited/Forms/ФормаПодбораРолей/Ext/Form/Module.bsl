&НаСервере
Функция ПолучитьИндексыДляУдаления(ДеревоОсновное, Родитель, ПоискРоли = Ложь);
	
	Если НЕ Родитель = Неопределено Тогда
		Ответ = ПолучитьИндексыДляУдаления(ДеревоОсновное, Родитель.Родитель, ПоискРоли);
		
		ПараметрыОтбора = Новый Структура("Имя", Родитель.Имя);
		НайденныеСтроки = ?(Ответ.ПоследняяСтрока, ДеревоОсновное.Строки.НайтиСтроки(ПараметрыОтбора), Ответ.СтрокаДанных.Строки.НайтиСтроки(ПараметрыОтбора));
		
		Если ПоискРоли Тогда
			Возврат Новый Структура("СтрокаДанных, Родитель, ПоследняяСтрока", Неопределено, Родитель, Ложь);
		Иначе
			Возврат Новый Структура("СтрокаДанных, Родитель, ПоследняяСтрока", НайденныеСтроки[0], Родитель, Ложь);
		КонецЕсли;
	Иначе
		Возврат Новый Структура("СтрокаДанных, Родитель, ПоследняяСтрока", Неопределено, Родитель, Истина);
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция НайтиЧислаСконца(ИсходнаяСтрока)
	
	ТекущееЧисло = "";
	А = 1;
	// Проходим по строке с конца
	Для Индекс = СтрДлина(ИсходнаяСтрока) По СтрДлина(ИсходнаяСтрока) * 2 Цикл 
		Символ = ?(Индекс = СтрДлина(ИсходнаяСтрока), 
			Сред(ИсходнаяСтрока, Индекс, 1), Сред(ИсходнаяСтрока, Индекс - А, 1));
		
		// Проверяем, является ли текущий символ цифрой
		Если СтрНайти("0123456789", Символ) > 0 Тогда
			// Добавляем символ в начало текущей подстроки числа
			ТекущееЧисло = Символ + ТекущееЧисло;
		ИначеЕсли НЕ ТекущееЧисло = "" Тогда
			// Если отработало эта ветка условия, то прерываем цикл
			Прервать;
		КонецЕсли;
		А = А + 1;
	КонецЦикла;
	
	Возврат ТекущееЧисло;
	
КонецФункции

&НаСервере
Процедура ОбходДереваДляПоиска(ТекРодитель, РодителиКУдалению, Отборы, ХотьОднаСтрокаПопалаПоОтбору, ДобавкаКИмени = "99", Уровень = "Уровень1")
	
	ИндексПоиска = 0;
	Для Каждого СтрокаРодителя Из ТекРодитель.Строки Цикл
		
		пХотьОднаСтрокаПопалаПоОтбору = Ложь;
		Если СтрокаРодителя.Строки.Количество() Тогда
			пДобавкаКИмени = ДобавкаКИмени + "9";
			ТекУровень = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(СтрЗаменить(СтрЗаменить(Уровень, "Уровень", ""), " ", "")) + 1; 
			
			ОбходДереваДляПоиска(СтрокаРодителя, РодителиКУдалению, Отборы, пХотьОднаСтрокаПопалаПоОтбору, пДобавкаКИмени, "Уровень" + ТекУровень);
		КонецЕсли;
	
		СтрокаРодителяСоответствуетОтбору = Ложь;
		
		Если Отборы.Свойство("ПоискПоНаименованию") И (СтрНайти(НРег(СтрокаРодителя.Синоним), НРег(Отборы.ПоискПоНаименованию))
			ИЛИ СтрНайти(НРег(СтрокаРодителя.Имя), НРег(Отборы.ПоискПоНаименованию)) > 0) Тогда
			
			СтрокаРодителяСоответствуетОтбору = Истина;
			
		ИначеЕсли Отборы.Свойство("ПолноеИмя") И НЕ Отборы.ПолноеИмя.Найти(СтрокаРодителя.ПолноеИмя) = Неопределено Тогда
			
			СтрокаРодителяСоответствуетОтбору = Истина;
			
		КонецЕсли;                                             
		
		Если Не СтрокаРодителяСоответствуетОтбору И НЕ пХотьОднаСтрокаПопалаПоОтбору Тогда
			
			РодителиКУдалению.Вставить(СтрокаРодителя.Родитель.Имя + ДобавкаКИмени + СтрЗаменить(СтрокаРодителя.ПолноеИмя, ".", "") 
				+ "ИндексПоиска" + ИндексПоиска + Уровень, СтрокаРодителя);
			
		Иначе
			
			ХотьОднаСтрокаПопалаПоОтбору = Истина;
			пХотьОднаСтрокаПопалаПоОтбору = Ложь;
			
		КонецЕсли;
		
		ИндексПоиска = ИндексПоиска + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьНовоеПустоеДеревоКопированием()
	
	ДеревоИсходник = РеквизитФормыВЗначение("ДеревоКонфигурации");
	МассивДобавленныхРеквизитов = Новый Массив;
	НовоеДерево = Новый РеквизитФормы("КопияДеревоКонфигурации", Новый ОписаниеТипов("ДеревоЗначений"));
	МассивДобавленныхРеквизитов.Добавить(НовоеДерево);
	
	Для Каждого ТекКол Из ДеревоИсходник.Колонки Цикл
		
		Колонка = Новый РеквизитФормы(ТекКол.Имя, ТекКол.ТипЗначения, "КопияДеревоКонфигурации");
		МассивДобавленныхРеквизитов.Добавить(Колонка);
		
	КонецЦикла;
	
	ИзменитьРеквизиты(МассивДобавленныхРеквизитов);  
	ЗначениеВРеквизитФормы(ДеревоИсходник, "КопияДеревоКонфигурации");
	
	ДеревоИсходник = Неопределено;
	
КонецПроцедуры

