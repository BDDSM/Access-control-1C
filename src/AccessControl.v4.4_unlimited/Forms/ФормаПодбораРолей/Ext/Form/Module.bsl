&НаСервереБезКонтекста
Функция ПользовательОнлайн(Пользователь, СеансНайден) 
	
	СеансыИнформационнойБазы = ПолучитьСеансыИнформационнойБазы();
	
	УИДПользователяИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Пользователь.ИдентификаторПользователяИБ).УникальныйИдентификатор;
	
	Для Каждого Сеанс Из СеансыИнформационнойБазы Цикл
		
		Если Сеанс.Пользователь.УникальныйИдентификатор = УИДПользователяИБ И (Сеанс.ИмяПриложения = "1CV8C" ИЛИ Сеанс.ИмяПриложения = "WebClient") Тогда
			СеансНайден = Истина;
			Прервать;
		КонецЕсли; 
		
	КонецЦикла;	
	
	Возврат СеансНайден;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНовоеДерево(ИмяМетаданного)
	
	Если ИмяМетаданного = Неопределено Тогда 
		Возврат;
	КонецЕсли;  	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрофилиГруппДоступаРоли.Ссылка КАК Профиль
	|ПОМЕСТИТЬ ВТ_Профиль
	|ИЗ
	|	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	|ГДЕ
	|	ПрофилиГруппДоступаРоли.Роль.Имя = &Роль
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГруппыДоступа.Ссылка КАК ГруппаДоступа,
	|	ВТ_Профиль.Профиль КАК Профиль
	|ИЗ
	|	ВТ_Профиль КАК ВТ_Профиль
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа КАК ГруппыДоступа
	|		ПО ВТ_Профиль.Профиль = ГруппыДоступа.Профиль
	|ИТОГИ ПО
	|	ГруппаДоступа";
	
	Запрос.УстановитьПараметр("Роль", ИмяМетаданного);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ГруппыИПрофилиДерево.ПолучитьЭлементы().Очистить();
	Пока Выборка.Следующий() Цикл
		Попытка
			СтрокаПрофиля = ГруппыИПрофилиДерево.ПолучитьЭлементы().Добавить();
			СтрокаПрофиля.СтроковоеПредставление = Выборка.ГруппаДоступа;
			
			ВыборкаПрофиль = Выборка.Выбрать();
			Пока ВыборкаПрофиль.Следующий() Цикл
				Если ЗначениеЗаполнено(ВыборкаПрофиль.Профиль) Тогда
					НоваяПользователя = СтрокаПрофиля.ПолучитьЭлементы().Добавить();
					НоваяПользователя.СтроковоеПредставление = ВыборкаПрофиль.Профиль;
				КонецЕсли;
			КонецЦикла;	
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;  		
	КонецЦикла; 
	
КонецПроцедуры

