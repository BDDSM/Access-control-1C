&НаСервере
Функция ВидОбъектаПоТипу(ТипОбъекта)
	                   
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "Справочники";
	
	ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "Документы";
	
	ИначеЕсли БизнесПроцессы.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "БизнесПроцессы";
	
	ИначеЕсли ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "ПланыВидовХарактеристик";
	
	ИначеЕсли ПланыСчетов.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "ПланыСчетов";
	
	ИначеЕсли ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "ПланыВидовРасчета";
	
	ИначеЕсли Задачи.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "Задачи";
	
	ИначеЕсли ПланыОбмена.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "ПланыОбмена";
	
	ИначеЕсли Перечисления.ТипВсеСсылки().СодержитТип(ТипОбъекта) Тогда
		Возврат "Перечисления";
	
	Иначе
		Возврат Неопределено;
	
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ИзвлечьСсылкиИзОбъекта(ОбъектАнализа, МассивСсылок, ПризнакНаличия)
	
	Для Каждого СсылкаОбъекта Из ОбъектАнализа Цикл  
		
		СтрокаРезультат = СтрШаблон("%1.%2", ОбщегоНазначения.ИмяБазовогоТипаПоОбъектуМетаданных(СсылкаОбъекта), СсылкаОбъекта.Имя);
		Если МассивСсылок.Найти(СтрокаРезультат) = Неопределено Тогда 
			МассивСсылок.Добавить(СтрокаРезультат); 
			ПризнакНаличия = Истина;
		КонецЕсли;
		
	КонецЦикла;		  	
	
КонецПроцедуры

&НаСервере
Процедура ИзвлечьДанныеИзРегистровИРеквизитов(ОбъектАнализа, МассивСсылок, ПризнакНаличия)
	
	Для Каждого СсылкаОбъекта Из ОбъектАнализа Цикл  
		
		МассивТипов = СсылкаОбъекта.Тип.Типы();
		
		Если МассивТипов.Количество() Тогда   
			
			Для Каждого ТипСсылки Из МассивТипов Цикл
				
				Если ВидОбъектаПоТипу(ТипСсылки) = Неопределено Тогда
					Продолжить;
				КонецЕсли;                                                                   
				
				СтрокаРезультат = СтрШаблон("%1.%2", ВидОбъектаПоТипу(ТипСсылки), Метаданные.НайтиПоТипу(ТипСсылки).Имя);
				Если МассивСсылок.Найти(СтрокаРезультат) = Неопределено Тогда 
					МассивСсылок.Добавить(СтрокаРезультат); 
					ПризнакНаличия = Истина;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;		              	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСвязиОбъектаНаСервере(ПолноеИмяОбъекта) 
	
	ОбъектАнализа = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъекта);
	ТипМетаданного = ОбщегоНазначения.ИмяБазовогоТипаПоОбъектуМетаданных(ОбъектАнализа);  	   
	
	ЕстьВладелец    = Ложь;
	ЕстьОснование   = Ложь;
	ЕстьДвижение    = Ложь;
	ЕстьРеквизит    = Ложь; 
	ЕстьИзмерение   = Ложь;
	ЕстьРесурс      = Ложь;
	ЕстьРегистратор = Ложь;
	
	Точка = ".";

	// Поиск среди владельцев
	Если ТипМетаданного = "Справочники" Тогда
		МассивВладельцев = Новый Массив;
		ИзвлечьСсылкиИзОбъекта(ОбъектАнализа.Владельцы, МассивВладельцев, ЕстьВладелец);
	КонецЕсли;
	
	// Поиск среди оснований     
	Если ТипМетаданного = "Справочники" ИЛИ ТипМетаданного = "Документы" Тогда
		МассивОснований = Новый Массив;
		ИзвлечьСсылкиИзОбъекта(ОбъектАнализа.ВводитсяНаОсновании, МассивОснований, ЕстьОснование);
	КонецЕсли;
	                                          
	// Поиск среди движений
	Если ТипМетаданного = "Документы" Тогда
		МассивДвижений = Новый Массив;
		ИзвлечьСсылкиИзОбъекта(ОбъектАнализа.Движения, МассивДвижений, ЕстьДвижение); 
	КонецЕсли;
	
	// Поиск среди измерений
	Если ТипМетаданного = "РегистрыНакопления" ИЛИ ТипМетаданного = "РегистрыСведений" Тогда
		МассивИзмерений = Новый Массив;
		ИзвлечьДанныеИзРегистровИРеквизитов(ОбъектАнализа.Измерения, МассивИзмерений, ЕстьИзмерение);
	КонецЕсли;
		
	// Поиск среди ресурсов
	Если ТипМетаданного = "РегистрыСведений" Тогда
		МассивРесурсов = Новый Массив;
		ИзвлечьДанныеИзРегистровИРеквизитов(ОбъектАнализа.Ресурсы, МассивРесурсов, ЕстьРесурс);
	КонецЕсли;
		
	// Поиск среди реквизитов
	МассивРеквизитов = Новый Массив;
	ИзвлечьДанныеИзРегистровИРеквизитов(ОбъектАнализа.Реквизиты, МассивРеквизитов, ЕстьРеквизит);
	
	
	// Поиск среди регистраторов
	Если ТипМетаданного = "РегистрыСведений" ИЛИ ТипМетаданного = "РегистрыНакопления" Тогда
		МассивРегистраторов = Новый Массив;
		Попытка
			МассивТипов = ОбъектАнализа.СтандартныеРеквизиты.Регистратор.Тип.Типы();
		Исключение
		КонецПопытки;
		
		Если МассивТипов <> Неопределено И МассивТипов.Количество() Тогда 
			
			Для Каждого ТипРегистратора Из МассивТипов Цикл   
				
				Если ВидОбъектаПоТипу(ТипРегистратора) = Неопределено Тогда
					Продолжить;
				КонецЕсли;   
				
				СтрокаРезультат = СтрШаблон("%1%2%3", ВидОбъектаПоТипу(ТипРегистратора), Точка, Метаданные.НайтиПоТипу(ТипРегистратора).Имя);
				Если МассивРегистраторов.Найти(СтрокаРезультат) = Неопределено Тогда 
					МассивРегистраторов.Добавить(СтрокаРезультат);   
					ЕстьРегистратор = Истина;
				КонецЕсли;	
				
			КонецЦикла;				
		КонецЕсли;		
	КонецЕсли;
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Объект", Новый ОписаниеТипов("Строка"));
	ТЗ.Колонки.Добавить("Картинка", Новый ОписаниеТипов("Картинка"));
		
	Если ЕстьВладелец Тогда            
		УпорядочитьОбъекты(МассивВладельцев);
		ДополнитьТаблицуОбъектов("*ВЛАДЕЛЬЦЫ:", МассивВладельцев, ТЗ);
	КонецЕсли; 
	
	Если ЕстьОснование Тогда            
		УпорядочитьОбъекты(МассивОснований);
		ДополнитьТаблицуОбъектов("*ОСНОВАНИЯ:", МассивОснований, ТЗ);
	КонецЕсли;
	
	Если ЕстьДвижение Тогда            
		УпорядочитьОбъекты(МассивДвижений);
		ДополнитьТаблицуОбъектов("*ДВИЖЕНИЯ:", МассивДвижений, ТЗ);
	КонецЕсли;
	
	Если ЕстьИзмерение Тогда            
		УпорядочитьОбъекты(МассивИзмерений);
		ДополнитьТаблицуОбъектов("*ИЗМЕРЕНИЯ:", МассивИзмерений, ТЗ);
	КонецЕсли;
	
	Если ЕстьРесурс Тогда            
		УпорядочитьОбъекты(МассивРесурсов);
		ДополнитьТаблицуОбъектов("*РЕСУРСЫ:", МассивРесурсов, ТЗ);
	КонецЕсли;
	
	Если ЕстьРегистратор Тогда            
		УпорядочитьОбъекты(МассивРегистраторов);
		ДополнитьТаблицуОбъектов("*РЕГИСТРАТОРЫ:", МассивРегистраторов, ТЗ);
	КонецЕсли;
	
	Если ЕстьРеквизит Тогда            
		УпорядочитьОбъекты(МассивРеквизитов);
		ДополнитьТаблицуОбъектов("*РЕКВИЗИТЫ:", МассивРеквизитов, ТЗ);
	КонецЕсли;
	
	Возврат ?(ТЗ.Количество(), ПоместитьВоВременноеХранилище(ТЗ, Новый УникальныйИдентификатор), ""); 
	
КонецФункции 

&НаСервере
Процедура УпорядочитьОбъекты(МассивОбъектов)

	Сортировка = Новый СписокЗначений; 
	Сортировка.ЗагрузитьЗначения(МассивОбъектов);
	Сортировка.СортироватьПоЗначению(НаправлениеСортировки.Возр);
	МассивОбъектов = Сортировка.ВыгрузитьЗначения();
	
КонецПроцедуры 

&НаСервере
Процедура ДополнитьТаблицуОбъектов(ИмяИсточника, КоллекцияИсточник, ТЗ)
	
	УпорядочитьОбъекты(КоллекцияИсточник);
	НоваяСтрока = ТЗ.Добавить();
	НоваяСтрока.Объект = ИмяИсточника; 
	Для Каждого ОбъектСтрокой Из КоллекцияИсточник Цикл
		НоваяСтрока = ТЗ.Добавить();
		НоваяСтрока.Объект = ОбъектСтрокой;                                          
		КартинкаНайдена = КартинкиМетаданных.НайтиПоЗначению((Лев(ОбъектСтрокой, СтрНайти(ОбъектСтрокой, ".") -1)));
		Если КартинкаНайдена <> Неопределено Тогда 
			НоваяСтрока.Картинка = КартинкаНайдена.Картинка;  
		КонецЕсли;
	КонецЦикла;		
	
КонецПроцедуры

&НаСервере
Процедура ЗафиксироватьИсправлениеОшибок(АдресТаблицыОшибок)
	
	Если НЕ ЭтоАдресВременногоХранилища(АдресТаблицыОшибок) Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Не верный формат адреса таблицы ошибок. Зафиксировать исправление не возможно.'"));
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура("ОшибкаИсправлена", Истина);
	Таблица = ПолучитьИзВременногоХранилища(АдресТаблицыОшибок).НайтиСтроки(СтруктураПоиска);
	
	Для Каждого Строка Из Таблица Цикл
		
		МенеджерЗаписи = РегистрыСведений.УД_ИсторияИсправленияОшибок.СоздатьМенеджерЗаписи();
		
		СтруктураПоиска = Новый Структура("Пользователь", Строка.Пользователь);
		НайденныйПользователь = ТаблицаИдентификаторовИБПользователей.НайтиСтроки(СтруктураПоиска);
		
		МенеджерЗаписи.ДатаОшибки    = Строка.ДатаОшибки;
		МенеджерЗаписи.Пользователь  = НайденныйПользователь[0].ИдентификаторИБ;
		МенеджерЗаписи.Событие       = Строка.Событие;
		
		МенеджерЗаписи.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуИдентификаторовИБ()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Пользователь,
	|	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторИБ
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	НЕ Пользователи.ПометкаУдаления";
	
	ТаблицаИдентификаторовИБПользователей.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПарсерЗапроса(Команда)
	
	ПараметрыОткрытия = Новый Структура("Пользователь", Объект.Пользователь);	
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаПарсерЗапроса", ПараметрыОткрытия, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуБраузера(Команда)
	
	ПараметрыФормы = Новый Структура("АдресURL", "https://github.com/VorozhbitDM/Access-control-1C/");
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаСправка", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти
