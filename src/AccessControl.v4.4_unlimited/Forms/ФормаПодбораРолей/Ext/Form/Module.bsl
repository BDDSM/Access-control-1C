&НаКлиенте
Процедура НовоеЗначениеВШаблон(Команда)
	
	Если Элементы.ВидыДоступа.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;                                                                                        
	
	Если Элементы.ЗначенияДоступа.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураДопПараметров = Новый Структура("ИмяКоманды", Команда.Имя);
	
	ОО = Новый ОписаниеОповещения("ПослеВыбораОганизации", ЭтотОбъект, СтруктураДопПараметров);
	
	Если Команда.Имя = "УдалитьЗначениеИзШаблона" Тогда
		
		ПослеВыбораОганизации(Элементы.ЗначенияДоступа.ТекущиеДанные.ЗначениеДоступа, СтруктураДопПараметров);
		
	Иначе	
		
		Если Элементы.ВидыДоступа.ТекущиеДанные.ВидДоступа = "Организации" Тогда
			
			ОткрытьФорму("Справочник.Организации.ФормаВыбора",, ЭтотОбъект,,,, ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
		Если Элементы.ВидыДоступа.ТекущиеДанные.ВидДоступа = "Пользователи" Тогда
			
			ПараметрыОткрытия = Новый Структура("РежимВыбора", Истина);
			
			ОткрытьФорму("Справочник.Пользователи.ФормаВыбора", ПараметрыОткрытия, ЭтотОбъект,,,, ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

