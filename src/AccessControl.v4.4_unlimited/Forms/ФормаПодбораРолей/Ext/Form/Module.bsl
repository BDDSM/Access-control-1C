&НаКлиенте
Процедура СравнитьРоли(Команда) 
	
	МассивРолей = Новый Массив;
	
	МассивСтрок = Элементы.РолиОбъекта.ВыделенныеСтроки;
	Если МассивСтрок.Количество() > 1 Тогда
		
		Для Каждого Идентификатор Из МассивСтрок Цикл
			Строка = РолиОбъекта.НайтиПоИдентификатору(Идентификатор);    
			МассивРолей.Добавить(Строка.НаименованиеРоли);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьГруппуИПрофильАвто(Команда)
		
	ТекДанные = Элементы.РолиОбъекта.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("ИдентификаторРоли, Роль", ТекДанные.Идентификатор, ТекДанные.Роль);
	Описание = Новый ОписаниеОповещения("ПослеВводаИмениГруппыИПрофиля", ЭтотОбъект, ДополнительныеПараметры);
	ПоказатьВводСтроки(Описание, "", "Введите название группы и профиля");     
	
КонецПроцедуры

&НаКлиенте
Процедура ПодготовитьДанныеДляОбработкиШаблона(ИмяКоманды, ЗначениеДоступа = Неопределено)
	
	Если Элементы.ТаблицаГруппДоступа.ТекущиеДанные = Неопределено ИЛИ Элементы.ВидыДоступа.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
			
	ТекДанныеДоступ = Элементы.ВидыДоступа.ТекущиеДанные;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ГруппаДоступа", Элементы.ТаблицаГруппДоступа.ТекущиеДанные.ГруппаДоступа);	
	СтруктураПараметров.Вставить("ВидДоступа", 	  ТекДанныеДоступ.ВидДоступа);
	СтруктураПараметров.Вставить("ИмяКоманды", 	  ИмяКоманды);
	
	Если ТекДанныеДоступ.ВидДоступа = "Организации" Тогда
		СтруктураПараметров.Вставить("ЗначениеДоступа", ?(ЗначениеДоступа <> Неопределено, ЗначениеДоступа, ЭтотОбъект.МестоРаботы));	
	ИначеЕсли ТекДанныеДоступ.ВидДоступа = "Пользователи" Тогда
		СтруктураПараметров.Вставить("ЗначениеДоступа", ?(ЗначениеДоступа <> Неопределено, ЗначениеДоступа, Объект.Пользователь));
	КонецЕсли;
		
	СтрокаКоллекции = ТаблицаГруппДоступа.НайтиПоИдентификатору(Элементы.ТаблицаГруппДоступа.ТекущаяСтрока);
	ИндексСтрокиКоллекции = ТаблицаГруппДоступа.Индекс(СтрокаКоллекции);
	
	СтрокаОграничения = ВидыДоступа.НайтиПоИдентификатору(Элементы.ВидыДоступа.ТекущаяСтрока);
	ИндексСтрокиОграничения =  ВидыДоступа.Индекс(СтрокаОграничения);
	
	ДополнительныеПараметры = Новый Структура("ИндексСтрокиКоллекции, ИндексСтрокиОграничения", ИндексСтрокиКоллекции, ИндексСтрокиОграничения);
	
	ИзменитьШаблонНаСервере(СтруктураПараметров);
	
	ПослеРедактированияОграничений(Неопределено, ДополнительныеПараметры);
	
КонецПроцедуры

