&НаКлиенте
Процедура ПослеВыбораРоли(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыбраннаяРоль = Результат.Значение;
	
	Элементы.ВыбраннаяРоль.СписокВыбора.Добавить(Результат.Значение, Результат.Представление,, БиблиотекаКартинок.ЗакрытыйКлюч);
	
	ПослеВыбораРолиНаСервере(Истина);
	
	Если НЕ ТаблицаВхождений.Количество() Тогда
		Возврат;
	КонецЕсли;
		
	Если Элементы.ДеревоКонфигурации.ТекущиеДанные <> Неопределено Тогда
		ВыбранныйОбъект = Элементы.ДеревоКонфигурации.ТекущиеДанные.Синоним; 				
	КонецЕсли;
	
	СменитьНадписьВыборОбъекта();
	
КонецПроцедуры

