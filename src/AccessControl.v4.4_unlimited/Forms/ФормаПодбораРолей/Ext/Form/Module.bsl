		ПоказатьВопрос(ОО, "Будут очищены следующие папки:
		|
		|" + СтрСоединить(ДополнительныеПараметры.СписокПапок, Символы.ПС), КнопкиОтвета,,, "Подтвердите очистку кеша");
		
