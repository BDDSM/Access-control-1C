&НаКлиенте
Процедура ДекорацияПраваДоступаНажатие(Элемент)
	
	ПараметрыОткрытия = Новый Структура("Пользователь", Объект.Пользователь);
	ОткрытьФорму("ОбщаяФорма.ПраваДоступа", ПараметрыОткрытия, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользовательПриИзмененииОбработчик(Элемент, СтруктураПараметров = Неопределено)
	
	ОбъектВыбран = Неопределено;
	
	Если Объект.Пользователь <> ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка") Тогда
		
		Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
			ОбъектВыбран = Истина;
			НайтиРолиВОбъекте(ПолноеИмяОбъекта);
		КонецЕсли;
		
		СтруктураАналитики = ПолучитьАналитикуПользователя(); 
		
		Если СтруктураАналитики <> Неопределено Тогда
			
			Должность 					   = ?(СтруктураАналитики.Свойство("Должность"), СтруктураАналитики.Должность, "Не удалось определить");
			Элементы.Должность.Гиперссылка = ?(СтруктураАналитики.Свойство("Должность"), Истина, Ложь);
			Элементы.Должность.ЦветТекста  = ?(СтруктураАналитики.Свойство("Должность"), Новый Цвет(28, 85, 174), WebЦвета.Красный);
			
			МестоРаботы 					 = ?(СтруктураАналитики.Свойство("Организация"), СтруктураАналитики.Организация, "Не удалось определить");
			Элементы.МестоРаботы.Гиперссылка = ?(СтруктураАналитики.Свойство("Организация"), Истина, Ложь);            
			Элементы.МестоРаботы.ЦветТекста  = ?(СтруктураАналитики.Свойство("Организация"), Новый Цвет(28, 85, 174), WebЦвета.Красный);
			
		КонецЕсли;
		
		УстановитьВидимостьЭлементов();
		СменитьНадписьВыборОбъекта(ОбъектВыбран);
		
	КонецЕсли;
	
	Если ТипЗнч(СтруктураПараметров) = Тип("Структура") Тогда
		
		Если СтруктураПараметров.ИмяТаблицы = "РолиОбъекта" Тогда
			СтрокаКоллекции = РолиОбъекта.Получить(СтруктураПараметров.ИндексСтрокиКоллекции);
			Элементы.РолиОбъекта.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		Иначе 
			СтрокаКоллекции = ТаблицаГруппДоступа.Получить(СтруктураПараметров.ИндексСтрокиКоллекции);
			Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.ОчиститьКешПользователя.Доступность = ?(ЗначениеЗаполнено(Объект.Пользователь) И ИспользуетсяТерминальныйРежим, Истина, Ложь);
	
	Если ЗначениеЗаполнено(Объект.Пользователь) Тогда
		Элементы.Пользователь.КартинкаКнопкиВыбора = ?(ПользовательОнлайн(Объект.Пользователь, Ложь), БиблиотекаКартинок.ОформлениеКругЗеленый, БиблиотекаКартинок.ОформлениеКругКрасный); 
	КонецЕсли;
	
КонецПроцедуры   

&НаКлиенте                  
Процедура ПользовательПриИзменении(Элемент)
	
	ГруппыЗагружены = Ложь;
	
	Если Элементы.РолиОбъекта.ТекущиеДанные <> Неопределено Тогда
		СтрокаКоллекцииРоли = РолиОбъекта.НайтиПоИдентификатору(Элементы.РолиОбъекта.ТекущаяСтрока);
		ИндексСтрокиКоллекцииРоли = РолиОбъекта.Индекс(СтрокаКоллекцииРоли);
	КонецЕсли; 
	
	Если Элементы.ТаблицаГруппДоступа.ТекущиеДанные <> Неопределено Тогда
		СтрокаКоллекции = ТаблицаГруппДоступа.НайтиПоИдентификатору(Элементы.ТаблицаГруппДоступа.ТекущаяСтрока);
		ИндексСтрокиКоллекции = ТаблицаГруппДоступа.Индекс(СтрокаКоллекции);
		ГруппыЗагружены = Истина;
	КонецЕсли;
	
	ПользовательПриИзмененииОбработчик(Элемент, ИндексСтрокиКоллекцииРоли);
	
	Если ГруппыЗагружены Тогда
		
		Если ИндексСтрокиКоллекции <> Неопределено И ИндексСтрокиКоллекции <> 0 Тогда
			СтрокаКоллекции = ТаблицаГруппДоступа.Получить(ИндексСтрокиКоллекции);
			Элементы.ТаблицаГруппДоступа.ТекущаяСтрока = СтрокаКоллекции.ПолучитьИдентификатор();
		КонецЕсли;
		
		ТаблицаГруппДоступаПриАктивизацииСтроки(Элементы.ТаблицаГруппДоступа);
		
	КонецЕсли;
	
	Если Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолучитьРодителя() = Неопределено Тогда
		РолиОбъекта.Очистить();  
		Элементы.РолиОбъектовМетаданныхРольПредставление.Заголовок = "Роли выбранного объекта";
	КонецЕсли;
	
КонецПроцедуры

