&НаСервереБезКонтекста
Функция ПолучитьАдресТаблицыОшибок(Знач ТаблицаОшибок, УникальникальныйИдентификатор)
	
	Возврат ПоместитьВоВременноеХранилище(ДанныеФормыВЗначение(ТаблицаОшибок, Тип("ТаблицаЗначений")), УникальникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура ВыполнитьАвтоматическийАнализОшибок()
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	
	ТаблицаЖурнала = ТекОбъект.ПолучитьЖурналРегистрации(ПериодПоискаОшибок.ДатаНачала, ПериодПоискаОшибок.ДатаОкончания);
	
	Ответ = ТекОбъект.ПарсингЖурналаРегистрации(ТаблицаЖурнала, ИсправленныеОшибки);
	
	СоответствиеПользователей = Ответ.СоответствиеПользователей;
	СчетчикОшибок             = Ответ.СчетчикОшибок;
	
	ПредложитьИсправлениеОшибки(СоответствиеПользователей);
	
	Если СоответствиеПользователей.Количество() Тогда		
		АдресСоответствияПользователей = ПоместитьВоВременноеХранилище(СоответствиеПользователей, УникальныйИдентификатор);		
		Элементы.ОбнаруженыОшибки.Видимость = Истина;
		Элементы.ОшибокНеОбнаружено.Видимость = Ложь;
		ЭтотОбъект.Команды.ОбнаруженыОшибки.Подсказка = "Обнаружены ошибки прав доступа (" + СчетчикОшибок + ")"; 
	Иначе
		Элементы.ОшибокНеОбнаружено.Видимость = Истина;
		Элементы.ОбнаруженыОшибки.Видимость = Ложь;
		ЭтотОбъект.Команды.ОшибокНеОбнаружено.Подсказка = "Ошибок не обнаружено! Нажмите, чтобы обновить.";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьВТелеграм(ТекстСообщения)
	
	ПолучательID 	= ""; 
	Ключ 			= "";
	Сервер 			= "api.telegram.org";
	
