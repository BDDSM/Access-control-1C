	|	втРолиОбъектов.УправлениеИтогами КАК УправлениеИтогами,
	|	втРолиОбъектов.Роль КАК Роль,
	|	ВЫБОР
	|		КОГДА ИдентификаторыОбъектовМетаданных.Ссылка ЕСТЬ NULL
	|			ТОГДА ИдентификаторыОбъектовРасширений.Ссылка
	|		ИНАЧЕ ИдентификаторыОбъектовМетаданных.Ссылка
	|	КОНЕЦ КАК Идентификатор
	|ПОМЕСТИТЬ ВТ_ПередОтборомИдентификаторов
	|ИЗ
	|	втРолиОбъектов КАК втРолиОбъектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовМетаданных КАК ИдентификаторыОбъектовМетаданных
	|		ПО (втРолиОбъектов.Роль = ИдентификаторыОбъектовМетаданных.Имя)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИдентификаторыОбъектовРасширений КАК ИдентификаторыОбъектовРасширений
	|		ПО (втРолиОбъектов.Роль = ИдентификаторыОбъектовРасширений.Имя)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПередОтборомИдентификаторов.Чтение КАК Чтение,
	|	ВТ_ПередОтборомИдентификаторов.Изменение КАК Изменение,
	|	ВТ_ПередОтборомИдентификаторов.Добавление КАК Добавление,
	|	ВТ_ПередОтборомИдентификаторов.Удаление КАК Удаление,
	|	ВТ_ПередОтборомИдентификаторов.Просмотр КАК Просмотр,
	|	ВТ_ПередОтборомИдентификаторов.Редактирование КАК Редактирование,
	|	ВТ_ПередОтборомИдентификаторов.Проведение КАК Проведение,
	|	ВТ_ПередОтборомИдентификаторов.Использование КАК Использование,
	|	ВТ_ПередОтборомИдентификаторов.ПризнакНаличияРоли КАК ПризнакНаличияРоли,
	|	ВТ_ПередОтборомИдентификаторов.КартинкаРоли КАК КартинкаРоли,
	|	ВТ_ПередОтборомИдентификаторов.РольПредставление КАК РольПредставление,
	|	ВТ_ПередОтборомИдентификаторов.НаименованиеРоли КАК НаименованиеРоли,
	|	ВТ_ПередОтборомИдентификаторов.УправлениеИтогами КАК УправлениеИтогами,
	|	ВТ_ПередОтборомИдентификаторов.Роль КАК Роль,
	|	ВТ_ПередОтборомИдентификаторов.Идентификатор КАК Идентификатор
	|ИЗ
	|	ВТ_ПередОтборомИдентификаторов КАК ВТ_ПередОтборомИдентификаторов
	|ГДЕ
	|	ВТ_ПередОтборомИдентификаторов.Идентификатор.ПолноеИмя ПОДОБНО ""Роль%"""; 
	
	Запрос.УстановитьПараметр("РолиОбъектов", РолиОбъекта.Выгрузить());
	
	РолиОбъекта.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

