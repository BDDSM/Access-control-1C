&НаКлиенте
Процедура НайтиСвязиОбъекта(Команда) 
	
	ПолноеИмяОбъекта = Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя;
	Если ПустаяСтрока(ПолноеИмяОбъекта) Тогда 
		Возврат;
	КонецЕсли;    
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("СписокОбъектов", ПолучитьСвязиОбъектаНаСервере(ПолноеИмяОбъекта)); 
	Если ПустаяСтрока(ПараметрыОткрытия.СписокОбъектов) Тогда
		Сообщить("Связанные объекты не обнаружены.");
		Возврат;
	КонецЕсли;
	ПараметрыОткрытия.Вставить("ОбъектСвязи", Элементы.ДеревоКонфигурации.ТекущиеДанные.ПолноеИмя);
	ПараметрыОткрытия.Вставить("Пользователь", Объект.Пользователь);
	ОткрытьФорму("ВнешняяОбработка.АнализИКонтрольДоступа.Форма.ФормаАнализОбъекта", ПараметрыОткрытия, ЭтотОбъект,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
