	               |		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Пользователь1 КАК ВТ_Пользователь1
	               |		ПО (ВТ_Пользователь1.ГруппаДоступа = ВТ_Пользователь2.ГруппаДоступа)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СовпадениеГруппДоступа УБЫВ,
	               |	Пользователь1 УБЫВ,
	               |	Пользователь2 УБЫВ";
	
	Запрос.УстановитьПараметр("Пользователь1", Источник);
	Запрос.УстановитьПараметр("Пользователь2", Приемник);
	
	СравнениеГрупп.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Элементы.СравнениеГрупп.ПодчиненныеЭлементы.СравнениеГруппПользователь1.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Источник.Наименование);
	Элементы.СравнениеГрупп.ПодчиненныеЭлементы.СравнениеГруппПользователь2.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Приемник.Наименование);
	
	Элементы.СтраницаСравнениеГрупп.Заголовок = "По группам доступа (" + СравнениеГрупп.Количество() + ")";
	
КонецПроцедуры

&НаСервере
Процедура СравнитьРолиНаСервере()
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь,
	               |	ПрофилиГруппДоступаРоли.Роль КАК Роль
	               |ПОМЕСТИТЬ ВТ_Пользователь1
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	               |		ПО ПрофилиГруппДоступаРоли.Ссылка = ГруппыДоступаПользователи.Ссылка.Профиль
	               |ГДЕ
	               |	ГруппыДоступаПользователи.Пользователь = &Пользователь1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь,
	               |	ПрофилиГруппДоступаРоли.Роль КАК Роль
	               |ПОМЕСТИТЬ ВТ_Пользователь2
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	               |		ПО ПрофилиГруппДоступаРоли.Ссылка = ГруппыДоступаПользователи.Ссылка.Профиль
	               |ГДЕ
	               |	ГруппыДоступаПользователи.Пользователь = &Пользователь2
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ВТ_Пользователь1.Роль, ВТ_Пользователь2.Роль) КАК Роль,
	               |	ИСТИНА КАК КартинкаРоли,
	               |	ЕСТЬNULL(ВТ_Пользователь1.Роль.Синоним, ВТ_Пользователь2.Роль.Синоним) КАК Представление,
	               |	ВЫБОР
	               |		КОГДА ВТ_Пользователь1.Пользователь ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Пользователь1,
	               |	ВЫБОР
	               |		КОГДА ВТ_Пользователь2.Пользователь ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Пользователь2,
	               |	ВЫБОР
	               |		КОГДА НЕ ВТ_Пользователь1.Пользователь ЕСТЬ NULL
	               |				И НЕ ВТ_Пользователь2.Пользователь ЕСТЬ NULL
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК СовпадениеРолей,
	               |	ЕСТЬNULL(ВТ_Пользователь1.Роль.Имя, ВТ_Пользователь2.Роль.Имя) КАК ИмяРоли
	               |ИЗ
	               |	ВТ_Пользователь2 КАК ВТ_Пользователь2
	               |		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Пользователь1 КАК ВТ_Пользователь1
	               |		ПО (ВТ_Пользователь1.Роль = ВТ_Пользователь2.Роль)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СовпадениеРолей УБЫВ,
	               |	Пользователь1 УБЫВ,
	               |	Пользователь2 УБЫВ";
	
	Запрос.УстановитьПараметр("Пользователь1", Источник);
	Запрос.УстановитьПараметр("Пользователь2", Приемник);
	
	СравнениеРолей.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Элементы.СравнениеРолей.ПодчиненныеЭлементы.СравнениеРолейПользователь1.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Источник.Наименование);
	Элементы.СравнениеРолей.ПодчиненныеЭлементы.СравнениеРолейПользователь2.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Приемник.Наименование);
	
	Элементы.СтраницаСравненияРолей.Заголовок = "По ролям (" + Формат(СравнениеРолей.Количество(), "ЧГ=0") + ")"; 
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораРоли(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		Закрыть(ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СброситьНастройкиНаСервере(СтруктураНастроек)
	
	ПользовательИБ = ПолучитьПользователяИБ(Объект.Пользователь);
	
	Для Каждого Настройка Из СтруктураНастроек Цикл						
		Хранилище = ПолучитьХранилищеНастроек(Настройка.Ключ);
		ОчиститьХранилищеНастроек(Хранилище, ПользовательИБ, Настройка.Значение);		
	КонецЦикла;	
	
	КоллекцияСтрок = ВидыНастроек.ПолучитьЭлементы();
	КоллекцияСтрок.Очистить();
	
	ЗаполнитьТаблицуНастроек();
	
КонецПроцедуры	

&НаСервереБезКонтекста
Функция ПолучитьПользователяИБ(Пользователь)
	
	Если Пользователь.Метаданные().Реквизиты.Найти("ИдентификаторПользователяИБ") <> Неопределено Тогда
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Пользователь.ИдентификаторПользователяИБ);
	Иначе
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(СокрЛП(Пользователь.Код));
	КонецЕсли;
	
	Возврат ПользовательИБ;
	
КонецФункции

&НаСервере
Функция ПолучитьХранилищеНастроек(Имя)
	
	Хранилище = Неопределено;
	
	Если Имя = "Варианты отчетов"
		ИЛИ Имя = "Вариантыотчетов" Тогда
		
		Хранилище = Вычислить("ХранилищеВариантовОтчетов");
		
	ИначеЕсли Имя = "Настройки данных форм"
		ИЛИ Имя = "Настройкиданныхформ" Тогда
		
		Хранилище = Вычислить("ХранилищеНастроекДанныхФорм");
		
	ИначеЕсли Имя = "Общие настройки"
		ИЛИ Имя = "Общиенастройки" Тогда
		
		Хранилище = Вычислить("ХранилищеОбщихНастроек");
		
	ИначеЕсли Имя = "Настройки динамических списков"
		ИЛИ Имя = "Настройкидинамическихсписков" Тогда
		
		Хранилище = Вычислить("ХранилищеПользовательскихНастроекДинамическихСписков");
		
	ИначеЕсли Имя = "Пользовательские настройки отчетов"
		ИЛИ Имя = "Пользовательскиенастройкиотчетов" Тогда
		
		Хранилище = Вычислить("ХранилищеПользовательскихНастроекОтчетов");
		
	ИначеЕсли Имя = "Системные настройки"
		ИЛИ Имя = "Системныенастройки" Тогда
		
		Хранилище = Вычислить("ХранилищеСистемныхНастроек");
		
	КонецЕсли;	
	
	Возврат Хранилище;
	
КонецФункции

&НаСервере
Процедура ОчиститьХранилищеНастроек(Хранилище, ПользовательИБ, КлючОбъекта)
	
	Если Ложь Тогда
		Хранилище = ХранилищеВариантовОтчетов;
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени("");
	КонецЕсли;	
	
	Отбор = Новый Структура;
	Отбор.Вставить("Пользователь", ПользовательИБ.Имя);
	Отбор.Вставить("КлючОбъекта", КлючОбъекта);
	
	Попытка
		Выборка = Хранилище.Выбрать(Отбор);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Хранилище);
		Возврат;
	КонецПопытки; 
	
	Пока Выборка.Следующий() Цикл
		Хранилище.Удалить(Выборка.КлючОбъекта, Выборка.КлючНастроек, Выборка.Пользователь);
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКаталогаФайла(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = Результат[0];
	
	АдресФайла = СохранитьНастройкиНаСервере(Истина, УникальныйИдентификатор);
	ПолучитьФайл(АдресФайла, ИмяФайла, Ложь);
	
	Элементы.ИмяФайла.Заголовок = "Сохранено в";
	Элементы.ИмяФайла.Видимость = Истина;
	
КонецПроцедуры

&НаСервере	
Функция СохранитьНастройкиНаСервере(ПередаватьНаКлиента = Ложь, УникальныйИдентификатор = Неопределено)
	
	Если ПередаватьНаКлиента Тогда
		пИмяФайла = ПолучитьИмяВременногоФайла("xml");
	Иначе	
		пИмяФайла = ИмяФайла;
	КонецЕсли;	
	
	ПользовательИБ = ПолучитьПользователяИБ(Объект.Пользователь);
	
	ЗаписьXML = Новый ЗаписьXML;
	ЗаписьXML.ОткрытьФайл(пИмяФайла);
	ЗаписьXML.ЗаписатьНачалоЭлемента("Корень");
	
	Для Каждого СтрокаТЧ Из ВидыНастроек.ПолучитьЭлементы() Цикл
		
		Если НЕ СтрокаТЧ.Пометка Тогда
			Продолжить;
		КонецЕсли;	
		
		Попытка
			Хранилище = ПолучитьХранилищеНастроек(СтрокаТЧ.Имя);
		Исключение
			Сообщить(ОписаниеОшибки());
			Продолжить;
		КонецПопытки;	
		
		Если Хранилище <> Неопределено Тогда
			СохранитьХранилищеНастроек(ЗаписьXML, Хранилище, СтрЗаменить(СтрокаТЧ.Имя, " ", ""), ПользовательИБ);
		КонецЕсли;	
			
	КонецЦикла;	
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	ЗаписьXML.Закрыть();
	
	Если ПередаватьНаКлиента Тогда
		
		ДвоичныеДанные = Новый ДвоичныеДанные(пИмяФайла);
		Адрес = ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
		Возврат Адрес;
		
	КонецЕсли;	
	
КонецФункции

&НаСервере
Процедура СохранитьХранилищеНастроек(ЗаписьXML, Хранилище, Имя, ПользовательИБ)
	
	Хранилище      = ХранилищеНастроекДанныхФорм;
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени("");	
	
	ЗаписьXML.ЗаписатьНачалоЭлемента(Имя);
	
	Отбор = Новый Структура;
	Отбор.Вставить("Пользователь", ПользовательИБ.Имя);
	
	Выборка = Хранилище.Выбрать(Отбор);
	Пока Выборка.Следующий() Цикл
		
		ТипЗначения = ТипЗнч(Выборка.Настройки);
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Элемент");
		
		ЗаписатьЭлементXML(ЗаписьXML, "КлючНастроек",  Выборка.КлючНастроек);
		ЗаписатьЭлементXML(ЗаписьXML, "КлючОбъекта",   Выборка.КлючОбъекта);
		ЗаписатьЭлементXML(ЗаписьXML, "Пользователь",  Выборка.Пользователь);
		ЗаписатьЭлементXML(ЗаписьXML, "Представление", Выборка.Представление);
		
		ЗаписьXML.ЗаписатьНачалоЭлемента("Значение");
		
		Если ТипЗначения = Тип("Строка") ИЛИ ТипЗначения = Тип("Число") ИЛИ ТипЗначения = Тип("Булево") Тогда			
			ЗаписатьXML(ЗаписьXML, Выборка.Настройки);			
		Иначе				
			Хранилище = Новый ХранилищеЗначения(Выборка.Настройки);
			ЗаписатьXML(ЗаписьXML, Хранилище);			
		КонецЕсли;	
			
		ЗаписьXML.ЗаписатьКонецЭлемента();
			
		ЗаписьXML.ЗаписатьКонецЭлемента();
		
	КонецЦикла;
	
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьЭлементXML(ЗаписьXML, Имя, Значение)
	
	ЗаписьXML.ЗаписатьНачалоЭлемента(Имя);
	ЗаписьXML.ЗаписатьТекст(XMLСтрока(Значение));
	ЗаписьXML.ЗаписатьКонецЭлемента();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораНастроек(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = Результат[0];
	
	АдресФайла = "";
    ПоместитьФайл(АдресФайла, ИмяФайла,, Ложь, УникальныйИдентификатор);
	
	ВосстановитьНастройкиНаСервере(АдресФайла);
	
	Элементы.ИмяФайла.Заголовок = "Восстановлено из:";
	Элементы.ИмяФайла.Видимость = Истина;

КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиНаСервере(АдресФайла = Неопределено)
	
	ЧтениеXML = Новый ЧтениеXML;
	
	Если АдресФайла = Неопределено Тогда
		ЧтениеXML.ОткрытьФайл(ИмяФайла);
	Иначе	
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xml");
		
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла);
		ДвоичныеДанные.Записать(ИмяВременногоФайла);
		
		ЧтениеXML.ОткрытьФайл(ИмяВременногоФайла);
	КонецЕсли;	
	
	Хранилище = Неопределено;
		
	Пока ЧтениеXML.Прочитать() Цикл
		
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			
			ИмяЭлемента = ЧтениеXML.Имя;
			
			Попытка
				ТекХранилище = ПолучитьХранилищеНастроек(ИмяЭлемента);
			Исключение
				Продолжить;
			КонецПопытки;	
		
			Если ТекХранилище <> Неопределено Тогда
				Хранилище = ТекХранилище;
			КонецЕсли;
			
			Если ИмяЭлемента = "Элемент" Тогда
				
				СтруктураДанных = Новый Структура("КлючНастроек, КлючОбъекта, Пользователь, Представление, Значение", "", "", "", "", Неопределено);
				
			ИначеЕсли ИмяЭлемента = "Значение" Тогда
				
				ЧтениеXML.Прочитать();
				Значение = ПрочитатьXML(ЧтениеXML);
				
				Если ТипЗнч(Значение) = Тип("ХранилищеЗначения") Тогда
					СтруктураДанных.Вставить(ИмяЭлемента, Значение.Получить());
				Иначе	
					СтруктураДанных.Вставить(ИмяЭлемента, Значение);
				КонецЕсли;	
				
			КонецЕсли;	
			
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.Текст Тогда
			
			СтруктураДанных.Вставить(ИмяЭлемента, ЧтениеXML.Значение);
			
		ИначеЕсли ЧтениеXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
			
			Если ЧтениеXML.Имя = "Элемент" Тогда
				
				Хранилище = ХранилищеНастроекДанныхФорм;
		
				Хранилище.Сохранить(СтруктураДанных.КлючОбъекта, СтруктураДанных.КлючНастроек, СтруктураДанных.Значение, СтруктураДанных.Представление, СтруктураДанных.Пользователь);
				Сообщить("" + СтруктураДанных.КлючОбъекта + ", " + СтруктураДанных.КлючНастроек + ", " + СтруктураДанных.Пользователь);
				
			КонецЕсли;	
			
		КонецЕсли;	
		
	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокРолей()
	
	МассивРолей = Новый Массив;
	
	Для Каждого Роль Из Метаданные.Роли Цикл
		СписокРолейМетаданных.Добавить(Роль.Имя, Роль.Синоним,, БиблиотекаКартинок.ЗакрытыйКлюч);	
	КонецЦикла;		
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокРолейДляОтметкиНаСервере(СтрокаПоиска)
	
	СписокДляОтметки = Новый СписокЗначений;
	СтрокаПоискаВРег = ВРег(СокрЛП(СтрокаПоиска));
	
	Для Каждого ЭлементСписка Из СписокРолейМетаданных Цикл
		
		Если НЕ ПустаяСтрока(СтрокаПоискаВРег) Тогда
			ИмяВРег = ВРег(Строка(ЭлементСписка.Значение));
			СинонимВРег = ВРег(ЭлементСписка.Представление);
			Если СтрНайти(ИмяВРег, СтрокаПоискаВРег) = 0
				И СтрНайти(СинонимВРег, СтрокаПоискаВРег) = 0 Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		СписокДляОтметки.Добавить(
			ЭлементСписка.Значение, ЭлементСписка.Представление, ЭлементСписка.Пометка, ЭлементСписка.Картинка);
		
	КонецЦикла;
	
	Возврат СписокДляОтметки;
	
КонецФункции

&НаКлиенте
Функция СтрокаФильтраРолейДляВыбора(ТекстПоля)
	
	ТекстПоля = СокрЛП(ТекстПоля);
	
	Если ПустаяСтрока(ТекстПоля) ИЛИ СтрНайти(ТекстПоля, ",") > 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ТекстПоля;
	
КонецФункции

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница.Имя = "ГруппаСтраницаСравнениеРолей" Тогда
		ЗаполнитьСписокРолей();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыбраннаяРольНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОО = Новый ОписаниеОповещения("ПослеВыбораРолейСравнения", ЭтотОбъект);
	СтрокаФильтра = СтрокаФильтраРолейДляВыбора(Элемент.ТекстРедактирования);
	СписокДляОтметки = ПолучитьСписокРолейДляОтметкиНаСервере(СтрокаФильтра);
	Заголовок = "Выберите роли для сравнения";
	Если ЗначениеЗаполнено(СтрокаФильтра) Тогда
		Заголовок = Заголовок + " (найдено: " + Формат(СписокДляОтметки.Количество(), "ЧГ=0") + ")";
	КонецЕсли;
	
	СписокДляОтметки.ПоказатьОтметкуЭлементов(ОО, Заголовок);
	
КонецПроцедуры    

&НаКлиенте
Процедура ПослеВыбораРолейСравнения(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;                                                                        
	
	МассивРолейСравнения = Новый Массив;
	
	Для Каждого Строка Из Результат Цикл
		
		ЭлементОсновногоСписка = СписокРолейМетаданных.НайтиПоЗначению(Строка.Значение);
		Если ЭлементОсновногоСписка <> Неопределено Тогда
			ЭлементОсновногоСписка.Пометка = Строка.Пометка;
		КонецЕсли;
		
		Если Строка.Пометка Тогда
			МассивРолейСравнения.Добавить(Строка);
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивРолейСравнения.Количество() Тогда
		Элементы.СравнитьРолиМетаданных.Доступность = Истина;
		ВыбраннаяРоль = СтрСоединить(МассивРолейСравнения, ", ");
	Иначе
		Элементы.СравнитьРолиМетаданных.Доступность = Ложь;
		ВыбраннаяРоль = "";	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбраннаяРольОчистка(Элемент, СтандартнаяОбработка)
	
	СписокРолейМетаданных.Очистить();
	ЗаполнитьСписокРолей();	
	Элементы.СравнитьРолиМетаданных.Доступность = Ложь;
	
	ИтоговаяТаблицаСравненияРолей.Очистить();
	
КонецПроцедуры      

&НаКлиенте
Процедура СравнитьРолиМетаданных(Команда)
	
	ИтоговаяТаблицаСравненияРолей.Очистить();
	СравнитьРолиМетаданныхНаСервере();       
	
	Элементы.ПоказатьВОбработке.Доступность = ?(ИтоговаяТаблицаСравненияРолей.Количество(), Истина, Ложь);	
		
КонецПроцедуры  

&НаСервере                                                             
Процедура СравнитьРолиМетаданныхНаСервере()	
	
	РолиМТД = Новый Массив;
	
	Для Каждого Строка Из СписокРолейМетаданных Цикл	
		Если Строка.Пометка Тогда
			РолиМТД.Добавить(Метаданные.Роли.Найти(Строка.Значение));
		КонецЕсли;	
	КонецЦикла;
	
	Для Каждого Строка Из РолиМТД Цикл
		
		Для Каждого ОМ Из ТаблицаКонфигурации Цикл 
			
			ТекОбъектМТД = Метаданные.НайтиПоПолномуИмени(ОМ.ПолноеИмя);
			Если ТекОбъектМТД = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Попытка             
				
				Если ПравоДоступа("Использование", ТекОбъектМТД, Метаданные.Роли.Найти(Строка.Имя)) Тогда	 
					
					СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
					
					Если НЕ СтрокаНайдена.Количество() Тогда 
						НоваяСтрока = ТаблицаВхождений.Добавить();
						НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
						НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя;
						НоваяСтрока.ПолныйСиноним = ОМ.Синоним; 
						НоваяСтрока.Картинка = ОМ.Картинка;
					КонецЕсли;
					
				КонецЕсли;
				
			Исключение
			КонецПопытки;
			
			Попытка 
				
				СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
				
				Если НЕ СтрокаНайдена.Количество() Тогда      
					
					Если ПравоДоступа("Чтение", ТекОбъектМТД, Метаданные.Роли.Найти(Строка.Имя)) Тогда
						НоваяСтрока = ТаблицаВхождений.Добавить();
						НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
						НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя;
						НоваяСтрока.ПолныйСиноним = ОМ.Синоним;
						НоваяСтрока.Картинка = ОМ.Картинка;
					КонецЕсли;                                                 
					
				КонецЕсли;
				
			Исключение
			КонецПопытки;
			
			Попытка 
				
				СтрокаНайдена = ТаблицаВхождений.НайтиСтроки(Новый Структура("ОбъектМетаданныхИмя", ОМ.Имя));   
				
				Если НЕ СтрокаНайдена.Количество() Тогда   
					
					Если ПравоДоступа("Просмотр", ТекОбъектМТД, Метаданные.Роли.Найти(Строка.Имя)) Тогда
						НоваяСтрока = ТаблицаВхождений.Добавить();
						НоваяСтрока.ОбъектМетаданныхИмя = ОМ.Имя; 
						НоваяСтрока.ОбъектМетаданныхПолноеИмя = ОМ.ПолноеИмя;
						НоваяСтрока.ПолныйСиноним = ОМ.Синоним;  
						НоваяСтрока.Картинка = ОМ.Картинка;
					КонецЕсли;                                             
					
				КонецЕсли;
				
			Исключение
			КонецПопытки; 
			
		КонецЦикла;
		
		НоваяСтрока = ИтоговаяТаблицаСравненияРолей.Добавить();
		НоваяСтрока.Имя = Строка.Имя;
		НоваяСтрока.Картинка = БиблиотекаКартинок.ЗакрытыйКлюч;
		НоваяСтрока.ЭтоРоль = Истина;
		
		Для Каждого СтрокаОМ Из ТаблицаВхождений Цикл
			
			НоваяСтрока = ИтоговаяТаблицаСравненияРолей.Добавить();
			НоваяСтрока.Имя = СтрокаОМ.ОбъектМетаданныхПолноеИмя;
			НоваяСтрока.Картинка = СтрокаОМ.Картинка;
			
		КонецЦикла;
		
		ТаблицаВхождений.Очистить();
		
	КонецЦикла;  
	
	Для Каждого Строка Из ИтоговаяТаблицаСравненияРолей Цикл
		
		Если Строка.ЭтоРоль Тогда
			МетаРоль = Метаданные.Роли.Найти(Строка.Имя);
			Продолжить;	                          
		КонецЕсли;
		
		НайденныйОбъект = Метаданные.НайтиПоПолномуИмени(Строка.Имя); 
				
		НачалоТочки = СтрНайти(Строка.Имя, ".") -1;
		ВидОбъекта = Сред(Строка.Имя, 0, НачалоТочки);
		
		Если ВидОбъекта = "Обработка" ИЛИ ВидОбъекта = "Отчет" Тогда
			
			Если ПравоДоступа("Использование", НайденныйОбъект, МетаРоль) Тогда				
				
				Строка.Использование = Истина;
				
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "Справочник" ИЛИ ВидОбъекта = "ПланВидовХарактеристик" ИЛИ ВидОбъекта = "ПланСчетов" ИЛИ ВидОбъекта = "ПланВидовРасчета" Тогда
			
			
			Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда
				
				Строка.Чтение = Истина;
				
				Если ПравоДоступа("Изменение", НайденныйОбъект, МетаРоль) Тогда
					Строка.Изменение = Истина;	
				КонецЕсли; 
				Если ПравоДоступа("Добавление", НайденныйОбъект, МетаРоль) Тогда
					Строка.Добавление = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Редактирование", НайденныйОбъект, МетаРоль) Тогда
					Строка.Редактирование = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Удаление", НайденныйОбъект, МетаРоль) Тогда
					Строка.Удаление = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "Документ" Тогда	
			
			Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда				
				
				Строка.Чтение = Истина;
				
				Если ПравоДоступа("Изменение", НайденныйОбъект, МетаРоль) Тогда
					Строка.Изменение = Истина;	
				КонецЕсли; 
				Если ПравоДоступа("Добавление", НайденныйОбъект, МетаРоль) Тогда
					Строка.Добавление = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Редактирование", НайденныйОбъект, МетаРоль) Тогда
					Строка.Редактирование = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Проведение", НайденныйОбъект, МетаРоль) Тогда
					Строка.Проведение = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Удаление", НайденныйОбъект, МетаРоль) Тогда
					Строка.Удаление = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "Константа" ИЛИ ВидОбъекта = "РегистрРасчета" Тогда
			
			Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда				
				
				Строка.Чтение = Истина;
				
				Если ПравоДоступа("Изменение", НайденныйОбъект, МетаРоль) Тогда
					Строка.Изменение = Истина;	
				КонецЕсли; 
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Редактирование", НайденныйОбъект, МетаРоль) Тогда
					Строка.Редактирование = Истина;	
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "ЖурналДокументов" Тогда
			
			Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда				
				
				Строка.Чтение = Истина;
				
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "РегистрСведений" ИЛИ ВидОбъекта = "РегистрНакопления" ИЛИ ВидОбъекта = "РегистрБухгалтерии" Тогда	
			
			Если ПравоДоступа("Чтение", НайденныйОбъект, МетаРоль) Тогда				
				
				Строка.Чтение = Истина;
				
				Если ПравоДоступа("Изменение", НайденныйОбъект, МетаРоль) Тогда
					Строка.Изменение = Истина;	
				КонецЕсли; 
				Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда
					Строка.Просмотр = Истина;	
				КонецЕсли;
				Если ПравоДоступа("Редактирование", НайденныйОбъект, МетаРоль) Тогда
					Строка.Редактирование = Истина;	
				КонецЕсли;
				Если ПравоДоступа("УправлениеИтогами", НайденныйОбъект, МетаРоль) Тогда
					Строка.УправлениеИтогами = Истина;	
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ВидОбъекта = "Подсистема" Тогда
			
			Если ПравоДоступа("Просмотр", НайденныйОбъект, МетаРоль) Тогда				
				Строка.Просмотр = Истина;		
			КонецЕсли;
			
		КонецЕсли;		
		
	КонецЦикла;
	
	ТЗКопия = РеквизитФормыВЗначение("ИтоговаяТаблицаСравненияРолей");

	ОписаниеТипаЧисло = Новый ОписаниеТипов("Число");
	
	АгрегированныеРоли = Новый ТаблицаЗначений;
	АгрегированныеРоли.Колонки.Добавить("Имя", Новый ОписаниеТипов("Строка"));
	АгрегированныеРоли.Колонки.Добавить("Чтение", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Изменение", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Добавление", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Удаление", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Просмотр", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Редактирование", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Проведение", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Использование", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("УправлениеИтогами", ОписаниеТипаЧисло);
	АгрегированныеРоли.Колонки.Добавить("Картинка", Новый ОписаниеТипов("Картинка"));
	АгрегированныеРоли.Колонки.Добавить("ЭтоРоль", ОписаниеТипаЧисло);
	
	НоваяСтрока = ИтоговаяТаблицаСравненияРолей.Добавить();
	НоваяСтрока.Имя = "Итоговые показатели доступа при сложении ролей";
	НоваяСтрока.ЭтоРоль = Истина; 
	НоваяСтрока.Картинка = БиблиотекаКартинок.ПроизвольноеВыражение;
	
	ОдиночныеРоли = ТЗКопия.СкопироватьКолонки();
	
	Для Каждого Строка Из ИтоговаяТаблицаСравненияРолей Цикл
		
		Если Строка.ЭтоРоль Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокиРолей = ИтоговаяТаблицаСравненияРолей.НайтиСтроки(Новый Структура("Имя", Строка.Имя));
		
		Если СтрокиРолей.Количество() = 1 Тогда
			
			ЗаполнитьЗначенияСвойств(ОдиночныеРоли.Добавить(), Строка);
	
		ИначеЕсли СтрокиРолей.Количество() > 1 Тогда
			
			Для Каждого Строка Из СтрокиРолей Цикл	
				ЗаполнитьЗначенияСвойств(АгрегированныеРоли.Добавить(), Строка);				
			КонецЦикла;
					
		КонецЕсли;
		
		Если АгрегированныеРоли.Количество() Тогда
			
			АгрегированныеРоли.Свернуть("Имя, Картинка", "Чтение, Изменение, Добавление, Удаление, Просмотр, Редактирование, Проведение, Использование, УправлениеИтогами");
			
		КонецЕсли;
			
	КонецЦикла; 
	
	Для Каждого Строка Из ОдиночныеРоли Цикл
		ЗаполнитьЗначенияСвойств(ИтоговаяТаблицаСравненияРолей.Добавить(), Строка);	
	КонецЦикла;                            
	
	Для Каждого Строка Из АгрегированныеРоли Цикл
		ЗаполнитьЗначенияСвойств(ИтоговаяТаблицаСравненияРолей.Добавить(), Строка);		
	КонецЦикла;  
			
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВОбработке(Команда)
	
	ТекДанные = Элементы.ИтоговаяТаблицаСравненияРолей.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Оповестить("ПоказатьОбъектВДереве", Новый Структура("ТекОбъект", ТекДанные.Имя));
	
КонецПроцедуры

&НаКлиенте
Процедура СравнениеГруппПредставлениеОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура("Ключ", Элементы.СравнениеГрупп.ТекущиеДанные.ГруппаДоступа);
	ОткрытьФорму("Справочник.ГруппыДоступа.Форма.ФормаЭлемента", ПараметрыОткрытия, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура СравнениеПрофилейПредставлениеОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура("Ключ", Элементы.СравнениеПрофилей.ТекущиеДанные.Профиль);
	ОткрытьФорму("Справочник.ПрофилиГруппДоступа.Форма.ФормаЭлемента", ПараметрыОткрытия, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСписокПрофилей(Команда)
	
	Если Элементы.СравнениеРолей.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("ОбъектПроверки", Элементы.СравнениеРолей.ТекущиеДанные.Роль);
