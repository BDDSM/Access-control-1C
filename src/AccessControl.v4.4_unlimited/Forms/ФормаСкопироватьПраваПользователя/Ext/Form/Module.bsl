
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗапуститьСравнениеРолейПослеОткрытия = Ложь;
	
	ЭтотОбъект.Пользователь = ПараметрыСеанса.АвторизованныйПользователь;  
	Элементы.СравнитьРолиМетаданных.Доступность = Ложь;
	Элементы.ПоказатьВОбработке.Доступность = Ложь;
	
	ЗаполнитьТаблицуНастроек();
	
	СтрокаСвойств = ("Источник, Организация, Должность");
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, СтрокаСвойств);
	
	ПодготовитьСравнениеРолейИзПараметров();
	
	КоллекцииОбъектовМетаданных = Новый ТаблицаЗначений;
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Имя");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Синоним");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Картинка");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("КартинкаОбъекта");
	
	Если СтрНайти(Метаданные.Синоним, "Управление торговлей") > 0 Тогда	
		ИмяКонфигурации = "УТ";
	ИначеЕсли СтрНайти(Метаданные.Синоним, "Комплексная автоматизация") > 0 Тогда
		ИмяКонфигурации = "КА";
	КонецЕсли;
	
	ЗаполнитьМетаЗначения(ИмяКонфигурации);
			
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗапуститьСравнениеРолейПослеОткрытия Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаСравнениеРолей;
		СравнитьРолиМетаданных(Неопределено);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Организация) Тогда
		ЭтотОбъект.УчитыватьОрганизацию = Истина;
		Элементы.ДекорацияОрганизация.Заголовок = Организация;
		Элементы.ДекорацияОрганизация.ЦветТекста = WebЦвета.Зеленый;
	Иначе
		Элементы.ДекорацияОрганизация.Заголовок = "Не удалось определить организацию";
		Элементы.ДекорацияОрганизация.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект.Должность) Тогда		
		ЭтотОбъект.УчитыватьДолжность = Истина;
		Элементы.ДекорацияДолжность.Заголовок = Должность;
		Элементы.ДекорацияДолжность.ЦветТекста = WebЦвета.Зеленый;
	Иначе
		Элементы.ДекорацияДолжность.Заголовок = "Не удалось определить должность";
		Элементы.ДекорацияДолжность.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьМетаЗначения(ИмяКонфигурации)
	
	СписокМетаданных.Добавить("Подсистемы", 			 "Подсистемы", 				  Истина, БиблиотекаКартинок.Подсистема);
	СписокМетаданных.Добавить("ОбщиеФормы", 			 "Общие формы", 			  Истина, БиблиотекаКартинок.Форма); 
	СписокМетаданных.Добавить("Константы", 				 "Константы", 				  Истина, БиблиотекаКартинок.Константа);
	СписокМетаданных.Добавить("Справочники", 			 "Справочники", 		      Истина, БиблиотекаКартинок.Справочник);
	СписокМетаданных.Добавить("ЖурналыДокументов", 		 "Журналы документов",        Истина, БиблиотекаКартинок.ЖурналДокументов);
	СписокМетаданных.Добавить("Документы", 				 "Документы", 				  Истина, БиблиотекаКартинок.Документ);
	//СписокМетаданных.Добавить("Перечисления", 			 "Перечисления", 			  Истина, БиблиотекаКартинок.Перечисление);
	СписокМетаданных.Добавить("Отчеты", 				 "Отчеты", 					  Истина, БиблиотекаКартинок.Отчет);
	СписокМетаданных.Добавить("Обработки",  			 "Обработки", 				  Истина, БиблиотекаКартинок.Обработка);
	СписокМетаданных.Добавить("ПланыВидовХарактеристик", "Планы видов характеристик", Истина, БиблиотекаКартинок.ПланВидовХарактеристик);
	СписокМетаданных.Добавить("ПланыВидовРасчета", 		 "Планы видов расчета", 	  Истина, БиблиотекаКартинок.ПланВидовРасчета);
	СписокМетаданных.Добавить("РегистрыСведений", 		 "Регистры сведений", 		  Истина, БиблиотекаКартинок.РегистрСведений);
	СписокМетаданных.Добавить("РегистрыНакопления", 	 "Регистры накопления", 	  Истина, БиблиотекаКартинок.РегистрНакопления);
	СписокМетаданных.Добавить("РегистрыБухгалтерии", 	 "Регистры бухгалтерии", 	  Истина, БиблиотекаКартинок.РегистрБухгалтерии);
	СписокМетаданных.Добавить("РегистрыРасчета", 		 "Регистры расчета", 		  Истина, БиблиотекаКартинок.РегистрРасчета);
	СписокМетаданных.Добавить("БизнесПроцессы", 		 "Бизнес-процессы", 		  Истина, БиблиотекаКартинок.БизнесПроцесс);
	СписокМетаданных.Добавить("Задачи", 				 "Задачи", 					  Истина, БиблиотекаКартинок.Задача);
	СписокМетаданных.Добавить("ОбщиеКоманды", 			 "Общие команды", 			  Истина, ?(ИмяКонфигурации = "КА", 
																							  БиблиотекаКартинок.ВыполнениеНачалось32, 
																							  БиблиотекаКартинок.ПиктограммаДеталиВариантаАнализа)); 
	КоллекцииОбъектовМетаданных = Новый ТаблицаЗначений;
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Имя");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Синоним");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("Картинка");
	КоллекцииОбъектовМетаданных.Колонки.Добавить("КартинкаОбъекта");																						  
																							  																							  
	Для Каждого Мета Из СписокМетаданных Цикл	
		НоваяСтрокаКоллекцииОбъектовМетаданных(Мета.Значение, Мета.Представление, Мета.Картинка, Мета.Картинка, КоллекцииОбъектовМетаданных);		
	КонецЦикла; 
	
	Для Каждого СтрокаКоллекции Из КоллекцииОбъектовМетаданных Цикл
		
		Для Каждого ОбъектМетаданных Из Метаданные[СтрокаКоллекции.Имя] Цикл
						
			НоваяСтрока = ТаблицаКонфигурации.Добавить(); 
			НоваяСтрока.Имя       = ОбъектМетаданных.Имя;
			НоваяСтрока.ПолноеИмя = ОбъектМетаданных.ПолноеИмя();
			НоваяСтрока.Синоним   = ОбъектМетаданных.Синоним;
			НоваяСтрока.Картинка  = СтрокаКоллекции.КартинкаОбъекта;
			
		КонецЦикла;
		
	КонецЦикла;	
																							  
КонецПроцедуры

&НаСервере
Процедура НоваяСтрокаКоллекцииОбъектовМетаданных(Имя, Синоним, Картинка, КартинкаОбъекта, Таб)
	
	НоваяСтрока = Таб.Добавить();
	НоваяСтрока.Имя               = Имя;
	НоваяСтрока.Синоним           = Синоним;
	НоваяСтрока.Картинка          = Картинка;
	НоваяСтрока.КартинкаОбъекта   = КартинкаОбъекта;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СкопироватьПрава(Команда)
	
	Если НЕ ЗначениеЗаполнено(Источник) И НЕ ЗначениеЗаполнено(Приемник) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите пользователей в качестве источника и приемника прав",, "Источник");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Источник) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите пользователя в качестве источника прав",, "Источник");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Приемник) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Укажите пользователя в качестве приемника прав",, "Приемник");
		Возврат;
	КонецЕсли;
	
	ОО = Новый ОписаниеОповещения("ПослеПодтвержденияКопирования", ЭтотОбъект);
	ПоказатьВопрос(ОО, "Вы уверены, что хотите скопировать права?", РежимДиалогаВопрос.ДаНет,,, "Подтвердите действие");
	
КонецПроцедуры

&НаКлиенте
Процедура ПодобратьИсточник(Команда)
	
	Если НЕ ЗначениеЗаполнено(Источник) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите пользователя в качестве источника прав");
		Возврат;
	КонецЕсли;
	
	Элементы.СравнениеРолей.Видимость = Ложь;
	Элементы.СравнениеГрупп.Видимость = Ложь;
	Элементы.СравнениеПрофилей.Видимость = Ложь;
	Элементы.ПользователиНаПодбор.Видимость = Истина;
	Элементы.ГруппаГоризонт.Видимость = Ложь;
	
	ПодобратьИсточникНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПриемникаПрав(Команда)
	
	ЭтотОбъект.Источник = Элементы.ПользователиНаПодбор.ТекущиеДанные.Пользователь;
	ПолучитьКадровыеДанныеИсточника();
	
КонецПроцедуры

&НаКлиенте
Процедура СравнитьПрава(Команда)
	
	Если НЕ ЗначениеЗаполнено(Источник) И НЕ ЗначениеЗаполнено(Приемник) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите хотя бы одного пользователя, чтобы получить список прав");
		Возврат;				
	КонецЕсли;
	
	Элементы.ПользователиНаПодбор.Видимость = Ложь;
	Элементы.СравнениеРолей.Видимость = Истина;
	Элементы.СравнениеГрупп.Видимость = Истина;
	Элементы.СравнениеПрофилей.Видимость = Истина;
	Элементы.ГруппаГоризонт.Видимость = Истина;
	
	ИсточникЗаполнен = ЗначениеЗаполнено(Источник);
	ПриемникЗаполнен = ЗначениеЗаполнено(Приемник);
	
	Элементы.СравнениеРолейПользователь1.Видимость = ИсточникЗаполнен;
	Элементы.СравнениеГруппПользователь1.Видимость = ИсточникЗаполнен;
	Элементы.СравнениеПрофилейПользователь1.Видимость = ИсточникЗаполнен;
	
	Элементы.СравнениеРолейПользователь2.Видимость = ПриемникЗаполнен;
	Элементы.СравнениеГруппПользователь2.Видимость = ПриемникЗаполнен;
	Элементы.СравнениеПрофилейПользователь2.Видимость = ПриемникЗаполнен;
		
	СравнитьПраваНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоменятьМестами(Команда)
	
	Пользователь1 = Источник;
	Пользователь2 = Приемник;
	
	Источник = Пользователь2;
	Приемник = Пользователь1;
	
	ПолучитьКадровыеДанныеИсточника();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьРольДляОбработки(Команда)
	
	Если Элементы.СравнениеРолей.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Значение", Элементы.СравнениеРолей.ТекущиеДанные.ИмяРоли);
	ДопПараметры.Вставить("Представление", Элементы.СравнениеРолей.ТекущиеДанные.Представление);
	
	ОО = Новый ОписаниеОповещения("ПослеВыбораРоли", ЭтотОбъект, ДопПараметры);
	ПоказатьВопрос(ОО, "Перенести роль в форму анализа ролей?", РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Да, "Выбор роли");
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьСнятьВсе(Команда)
	
	ВариантОтметки = ?(Команда.Имя = "ОтметитьВсе", Истина, Ложь);
	
	Для Каждого Строка Из ВидыНастроек.ПолучитьЭлементы() Цикл
		
		Строка.Пометка = ВариантОтметки;
		
		Для Каждого СтрокаНастройки Из Строка.ПолучитьЭлементы() Цикл			
			СтрокаНастройки.Пометка = ВариантОтметки;				
		КонецЦикла;
				
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьНастройки(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Пользователь) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите пользователя",, "Пользователь");
		Возврат;
	КонецЕсли;		
	
	СтруктураНастроек = Новый Структура;	
	
	Для Каждого Строка Из ВидыНастроек.ПолучитьЭлементы() Цикл
		
		Для Каждого Настройка Из Строка.ПолучитьЭлементы() Цикл
						
			Если Настройка.Пометка Тогда
				Родитель = СтрЗаменить(Строка.Имя, " ", "");
				СтруктураНастроек.Вставить(Родитель, Настройка.Имя);
			КонецЕсли;
			
		КонецЦикла;
				
	КонецЦикла;
	
	Если НЕ СтруктураНастроек.Количество() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите настройки для очистки");
		Возврат;			
	КонецЕсли;
	
	СброситьНастройкиНаСервере(СтруктураНастроек);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	ОО = Новый ОписаниеОповещения("ПослеВыбораКаталогаФайла", ЭтотОбъект);
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.ПолноеИмяФайла = "Настройки [" + Объект.Пользователь + "]";
	Диалог.Заголовок = "Выберите каталог для сохранения файла";
	Диалог.Фильтр = "*.xml|*.xml";
	
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(ОО, Диалог);
		
КонецПроцедуры 

&НаКлиенте
Процедура ВосстановитьНастройки(Команда)
	
	ОО = Новый ОписаниеОповещения("ПослеВыбораНастроек", ЭтотОбъект);
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл с настройками";
	Диалог.Фильтр = "*.xml|*.xml";
	
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(ОО, Диалог);
	
	КоллекцияСтрок = ВидыНастроек.ПолучитьЭлементы();
	КоллекцияСтрок.Очистить();
	
	ЗаполнитьТаблицуНастроек();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура УчитыватьДолжностьПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Должность) Тогда		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось определить должность у источника прав");
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УчитыватьОрганизациюПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.Организация) Тогда		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось определить организацию у источника прав");
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникПриИзменении(Элемент)
	
	ПолучитьКадровыеДанныеИсточника();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмяФайлаОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ЗапуститьПриложение(ИмяФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ПользовательПриИзменении(Элемент)
	
	КоллекцияСтрок = ВидыНастроек.ПолучитьЭлементы();
	КоллекцияСтрок.Очистить();
	
	ЗаполнитьТаблицуНастроек();
	
КонецПроцедуры

&НаКлиенте
Процедура ВидыНастроек1ПриИзменении(Элемент)
	
	Если Элемент.ТекущиеДанные.ПолучитьРодителя() = Неопределено Тогда
		
		Для Каждого Строка Из Элемент.ТекущиеДанные.ПолучитьЭлементы() Цикл			
			Строка.Пометка = Элемент.ТекущиеДанные.Пометка;				
		КонецЦикла;
		
	Иначе
		
		ТекРодитель = Элемент.ТекущиеДанные.ПолучитьРодителя();
		ТекРодитель.Пометка = Элемент.ТекущиеДанные.Пометка;
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПодготовитьСравнениеРолейИзПараметров()
	
	Если НЕ Параметры.Свойство("РолиДляСравнения") Тогда
		Возврат;
	КонецЕсли;
	
	РолиДляСравнения = Параметры.РолиДляСравнения;
	
	Если ТипЗнч(РолиДляСравнения) <> Тип("Массив") Или РолиДляСравнения.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСписокРолей();
	
	МассивПредставлений = Новый Массив;
	
	Для Каждого ИмяРоли Из РолиДляСравнения Цикл
		
		ЭлементСписка = СписокРолейМетаданных.НайтиПоЗначению(ИмяРоли);
		
		Если ЭлементСписка <> Неопределено Тогда
			ЭлементСписка.Пометка = Истина;
		КонецЕсли;
		
		МетаРоль = Метаданные.Роли.Найти(ИмяРоли);
		
		Если МетаРоль <> Неопределено Тогда
			МассивПредставлений.Добавить(МетаРоль.Синоним);
		Иначе
			МассивПредставлений.Добавить(ИмяРоли);
		КонецЕсли;
		
	КонецЦикла;
	
	ВыбраннаяРоль = СтрСоединить(МассивПредставлений, ", ");
	Элементы.СравнитьРолиМетаданных.Доступность = Истина;
	
	Если Параметры.Свойство("ЗапуститьСравнениеРолейМетаданных") И Параметры.ЗапуститьСравнениеРолейМетаданных Тогда
		ЗапуститьСравнениеРолейПослеОткрытия = Истина;
	КонецЕсли;
	
КонецПроцедуры

