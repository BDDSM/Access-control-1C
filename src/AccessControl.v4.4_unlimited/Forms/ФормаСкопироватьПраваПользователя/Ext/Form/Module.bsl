&НаСервере
Процедура ДобавитьСтроку(Пометка, Имя)
	
	НоваяСтрока = ВидыНастроек.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Пометка = Пометка;
	НоваяСтрока.Имя     = Имя;
	                                  
	Выборка = ПолучитьХранилищеНастроек(Имя).Выбрать(Новый Структура("Пользователь", ПолучитьПользователяИБ(Пользователь).Имя));
	
	ВторойУровень = НоваяСтрока.ПолучитьЭлементы();
	
	Пока Выборка.Следующий() Цикл 
		СтрокаДерева = ВторойУровень.Добавить();
		СтрокаДерева.Имя = Выборка.КлючОбъекта;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПодтвержденияКопирования(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Попытка
			СкопироватьПраваНаСервере();
			ПоказатьОповещениеПользователя("Успешно!",,, БиблиотекаКартинок.Успешно);
			Закрыть();
		Исключение
			ПоказатьОповещениеПользователя("Произошла ошибка",,, БиблиотекаКартинок.Ошибка32);
		КонецПопытки;
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура СкопироватьПраваНаСервере()
	
	МодульУправлениеДоступомСлужебный = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступомСлужебный");
	МодульУправлениеДоступомСлужебный.ПриКопированииПравНовомуПользователю(Источник, Приемник);
	ПользователиСлужебный.СкопироватьГруппыПользователя(Источник, Приемник);
		
КонецПроцедуры

&НаСервере
Процедура ПодобратьИсточникНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Сотрудники.Ссылка КАК Сотрудник,
				   |	Пользователи.Ссылка КАК Пользователь,
	               |	ФизическиеЛица.Ссылка КАК ФизЛицо,
	               |	Сотрудники.ГоловнаяОрганизация КАК Организация,
	               |	КадроваяИсторияСотрудниковСрезПоследних.Должность КАК Должность
	               |ИЗ
	               |	Справочник.Пользователи КАК Пользователи
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	               |			ПО (Сотрудники.ФизическоеЛицо = ФизическиеЛица.Ссылка)
	               |			ПРАВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних КАК КадроваяИсторияСотрудниковСрезПоследних
	               |			ПО (КадроваяИсторияСотрудниковСрезПоследних.ФизическоеЛицо = ФизическиеЛица.Ссылка)
	               |		ПО Пользователи.ФизическоеЛицо = ФизическиеЛица.Ссылка
	               |ГДЕ
	               |	Пользователи.Ссылка <> &Источник
				   |	И КадроваяИсторияСотрудниковСрезПоследних.Должность = &Должность
	               |	И Сотрудники.ГоловнаяОрганизация = &Организация";
	
	Запрос.УстановитьПараметр("Источник", Источник);
	
	Если УчитыватьОрганизацию И УчитыватьДолжность Тогда		
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("Должность", Должность);		
	ИначеЕсли УчитыватьОрганизацию И НЕ УчитыватьДолжность Тогда		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И КадроваяИсторияСотрудниковСрезПоследних.Должность = &Должность", "");
		Запрос.УстановитьПараметр("Организация", Организация);
	ИначеЕсли НЕ УчитыватьОрганизацию И УчитыватьДолжность Тогда		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Сотрудники.ГоловнаяОрганизация = &Организация", "");
		Запрос.УстановитьПараметр("Должность", Должность);
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Подбор источника прав имеет смысл только с использованием отборов");
		Элементы.ПользователиНаПодбор.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если НЕ Результат.Количество() Тогда		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("К сожалению, похожий пользователь не найден, измените отборы и попробуйте снова");
		Элементы.ПользователиНаПодбор.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	ПользователиНаПодбор.Загрузить(Запрос.Выполнить().Выгрузить());
	Элементы.ПользователиНаПодбор.Видимость = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьКадровыеДанныеИсточника()
	
	Если Метаданные.НайтиПоПолномуИмени("Справочник.Сотрудники") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	ФизическиеЛица.Ссылка КАК ФизЛицо,
	|	Пользователи.Ссылка КАК Пользователь,
	|	Сотрудники.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	|	КадроваяИсторияСотрудниковСрезПоследних.Должность КАК Должность
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|			ПО (Сотрудники.ФизическоеЛицо = ФизическиеЛица.Ссылка)
	|			ПРАВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних КАК КадроваяИсторияСотрудниковСрезПоследних
	|			ПО (КадроваяИсторияСотрудниковСрезПоследних.ФизическоеЛицо = ФизическиеЛица.Ссылка)
	|		ПО Пользователи.ФизическоеЛицо = ФизическиеЛица.Ссылка
	|ГДЕ
	|	Пользователи.Ссылка = &Источник";
	
	Запрос.УстановитьПараметр("Источник", ЭтотОбъект.Источник);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаЗапроса = Результат.Выгрузить();
	
	ЭтотОбъект.Организация = ТаблицаЗапроса[0].ГоловнаяОрганизация;
	ЭтотОбъект.Должность   = ТаблицаЗапроса[0].Должность;
	
	Если УчитыватьОрганизацию <> Справочники.Организации.ПустаяСсылка() Тогда
		ЭтотОбъект.УчитыватьОрганизацию          = Истина;
		Элементы.ДекорацияОрганизация.Заголовок  = Строка(ЭтотОбъект.Организация);
		Элементы.ДекорацияОрганизация.ЦветТекста = WebЦвета.Зеленый;
	Иначе
		ЭтотОбъект.УчитыватьОрганизацию          = Ложь;
		Элементы.ДекорацияОрганизация.Заголовок  = "Не удалось определить организацию";
		Элементы.ДекорацияОрганизация.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
	
	Если УчитыватьДолжность <> Справочники.Должности.ПустаяСсылка() Тогда
		ЭтотОбъект.УчитыватьДолжность          = Истина;
		Элементы.ДекорацияДолжность.Заголовок  = Строка(ЭтотОбъект.Должность);
		Элементы.ДекорацияДолжность.ЦветТекста = WebЦвета.Зеленый;		
	Иначе
		ЭтотОбъект.УчитыватьДолжность          = Ложь;
		Элементы.ДекорацияДолжность.Заголовок  = "Не удалось определить должность";
		Элементы.ДекорацияДолжность.ЦветТекста = WebЦвета.Красный;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СравнитьПрофилиНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь,
	               |	ПрофилиГруппДоступаРоли.Ссылка КАК Профиль
	               |ПОМЕСТИТЬ ВТ_Пользователь1
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	               |		ПО ПрофилиГруппДоступаРоли.Ссылка = ГруппыДоступаПользователи.Ссылка.Профиль
	               |ГДЕ
	               |	ГруппыДоступаПользователи.Пользователь = &Пользователь1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь,
	               |	ПрофилиГруппДоступаРоли.Ссылка КАК Профиль
	               |ПОМЕСТИТЬ ВТ_Пользователь2
	               |ИЗ
	               |	Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	               |		ПО ПрофилиГруппДоступаРоли.Ссылка = ГруппыДоступаПользователи.Ссылка.Профиль
	               |ГДЕ
	               |	ГруппыДоступаПользователи.Пользователь = &Пользователь2
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(ВТ_Пользователь1.Профиль, ВТ_Пользователь2.Профиль) КАК Профиль,
	               |	ИСТИНА КАК КартинкаПрофиля,
	               |	ЕСТЬNULL(ВТ_Пользователь1.Профиль.Наименование, ВТ_Пользователь2.Профиль.Наименование) КАК ПредставлениеПрофиля,
	               |	ВЫБОР
	               |		КОГДА ВТ_Пользователь1.Пользователь ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Пользователь1,
	               |	ВЫБОР
	               |		КОГДА ВТ_Пользователь2.Пользователь ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Пользователь2,
	               |	ВЫБОР
	               |		КОГДА НЕ ВТ_Пользователь1.Пользователь ЕСТЬ NULL
	               |				И НЕ ВТ_Пользователь2.Пользователь ЕСТЬ NULL
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК СовпадениеПрофилей,
				   |	ЕСТЬNULL(ВТ_Пользователь1.Профиль.Наименование, ВТ_Пользователь2.Профиль.Наименование) КАК ИмяПрофиля
	               |ИЗ
	               |	ВТ_Пользователь2 КАК ВТ_Пользователь2
	               |		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_Пользователь1 КАК ВТ_Пользователь1
	               |		ПО (ВТ_Пользователь1.Профиль = ВТ_Пользователь2.Профиль)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СовпадениеПрофилей УБЫВ,
	               |	Пользователь1 УБЫВ,
	               |	Пользователь2 УБЫВ";
	
	Запрос.УстановитьПараметр("Пользователь1", Источник);
	Запрос.УстановитьПараметр("Пользователь2", Приемник);
	
	СравнениеПрофилей.Загрузить(Запрос.Выполнить().Выгрузить());
	
	Элементы.СравнениеПрофилей.ПодчиненныеЭлементы.СравнениеПрофилейПользователь1.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Источник.Наименование);
	Элементы.СравнениеПрофилей.ПодчиненныеЭлементы.СравнениеПрофилейПользователь2.Заголовок = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Приемник.Наименование); 
	
	Элементы.СтраницаСравнениеПрофилей.Заголовок = "По профилям (" + СравнениеПрофилей.Количество() + ")";
	
КонецПроцедуры

&НаСервере
Процедура СравнитьГруппыДоступаНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ГруппыДоступаПользователи.Пользователь КАК Пользователь,
